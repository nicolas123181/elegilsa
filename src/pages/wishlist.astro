---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wishlist | ELEGILSA" description="Tus productos favoritos guardados.">
  <section class="panel" style="margin-top: 1rem;">
    <h1 style="margin-top: 0;">Wishlist / Mis Favoritos</h1>
    <p style="color: var(--muted);">Aqui encontraras los productos a los que les has dado me gusta.</p>
    
    <div id="wishlist-empty" style="display: none;">
      <p>Aun no tienes productos en tu wishlist.</p>
      <a class="btn secondary" href="/collections/all">Ver productos</a>
    </div>

    <div id="wishlist-content" style="display: none;">
      <div id="wishlist-list" class="grid"></div>
    </div>
  </section>

  <script is:inline>
    const WISHLIST_KEY = 'elegilsa_wishlist_v2';
    const LEGACY_WISHLIST_KEY = 'elegilsa_wishlist_v1';
    const emptyEl = document.getElementById('wishlist-empty');
    const contentEl = document.getElementById('wishlist-content');
    const listEl = document.getElementById('wishlist-list');

    function formatEuros(cents) {
      return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format((cents || 0) / 100);
    }

    function normalizeWishlistItem(item) {
      if (!item || typeof item !== 'object') return null;
      const slug = typeof item.slug === 'string' ? item.slug.trim() : '';
      const name = typeof item.name === 'string' ? item.name.trim() : '';
      if (!slug || !name) return null;

      return {
        id: typeof item.id === 'string' ? item.id : null,
        slug,
        name,
        price_cents: Number.isFinite(Number(item.price_cents)) ? Math.max(0, Math.round(Number(item.price_cents))) : 0,
        image: typeof item.image === 'string' && item.image.trim() ? item.image.trim() : '/catalogo/placeholder.svg',
      };
    }

    function readWishlist() {
      try {
        const raw = localStorage.getItem(WISHLIST_KEY);
        const parsed = raw ? JSON.parse(raw) : [];
        if (Array.isArray(parsed) && parsed.length > 0) {
          return parsed.map(normalizeWishlistItem).filter((item) => item !== null);
        }
      } catch {}

      try {
        const rawLegacy = localStorage.getItem(LEGACY_WISHLIST_KEY);
        const parsedLegacy = rawLegacy ? JSON.parse(rawLegacy) : [];
        const migrated = Array.isArray(parsedLegacy)
          ? parsedLegacy.map(normalizeWishlistItem).filter((item) => item !== null)
          : [];
        if (migrated.length > 0) {
          localStorage.setItem(WISHLIST_KEY, JSON.stringify(migrated));
        }
        return migrated;
      } catch {
        return [];
      }
    }

    function writeWishlist(items) {
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(items));
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function removeWishlist(slug) {
      const next = readWishlist().filter((item) => item.slug !== slug);
      writeWishlist(next);
      render();
    }

    function render() {
      const wishlist = readWishlist();

      if (wishlist.length === 0) {
        emptyEl.style.display = 'block';
        contentEl.style.display = 'none';
        return;
      }

      emptyEl.style.display = 'none';
      contentEl.style.display = 'block';
      listEl.innerHTML = '';

      wishlist.forEach(item => {
        const safeSlug = encodeURIComponent(item.slug);
        const safeName = escapeHtml(item.name);
        const safeImage = escapeHtml(item.image || '/catalogo/placeholder.svg');
        const article = document.createElement('article');
        article.className = 'card';
        article.innerHTML = `
          <a href="/products/${safeSlug}" aria-label="Ver ${safeName}">
            <div class="card-media">
              <img src="${safeImage}" alt="${safeName}" loading="lazy" />
            </div>
            <div class="card-body">
              <h3 class="card-name">${safeName}</h3>
              <p class="price">
                <span>${formatEuros(item.price_cents)}</span>
              </p>
            </div>
          </a>
          <div style="padding: 0 1rem 1rem;">
            <button class="btn secondary" style="width: 100%;" data-action="remove" data-slug="${safeSlug}">Eliminar de Wishlist</button>
          </div>
        `;
        listEl.appendChild(article);
      });
    }

    listEl?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-action="remove"]');
      if (!button) return;
      event.preventDefault();
      const slug = button.getAttribute('data-slug');
      if (!slug) return;
      removeWishlist(decodeURIComponent(slug));
    });

    render();
  </script>
</Layout>