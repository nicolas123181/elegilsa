---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carrito | ELEGILSA" description="Revisa y ajusta tu carrito antes de pasar al checkout.">
  <section class="panel" style="margin-top: 1rem;">
    <h1 style="margin-top: 0;">Carrito</h1>
    <p id="cart-subtitle" style="color: var(--muted);">Revisa cantidades y stock disponible.</p>

    <div id="cart-empty" style="display: none;">
      <p>No tienes productos en el carrito.</p>
      <a class="btn secondary" href="/collections/all">Ir al catalogo</a>
    </div>

    <div id="cart-content" style="display: none;">
      <div id="cart-list" class="cart-list"></div>

      <div class="panel" style="margin-top: 1rem;">
        <div class="summary-line">
          <span>Subtotal</span>
          <strong id="cart-subtotal">0,00 €</strong>
        </div>
        <div class="summary-line">
          <span>Total articulos</span>
          <strong id="cart-items">0</strong>
        </div>

        <div class="checkout-actions">
          <button id="clear-cart" type="button" class="btn secondary">Vaciar carrito</button>
          <a class="btn" href="/checkout">Continuar al checkout</a>
        </div>
      </div>
    </div>

    <p id="cart-feedback" class="alert" style="display: none; margin-top: 1rem;"></p>
  </section>

  <script is:inline>
    const CART_KEY = 'elegilsa_cart_v1';

    const emptyEl = document.getElementById('cart-empty');
    const contentEl = document.getElementById('cart-content');
    const listEl = document.getElementById('cart-list');
    const subtotalEl = document.getElementById('cart-subtotal');
    const itemsEl = document.getElementById('cart-items');
    const feedbackEl = document.getElementById('cart-feedback');
    const clearBtn = document.getElementById('clear-cart');

    function formatEuros(cents) {
      return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format((cents || 0) / 100);
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function showFeedback(type, message) {
      feedbackEl.textContent = message;
      feedbackEl.classList.remove('ok', 'danger');
      feedbackEl.classList.add(type === 'ok' ? 'ok' : 'danger');
      feedbackEl.style.display = 'block';
    }

    function readCart() {
      try {
        const raw = localStorage.getItem(CART_KEY);
        const parsed = raw ? JSON.parse(raw) : [];
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function writeCart(items) {
      localStorage.setItem(CART_KEY, JSON.stringify(items));
    }

    function normalizeCart(items) {
      return items.map((item) => {
        const stock = Math.max(0, Number(item.stock || 0));
        let quantity = Math.max(0, Number(item.quantity || 0));
        if (stock > 0) quantity = Math.min(quantity, stock);
        if (stock === 0) quantity = 0;
        return {
          ...item,
          key: String(item.key || `${item.productId || 'item'}::${item.variantId || 'no-variant'}`),
          name: String(item.name || 'Producto'),
          variantName: String(item.variantName || 'Variante unica'),
          imageUrl: String(item.imageUrl || '/catalogo/placeholder.svg'),
          unitPriceCents: Math.max(0, Math.round(Number(item.unitPriceCents || 0))),
          quantity,
          stock,
        };
      }).filter((item) => item.quantity > 0);
    }

    function render() {
      let cart = normalizeCart(readCart());
      writeCart(cart);

      if (cart.length === 0) {
        emptyEl.style.display = 'block';
        contentEl.style.display = 'none';
        return;
      }

      emptyEl.style.display = 'none';
      contentEl.style.display = 'block';

      listEl.innerHTML = '';

      for (const item of cart) {
        const safeName = escapeHtml(item.name || 'Producto');
        const safeVariant = escapeHtml(item.variantName || 'Variante unica');
        const safeImage = escapeHtml(item.imageUrl || '/catalogo/placeholder.svg');
        const safeKey = escapeHtml(item.key);
        const wrapper = document.createElement('article');
        wrapper.className = 'cart-item';
        wrapper.innerHTML = `
          <img class="cart-image" src="${safeImage}" alt="${safeName}" />
          <div>
            <p style="margin: 0; font-weight: 700;">${safeName}</p>
            <p style="margin: 0.3rem 0; color: var(--muted);">${safeVariant}</p>
            <p style="margin: 0;">Stock disponible: <strong>${item.stock}</strong></p>
            <div class="qty-control" style="margin-top: 0.5rem;">
              <button class="qty-btn" type="button" data-action="dec" data-key="${safeKey}">-</button>
              <input class="qty" type="number" min="1" max="${Math.max(item.stock, 1)}" value="${item.quantity}" data-action="input" data-key="${safeKey}" />
              <button class="qty-btn" type="button" data-action="inc" data-key="${safeKey}">+</button>
            </div>
          </div>
          <div style="display: grid; gap: 0.5rem; justify-items: end;">
            <strong>${formatEuros((item.unitPriceCents || 0) * item.quantity)}</strong>
            <button class="btn secondary" type="button" data-action="remove" data-key="${safeKey}">Quitar</button>
          </div>
        `;
        listEl.appendChild(wrapper);
      }

      const subtotal = cart.reduce((acc, item) => acc + (item.unitPriceCents || 0) * item.quantity, 0);
      const totalItems = cart.reduce((acc, item) => acc + item.quantity, 0);
      subtotalEl.textContent = formatEuros(subtotal);
      itemsEl.textContent = String(totalItems);

      listEl.querySelectorAll('[data-action]').forEach((control) => {
        control.addEventListener('click', handleControl);
      });

      listEl.querySelectorAll('input[data-action="input"]').forEach((input) => {
        input.addEventListener('change', handleControl);
      });
    }

    function handleControl(event) {
      const target = event.currentTarget;
      const action = target.getAttribute('data-action');
      const key = target.getAttribute('data-key');
      let cart = normalizeCart(readCart());
      const item = cart.find((row) => row.key === key);
      if (!item) return;

      if (action === 'remove') {
        cart = cart.filter((row) => row.key !== key);
      }

      if (action === 'dec') {
        item.quantity = Math.max(1, item.quantity - 1);
      }

      if (action === 'inc') {
        if (item.quantity >= item.stock) {
          showFeedback('danger', `No puedes superar el stock (${item.stock}) para ${item.name}.`);
        }
        item.quantity = Math.min(item.stock, item.quantity + 1);
      }

      if (action === 'input') {
        const nextQty = Number(target.value || '1');
        if (!Number.isFinite(nextQty) || nextQty < 1) {
          item.quantity = 1;
        } else {
          if (nextQty > item.stock) {
            showFeedback('danger', `No puedes superar el stock (${item.stock}) para ${item.name}.`);
          }
          item.quantity = Math.min(item.stock, Math.max(1, Math.round(nextQty)));
        }
      }

      writeCart(normalizeCart(cart));
      render();
    }

    clearBtn?.addEventListener('click', () => {
      localStorage.removeItem(CART_KEY);
      render();
      showFeedback('ok', 'Carrito vaciado.');
    });

    render();
  </script>
</Layout>
