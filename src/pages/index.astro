---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getFeaturedProducts } from '../lib/store';

const products = await getFeaturedProducts(8);
---

<Layout
	title="ELEGILSA | Novedades"
	description="Descubre las ultimas novedades de ELEGILSA con compra online y carrito en tiempo real."
>
	<section class="hero">
		<div>
			<p class="hero-kicker">Nueva temporada 2026</p>
			<h1>Descubre las ultimas novedades</h1>
			<p>
				Colecciones con estilo diario, prendas especiales y complementos para elevar cada look. Compra online
				con total facilidad.
			</p>
			<div class="hero-actions">
				<a class="btn" href="/collections/all">Comprar ahora</a>
				<a class="btn secondary" href="/wishlist" data-requires-auth="wishlist">Ver favoritos</a>
			</div>
			<div class="hero-trust">
				<span>Envio 24/48h</span>
				<span>Pago seguro</span>
				<span>Cambios faciles</span>
			</div>
		</div>
		<div class="hero-card">
			<img src="/catalogo/vestido-alma/01.svg" alt="Portada de novedades ELEGILSA" loading="eager" />
		</div>
	</section>

	<section>
		<div class="section-title">
			<h2>NOVEDADES</h2>
			<a href="/collections/all">Ver todo</a>
		</div>
		<div class="grid">
			{products.map((product) => <ProductCard product={product} />)}
		</div>
	</section>
</Layout>
