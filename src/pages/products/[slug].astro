---
import Layout from '../../layouts/Layout.astro';
import { resolveImageUrl } from '../../lib/images';
import { getProductBySlug } from '../../lib/store';
import type { ProductVariant } from '../../lib/types';

const { slug } = Astro.params;
const product = slug ? await getProductBySlug(slug) : null;

if (!product) {
  Astro.response.status = 404;
}

const images = product?.product_images ?? [];
const resolvedImages = images.map((image) => ({
  ...image,
  url: resolveImageUrl(image.url),
}));
const activeVariants: ProductVariant[] = (product?.product_variants ?? []).filter((variant) => variant.is_active);
const firstAvailableVariant = activeVariants.find((variant) => variant.stock > 0) ?? activeVariants[0] ?? null;
const usesVariantStock = activeVariants.length > 0;
const initialStock = usesVariantStock ? (firstAvailableVariant ? Math.max(0, firstAvailableVariant.stock) : 0) : 99;

function isGenericVariantName(name: string | null | undefined): boolean {
  const normalized = (name ?? '').trim().toLowerCase();
  return normalized.length === 0 || normalized === 'default title' || normalized === 'default' || normalized === 'principal';
}

function getVariantDisplayLabel(variant: ProductVariant): string {
  const parts: string[] = [];
  if (!isGenericVariantName(variant.name)) parts.push(variant.name);
  if (variant.size_label && variant.size_label.trim()) parts.push(variant.size_label.trim());
  if (variant.color_name && variant.color_name.trim()) parts.push(variant.color_name.trim());
  return parts.length > 0 ? parts.join(' · ') : 'Talla única';
}

function normalizeOptionValue(value: string | null | undefined): string {
  return String(value || '')
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');
}

function uniqueOptionValues(values: Array<string | null | undefined>): string[] {
  const seen = new Set<string>();
  const result: string[] = [];

  for (const value of values) {
    const trimmed = String(value || '').trim();
    if (!trimmed) continue;
    const key = normalizeOptionValue(trimmed);
    if (!key || seen.has(key)) continue;
    seen.add(key);
    result.push(trimmed);
  }

  return result;
}

function getSizeOptionLabel(variants: ProductVariant[]): string {
  const sizes = variants
    .map((variant) => String(variant.size_label || '').trim())
    .filter((value) => value.length > 0);

  if (sizes.length === 0) return 'Talla';
  const numericLike = sizes.every((value) => /^\d{2}(?:\.5)?$/.test(value));
  return numericLike ? 'Talla del calzado' : 'Talla';
}

function parseVariantImageIdFromMeta(raw: string | null | undefined): number | null {
  const value = String(raw || '').trim();
  if (!value) return null;
  const match = value.match(/(?:^|\|)img:(\d+)(?:\||$)/i);
  if (!match) return null;
  const parsed = Number(match[1]);
  return Number.isFinite(parsed) ? parsed : null;
}

const hasVariantDetails = activeVariants.some((variant) => getVariantDisplayLabel(variant) !== 'Talla única');
const hasColorOptions = activeVariants.some((variant) => String(variant.color_name || '').trim().length > 0);
const hasSizeOptions = activeVariants.some((variant) => String(variant.size_label || '').trim().length > 0);
const usesStructuredOptions = hasColorOptions || hasSizeOptions;
const colorOptions = uniqueOptionValues(activeVariants.map((variant) => variant.color_name));
const sizeOptions = uniqueOptionValues(activeVariants.map((variant) => variant.size_label));
const sizeOptionLabel = getSizeOptionLabel(activeVariants);
const showVariantSelector = !usesStructuredOptions && (activeVariants.length > 1 || hasVariantDetails);
const fallbackVariantLabel = firstAvailableVariant ? getVariantDisplayLabel(firstAvailableVariant) : 'Talla única';
const fallbackVariantStock = firstAvailableVariant ? Math.max(0, firstAvailableVariant.stock) : 99;
const variantClientPayload = activeVariants.map((variant) => ({
  id: variant.id,
  name: variant.name,
  color_name: variant.color_name,
  color_hex: variant.color_hex,
  size_label: variant.size_label,
  price_cents: variant.price_cents,
  stock: variant.stock,
  variant_image_id: parseVariantImageIdFromMeta(variant.color_hex),
}));
const imageClientPayload = resolvedImages.map((image) => ({
  id: Number(image.id) || null,
  url: image.url,
  alt_text: image.alt_text ?? product?.name ?? '',
}));

function formatEuros(cents: number): string {
  return new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
  }).format(cents / 100);
}
---

{
  !product ? (
    <Layout title="Producto no encontrado | ELEGILSA" description="Este producto no existe o ya no esta disponible.">
      <section class="panel" style="margin-top: 1.2rem;">
        <h1>Producto no encontrado</h1>
        <p>Puede que este producto ya no este disponible.</p>
        <a class="btn secondary" href="/collections/all">Volver al catalogo</a>
      </section>
    </Layout>
  ) : (
    <Layout title={`${product.name} | ELEGILSA`} description={product.description ?? `Comprar ${product.name} en ELEGILSA.`}>
      <section class="pdp">
        <div>
          <div class="gallery-main">
              <img
              id="product-main-image"
              src={resolvedImages[0]?.url ?? '/catalogo/placeholder.svg'}
              alt={resolvedImages[0]?.alt_text ?? product.name}
              loading="eager"
            />
          </div>

          {
            resolvedImages.length > 1 && (
              <div class="gallery-thumbs" id="product-thumbs">
                {resolvedImages.map((image) => (
                  <button type="button" class="thumb" data-image-url={image.url} data-image-alt={image.alt_text ?? product.name}>
                    <img src={image.url} alt={image.alt_text ?? product.name} loading="lazy" />
                  </button>
                ))}
              </div>
            )
          }
        </div>

        <div class="panel">
          <h1 style="margin-top: 0;">{product.name}</h1>
          <p class="price" style="font-size: 1.2rem; margin-top: 0.1rem;">
            <span id="product-price-current">{formatEuros(product.price_cents)}</span>
            {typeof product.compare_at_cents === 'number' && product.compare_at_cents > product.price_cents && (
              <span class="compare">{formatEuros(product.compare_at_cents)}</span>
            )}
          </p>

          {product.description && <p>{product.description}</p>}

          {
            usesStructuredOptions ? (
              <div class="form-grid" style="margin-top: 1rem; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.7rem;">
                {hasColorOptions && (
                  <label>
                    <strong>Color</strong>
                    <select id="variant-color-select" class="select-field">
                      {colorOptions.map((color) => (
                        <option
                          value={color}
                          selected={normalizeOptionValue(firstAvailableVariant?.color_name) === normalizeOptionValue(color)}
                        >
                          {color}
                        </option>
                      ))}
                    </select>
                  </label>
                )}
                {hasSizeOptions && (
                  <label>
                    <strong>{sizeOptionLabel}</strong>
                    <select id="variant-size-select" class="select-field">
                      {sizeOptions.map((size) => (
                        <option
                          value={size}
                          selected={normalizeOptionValue(firstAvailableVariant?.size_label) === normalizeOptionValue(size)}
                        >
                          {size}
                        </option>
                      ))}
                    </select>
                  </label>
                )}
              </div>
            ) : showVariantSelector ? (
              <div style="margin-top: 1rem;">
                <label for="variant-select"><strong>Variante</strong></label>
                <select id="variant-select" class="select-field">
                  {activeVariants.map((variant) => (
                    <option
                      value={variant.id}
                      data-stock={variant.stock}
                      selected={firstAvailableVariant?.id === variant.id}
                    >
                      {getVariantDisplayLabel(variant)}
                    </option>
                  ))}
                </select>
              </div>
            ) : (
              <p style="margin: 0.9rem 0 0; color: var(--muted);"><strong>Talla:</strong> {fallbackVariantLabel}</p>
            )
          }

          <div class="row" style="margin-top: 1rem;">
            <strong>Cantidad</strong>
            <div class="qty-control">
              <button type="button" class="qty-btn" id="qty-dec" aria-label="Restar una unidad">-</button>
              <input
                id="qty-input"
                class="qty"
                type="number"
                min="1"
                max={Math.max(initialStock, 1)}
                value={initialStock > 0 ? '1' : '0'}
                { ...(initialStock === 0 ? { disabled: true } : {}) }
              />
              <button type="button" class="qty-btn" id="qty-inc" aria-label="Sumar una unidad">+</button>
            </div>
          </div>

          <div class="row" style="margin-top: 1rem;">
            <button id="add-to-cart-btn" type="button" disabled={initialStock === 0}>Añadir al carrito</button>
            <button id="wishlist-btn" type="button" class="wishlist-btn icon-only" aria-label="Añadir a wishlist" aria-pressed="false">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 21s-6.7-4.35-9.2-8.2C.86 9.85 2 6.2 5.33 5.16c2.17-.68 4.06.15 5.17 1.5 1.11-1.35 3-2.18 5.17-1.5C19 6.2 20.14 9.85 21.2 12.8 18.7 16.65 12 21 12 21z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>

          <p id="product-feedback" class="alert" style="display: none; margin-top: 0.9rem;"></p>
        </div>
      </section>

      <script
        is:inline
        define:vars={{
          productId: product.id,
          productSlug: product.slug,
          productName: product.name,
          productPriceCents: product.price_cents,
          productImage: resolvedImages[0]?.url ?? '/catalogo/placeholder.svg',
          fallbackVariantId: firstAvailableVariant?.id ?? null,
          fallbackVariantLabel,
          fallbackVariantStock,
          productVariantsData: variantClientPayload,
          productImagesData: imageClientPayload,
          hasStructuredVariantOptions: usesStructuredOptions,
        }}
      >
        // @ts-nocheck
        const variantSelect = document.getElementById('variant-select');
        const colorSelect = document.getElementById('variant-color-select');
        const sizeSelect = document.getElementById('variant-size-select');
        const qtyInput = document.getElementById('qty-input');
        const qtyDec = document.getElementById('qty-dec');
        const qtyInc = document.getElementById('qty-inc');
        const addToCartBtn = document.getElementById('add-to-cart-btn');
        const wishlistBtn = document.getElementById('wishlist-btn');
        const feedbackEl = document.getElementById('product-feedback');
        const priceCurrentEl = document.getElementById('product-price-current');
        const mainImage = document.getElementById('product-main-image');
        const thumbs = Array.from(document.querySelectorAll('#product-thumbs .thumb'));

        const CART_KEY = 'elegilsa_cart_v1';
        const WISHLIST_KEY = 'elegilsa_wishlist_v2';
        // @ts-ignore injected by Astro define:vars
        const variants = Array.isArray(productVariantsData) ? productVariantsData : [];
        // @ts-ignore injected by Astro define:vars
        const productImages = Array.isArray(productImagesData) ? productImagesData : [];
        const usesStructuredVariantPickers = Boolean(hasStructuredVariantOptions);

        function normalizeToken(value) {
          return String(value || '')
            .trim()
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '');
        }

        function isGenericVariantLabel(name) {
          const normalized = normalizeToken(name);
          return !normalized || normalized === 'principal' || normalized === 'default title' || normalized === 'default';
        }

        function getVariantLabel(variant) {
          if (!variant || typeof variant !== 'object') return fallbackVariantLabel;
          const parts = [];
          if (!isGenericVariantLabel(variant.name)) parts.push(String(variant.name || '').trim());
          if (String(variant.size_label || '').trim()) parts.push(String(variant.size_label).trim());
          if (String(variant.color_name || '').trim()) parts.push(String(variant.color_name).trim());
          return parts.length > 0 ? parts.join(' · ') : fallbackVariantLabel;
        }

        function formatEurosClient(cents) {
          return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format((Number(cents) || 0) / 100);
        }

        function parseImageIdFromMeta(rawValue) {
          const value = String(rawValue || '').trim();
          const match = value.match(/(?:^|\|)img:(\d+)(?:\||$)/i);
          if (!match) return null;
          const parsed = Number(match[1]);
          return Number.isFinite(parsed) ? parsed : null;
        }

        function setActiveThumbByUrl(url) {
          thumbs.forEach((thumb) => {
            const thumbUrl = String(thumb.getAttribute('data-image-url') || '');
            thumb.classList.toggle('active', thumbUrl === String(url || ''));
          });
        }

        function applyMainImage(url, alt) {
          if (!(mainImage instanceof HTMLImageElement)) return;
          const nextUrl = String(url || '').trim() || '/catalogo/placeholder.svg';
          const nextAlt = String(alt || '').trim() || productName;
          mainImage.setAttribute('src', nextUrl);
          mainImage.setAttribute('alt', nextAlt);
          setActiveThumbByUrl(nextUrl);
        }

        function findImageForVariant(variant) {
          if (!variant || productImages.length === 0) return null;

          const directImageId = Number(variant.variant_image_id);
          if (Number.isFinite(directImageId) && directImageId > 0) {
            const direct = productImages.find((image) => Number(image?.id) === directImageId);
            if (direct) return direct;
          }

          const imageIdFromMeta = parseImageIdFromMeta(variant.color_hex);
          if (imageIdFromMeta) {
            const mapped = productImages.find((image) => Number(image?.id) === imageIdFromMeta);
            if (mapped) return mapped;
          }

          const colorToken = normalizeToken(variant.color_name);
          if (!colorToken) return null;

          const byAlt = productImages.find((image) => normalizeToken(image?.alt_text).includes(colorToken));
          if (byAlt) return byAlt;

          const colorSlug = colorToken.replace(/\s+/g, '-');
          const byUrl = productImages.find((image) => normalizeToken(image?.url).includes(colorSlug));
          return byUrl || null;
        }

        function findVariantBySelection() {
          if (variants.length === 0) return null;

          if (!usesStructuredVariantPickers && variantSelect) {
            const selectedId = String(variantSelect.value || '').trim();
            return variants.find((variant) => String(variant.id) === selectedId)
              || variants.find((variant) => Number(variant.stock) > 0)
              || variants[0]
              || null;
          }

          const selectedColor = normalizeToken(colorSelect?.value || '');
          const selectedSize = normalizeToken(sizeSelect?.value || '');

          const matches = variants.filter((variant) => {
            const colorMatch = !selectedColor || normalizeToken(variant.color_name) === selectedColor;
            const sizeMatch = !selectedSize || normalizeToken(variant.size_label) === selectedSize;
            return colorMatch && sizeMatch;
          });

          if (matches.length > 0) {
            return matches.find((variant) => Number(variant.stock) > 0) || matches[0];
          }

          const colorOnlyMatches = selectedColor
            ? variants.filter((variant) => normalizeToken(variant.color_name) === selectedColor)
            : [];
          if (colorOnlyMatches.length > 0) {
            return colorOnlyMatches.find((variant) => Number(variant.stock) > 0) || colorOnlyMatches[0];
          }

          const sizeOnlyMatches = selectedSize
            ? variants.filter((variant) => normalizeToken(variant.size_label) === selectedSize)
            : [];
          if (sizeOnlyMatches.length > 0) {
            return sizeOnlyMatches.find((variant) => Number(variant.stock) > 0) || sizeOnlyMatches[0];
          }

          return variants.find((variant) => Number(variant.stock) > 0) || variants[0] || null;
        }

        function syncStructuredSelectors(variant) {
          if (!variant || !usesStructuredVariantPickers) return;

          if (colorSelect && String(variant.color_name || '').trim()) {
            const nextColor = String(variant.color_name).trim();
            const option = Array.from(colorSelect.options).find((entry) => normalizeToken(entry.value) === normalizeToken(nextColor));
            if (option) colorSelect.value = option.value;
          }

          if (sizeSelect && String(variant.size_label || '').trim()) {
            const nextSize = String(variant.size_label).trim();
            const option = Array.from(sizeSelect.options).find((entry) => normalizeToken(entry.value) === normalizeToken(nextSize));
            if (option) sizeSelect.value = option.value;
          }
        }

        function getCurrentVariant() {
          return findVariantBySelection();
        }

        function getCurrentStock() {
          const variant = getCurrentVariant();
          if (!variant) return Number(fallbackVariantStock || 99);
          return Math.max(0, Number(variant.stock) || 0);
        }

        function getCurrentPriceCents() {
          const variant = getCurrentVariant();
          const variantPrice = Number(variant?.price_cents);
          if (Number.isFinite(variantPrice) && variantPrice > 0) {
            return Math.round(variantPrice);
          }
          return Number(productPriceCents || 0);
        }

        function showFeedback(type, message) {
          if (!feedbackEl) return;
          feedbackEl.textContent = message;
          feedbackEl.classList.remove('ok', 'danger');
          feedbackEl.classList.add(type === 'ok' ? 'ok' : 'danger');
          feedbackEl.style.display = 'block';
        }

        function refreshVariantState(clearFeedback = true) {
          const variant = getCurrentVariant();
          if (usesStructuredVariantPickers) {
            syncStructuredSelectors(variant);
          }

          const image = findImageForVariant(variant);
          if (image?.url) {
            applyMainImage(image.url, image.alt_text || productName);
          }

          if (priceCurrentEl) {
            priceCurrentEl.textContent = formatEurosClient(getCurrentPriceCents());
          }

          clampQty();
          if (clearFeedback && feedbackEl) {
            feedbackEl.style.display = 'none';
          }
        }

        function clampQty() {
          if (!qtyInput) return;
          const stock = getCurrentStock();
          const min = stock > 0 ? 1 : 0;
          let value = Number(qtyInput.value || '1');
          if (!Number.isFinite(value)) value = min;
          value = Math.max(min, Math.min(stock, Math.round(value)));
          qtyInput.value = String(value);
          qtyInput.max = String(Math.max(stock, 1));

          if (addToCartBtn) addToCartBtn.disabled = stock === 0;
          if (stock === 0) {
            showFeedback('danger', 'Producto agotado para la opción seleccionada.');
          }
        }

        function readCart() {
          try {
            const raw = localStorage.getItem(CART_KEY);
            const parsed = raw ? JSON.parse(raw) : [];
            return Array.isArray(parsed) ? parsed : [];
          } catch {
            return [];
          }
        }

        function writeCart(items) {
          localStorage.setItem(CART_KEY, JSON.stringify(items));
        }

        function normalizeWishlistItem(item) {
          if (!item || typeof item !== 'object') return null;
          const slug = typeof item.slug === 'string' ? item.slug.trim() : '';
          const name = typeof item.name === 'string' ? item.name.trim() : '';
          if (!slug || !name) return null;

          return {
            id: typeof item.id === 'string' ? item.id : null,
            slug,
            name,
            price_cents: Number.isFinite(Number(item.price_cents)) ? Math.max(0, Math.round(Number(item.price_cents))) : 0,
            image: typeof item.image === 'string' && item.image.trim() ? item.image.trim() : '/catalogo/placeholder.svg',
          };
        }

        function readWishlist() {
          const userId = getCurrentWishlistUserId();
          if (!userId) return [];

          try {
            const raw = localStorage.getItem(`${WISHLIST_KEY}::${userId}`);
            const parsed = raw ? JSON.parse(raw) : [];
            return Array.isArray(parsed) ? parsed.map(normalizeWishlistItem).filter((item) => item !== null) : [];
          } catch {
            return [];
          }
        }

        function writeWishlist(items) {
          const userId = getCurrentWishlistUserId();
          if (!userId) return;
          localStorage.setItem(`${WISHLIST_KEY}::${userId}`, JSON.stringify(items));
        }

        function getSupabaseSessionFromStorage() {
          try {
            const tokenKey = Object.keys(localStorage).find((key) => key.startsWith('sb-') && key.endsWith('-auth-token'));
            if (!tokenKey) return null;

            const raw = localStorage.getItem(tokenKey);
            if (!raw) return null;
            const parsed = JSON.parse(raw);

            if (parsed?.currentSession?.user?.id) return parsed.currentSession;
            if (parsed?.user?.id) return parsed;
            if (Array.isArray(parsed) && parsed[0]?.currentSession?.user?.id) return parsed[0].currentSession;
            if (Array.isArray(parsed) && parsed[0]?.user?.id) return parsed[0];
            return null;
          } catch {
            return null;
          }
        }

        function getCurrentWishlistUserId() {
          const session = getSupabaseSessionFromStorage();
          return session?.user?.id ? String(session.user.id) : null;
        }

        function syncWishlistButton() {
          if (!wishlistBtn) return;
          const items = readWishlist();
          const active = items.some((item) => item.slug === productSlug || item.id === productId);
          wishlistBtn.classList.toggle('is-active', active);
          wishlistBtn.setAttribute('aria-pressed', active ? 'true' : 'false');
        }

        variantSelect?.addEventListener('change', () => {
          refreshVariantState(true);
        });

        colorSelect?.addEventListener('change', () => {
          refreshVariantState(true);
        });

        sizeSelect?.addEventListener('change', () => {
          refreshVariantState(true);
        });

        qtyDec?.addEventListener('click', () => {
          if (!qtyInput) return;
          qtyInput.value = String(Math.max(Number(qtyInput.value) - 1, getCurrentStock() > 0 ? 1 : 0));
        });

        qtyInc?.addEventListener('click', () => {
          if (!qtyInput) return;
          const stock = getCurrentStock();
          qtyInput.value = String(Math.min(Number(qtyInput.value) + 1, stock));
        });

        qtyInput?.addEventListener('input', clampQty);

        addToCartBtn?.addEventListener('click', () => {
          const selectedVariant = getCurrentVariant();
          const stock = getCurrentStock();
          const selectedQty = Math.max(1, Number(qtyInput?.value || '1'));

          if (stock <= 0) {
            showFeedback('danger', 'Producto agotado para la opción seleccionada.');
            return;
          }

          if (selectedQty > stock) {
            showFeedback('danger', 'No hay suficiente disponibilidad para esa cantidad.');
            if (qtyInput) qtyInput.value = String(stock);
            return;
          }

          const variantId = selectedVariant?.id ?? variantSelect?.selectedOptions?.[0]?.value ?? fallbackVariantId ?? null;
          const variantName = selectedVariant ? getVariantLabel(selectedVariant) : fallbackVariantLabel;
          const unitPriceCents = getCurrentPriceCents();
          const itemKey = `${productId}::${variantId ?? 'no-variant'}`;

          const cart = readCart();
          const existing = cart.find((item) => item.key === itemKey);
          const currentQty = existing ? Number(existing.quantity || 0) : 0;
          const nextQty = Math.min(currentQty + selectedQty, stock);

          if (nextQty <= currentQty) {
            showFeedback('danger', 'No hay más unidades disponibles para esta opción.');
            return;
          }

          const nextItem = {
            key: itemKey,
            productId,
            slug: productSlug,
            name: productName,
            variantId,
            variantName,
            quantity: nextQty,
            unitPriceCents,
            imageUrl: mainImage?.getAttribute('src') || productImage,
            stock,
          };

          const nextCart = existing
            ? cart.map((item) => (item.key === itemKey ? nextItem : item))
            : [...cart, nextItem];

          writeCart(nextCart);
          showFeedback('ok', 'Añadido al carrito.');
        });

        wishlistBtn?.addEventListener('click', () => {
          const userId = getCurrentWishlistUserId();
          if (!userId) {
            window.location.href = `/perfil?next=${encodeURIComponent('/wishlist')}`;
            return;
          }

          const items = readWishlist();
          const exists = items.some((item) => item.slug === productSlug || item.id === productId);
          const next = exists
            ? items.filter((item) => item.slug !== productSlug && item.id !== productId)
            : [
                ...items,
                {
                  id: productId,
                  slug: productSlug,
                  name: productName,
                  price_cents: productPriceCents,
                  image: productImage,
                },
              ];
          writeWishlist(next);
          syncWishlistButton();
          showFeedback('ok', exists ? 'Producto eliminado de wishlist.' : 'Producto guardado en wishlist.');
        });

        thumbs.forEach((thumb) => {
          thumb.addEventListener('click', () => {
            const nextUrl = thumb.getAttribute('data-image-url') || '/catalogo/placeholder.svg';
            const nextAlt = thumb.getAttribute('data-image-alt') || productName;
            applyMainImage(nextUrl, nextAlt);
          });
        });

        if (thumbs.length > 0) thumbs[0].classList.add('active');
        refreshVariantState(false);
        syncWishlistButton();
      </script>
    </Layout>
  )
}
