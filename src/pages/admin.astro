    const categoryProductsList = document.getElementById('category-products-list');
    const categoryAddProductSelect = document.getElementById('category-add-product-select');
    const categoryAddProductBtn = document.getElementById('category-add-product-btn');
    const categoryProductsCloseBtn = document.getElementById('category-products-close-btn');

    let currentManageCategoryId = null;

    categoryProductsCloseBtn?.addEventListener('click', () => categoryProductsModal.close());
    productImagesCloseBtn?.addEventListener('click', () => productImagesModal.close());

    categoryAddProductBtn?.addEventListener('click', async () => {
      const productId = categoryAddProductSelect.value;
      if (!productId || !currentManageCategoryId) return;
      
      const { error } = await supabase.from('products').update({ category_id: currentManageCategoryId }).eq('id', productId);
      if (error) {
        showGlobal('danger', `No se pudo añadir el producto: ${error.message}`);
        return;
      }
      showGlobal('ok', 'Producto añadido a la categoría.');
      await refreshAll();
      openCategoryProductsModal(currentManageCategoryId);
    });

    categoryProductsList?.addEventListener('click', async (e) => {
      const btn = e.target.closest('button[data-action]');
      if (!btn) return;

      const action = btn.getAttribute('data-action');
      const productId = btn.getAttribute('data-id');
      if (!productId) return;

      if (action === 'manage-product-images-cat') {
        if (categoryProductsModal?.open) {
          categoryProductsModal.close();
        }
        openProductImagesModal(productId);
        return;
      }

      if (action === 'remove-product-cat') {
        const { error } = await supabase.from('products').update({ category_id: null }).eq('id', productId);
        if (error) {
          showGlobal('danger', `No se pudo remover el producto: ${error.message}`);
          return;
        }
        showGlobal('ok', 'Producto removido de la categoría.');
        await refreshAll();
        openCategoryProductsModal(currentManageCategoryId);
      }
    });

    function openCategoryProductsModal(categoryId) {
      const category = categories.find(c => String(c.id) === String(categoryId));
      if (!category) return;
      currentManageCategoryId = categoryId;
      categoryProductsTitle.textContent = `Productos en: ${category.name}`;
      
      const catProducts = products.filter(p => String(p.category_id) === String(categoryId));
      categoryProductsSubtitle.textContent = `${catProducts.length} productos en esta categoria.`;

      categoryProductsList.innerHTML = catProducts.length ? catProducts.map(p => `
        <tr>
          <td>${p.name}</td>
          <td>${renderImageStrip(p)}</td>
          <td>
            <div class="row">
              <button type="button" class="btn secondary" data-action="manage-product-images-cat" data-id="${p.id}" ${(Boolean(p.is_shopify_fallback) || String(p.id || '').startsWith('shopify:')) ? 'disabled title="Solo disponible con conexión a Supabase"' : ''}>Fotos</button>
              <button type="button" class="btn secondary" data-action="remove-product-cat" data-id="${p.id}">Quitar</button>
            </div>
          </td>
        </tr>
      `).join('') : '<tr><td colspan="3">No hay productos.</td></tr>';

      const unassignedProducts = products.filter(p => String(p.category_id) !== String(categoryId));
      categoryAddProductSelect.innerHTML = '<option value="">Selecciona un producto...</option>' + 
        unassignedProducts.map(p => `<option value="${p.id}">${p.name} (Actual: ${getCategoryName(p.category_id)})</option>`).join('');

      categoryProductsModal.showModal();
    }

    function renderProductImagesModalContent(productId) {
      const product = products.find((entry) => String(entry.id) === String(productId));
      if (!product) {
        productImagesList.innerHTML = '<tr><td colspan="5">Producto no encontrado.</td></tr>';
        return;
      }

      const sorted = getSortedImages(product);
      productImagesModalTitle.textContent = `Fotos: ${product.name}`;
      productImagesModalSubtitle.textContent = `${sorted.length} imagen(es) asociada(s).`;

      productImagesList.innerHTML = sorted.length
        ? sorted
            .map((image, index) => `
              <tr>
                <td><img class="admin-thumb is-lg ${index === 0 ? 'is-primary' : ''}" src="${escapeHtml(resolveImageUrl(image.url || '/catalogo/placeholder.svg'))}" alt="${escapeHtml(image.alt_text || product.name)}" loading="lazy" onerror="this.onerror=null;this.src='/catalogo/placeholder.svg'" /></td>
                <td><input type="url" class="admin-inline-input" data-field="url" data-image-id="${image.id}" value="${escapeHtml(image.url || '')}" placeholder="URL pública o ruta de Storage" /></td>
                <td><input type="text" class="admin-inline-input" data-field="alt" data-image-id="${image.id}" value="${escapeHtml(image.alt_text || '')}" /></td>
                <td><strong>${index === 0 ? 'Si' : 'No'}</strong></td>
                <td>
                  <div class="row">
                    <button type="button" class="btn secondary" data-action="save-product-image" data-id="${image.id}">Guardar</button>
                    <button type="button" class="btn secondary" data-action="set-primary-product-image" data-id="${image.id}" ${index === 0 ? 'disabled' : ''}>Principal</button>
                    <button type="button" class="btn secondary" data-action="delete-product-image" data-id="${image.id}">Borrar</button>
                  </div>
                </td>
              </tr>
            `)
            .join('')
        : '<tr><td colspan="5">Este producto no tiene imágenes todavía.</td></tr>';
    }

    function openProductImagesModal(productId) {
      currentImagesProductId = String(productId || '');
      if (!currentImagesProductId) return;

      hideAlert(productImagesFeedback);
      if (productImagesNewUrl instanceof HTMLInputElement) {
        productImagesNewUrl.value = '';
      }
      if (productImagesNewFile instanceof HTMLInputElement) {
        productImagesNewFile.value = '';
      }
      if (productImagesNewAlt instanceof HTMLInputElement) {
        productImagesNewAlt.value = '';
      }

      renderProductImagesModalContent(currentImagesProductId);
      if (!productImagesModal.open) {
        productImagesModal.showModal();
      }
    }

    async function addProductImage(productId, imageUrl, altText, imageFile = null) {
      const product = products.find((entry) => String(entry.id) === String(productId));
      if (!product) {
        showAlert(productImagesFeedback, 'danger', 'Producto no encontrado para añadir imagen.');
        return;
      }

      let finalUrl = toStorageReference(imageUrl);
      if (imageFile instanceof File) {
        try {
          finalUrl = await uploadProductImageFileLegacyBroken(imageFile, productId || 'producto');
        } catch (error) {
          const reason = error instanceof Error ? error.message : 'No se pudo subir imagen.';
          showAlert(productImagesFeedback, 'danger', reason);
          return;
        }
      }

      if (!finalUrl) {
        showAlert(productImagesFeedback, 'danger', 'Debes indicar URL o adjuntar un archivo de imagen.');
        return;
      }

      const maxPosition = getSortedImages(product).reduce((acc, image) => Math.max(acc, Number(image.position) || 0), 0);
      const { error } = await supabase.from('product_images').insert({
        product_id: productId,
        url: toStorageReference(finalUrl),
        alt_text: altText || product.name,
        position: maxPosition + 1,
      });

      if (error) {
        showAlert(productImagesFeedback, 'danger', `No se pudo añadir la imagen: ${error.message}`);
        return;
      }

      await refreshAll();
      renderProductImagesModalContent(productId);
      showAlert(productImagesFeedback, 'ok', 'Imagen añadida.');
    }

    async function saveProductImage(imageId) {
      const urlInput = productImagesList.querySelector(`input[data-field="url"][data-image-id="${imageId}"]`);
      const altInput = productImagesList.querySelector(`input[data-field="alt"][data-image-id="${imageId}"]`);
      const nextUrl = toStorageReference(urlInput?.value);
      const nextAlt = String(altInput?.value || '').trim();

      if (!nextUrl) {
        showAlert(productImagesFeedback, 'danger', 'La URL de imagen no puede estar vacía.');
        return;
      }

      const { error } = await supabase.from('product_images').update({ url: nextUrl, alt_text: nextAlt || null }).eq('id', imageId);
      if (error) {
        showAlert(productImagesFeedback, 'danger', `No se pudo guardar la imagen: ${error.message}`);
        return;
      }

      await refreshAll();
      renderProductImagesModalContent(currentImagesProductId);
      showAlert(productImagesFeedback, 'ok', 'Imagen actualizada.');
    }

    async function setPrimaryProductImage(productId, imageId) {
      const product = products.find((entry) => String(entry.id) === String(productId));
      if (!product) {
        showAlert(productImagesFeedback, 'danger', 'Producto no encontrado.');
        return;
      }

      const sorted = getSortedImages(product);
      if (sorted.length <= 1) {
        showAlert(productImagesFeedback, 'ok', 'Ya existe una única imagen principal.');
        return;
      }

      const selected = sorted.find((entry) => String(entry.id) === String(imageId));
      if (!selected) {
        showAlert(productImagesFeedback, 'danger', 'Imagen no encontrada.');
        return;
      }

      const reordered = [selected, ...sorted.filter((entry) => String(entry.id) !== String(imageId))];
      for (let index = 0; index < reordered.length; index += 1) {
        const image = reordered[index];
        const { error } = await supabase.from('product_images').update({ position: index + 1 }).eq('id', image.id).eq('product_id', productId);
        if (error) {
          showAlert(productImagesFeedback, 'danger', `No se pudo actualizar orden de imágenes: ${error.message}`);
          return;
        }
      }

      await refreshAll();
      renderProductImagesModalContent(productId);
      showAlert(productImagesFeedback, 'ok', 'Imagen principal actualizada.');
    }

    async function deleteProductImage(imageId) {
      const { error } = await supabase.from('product_images').delete().eq('id', imageId);
      if (error) {
        showAlert(productImagesFeedback, 'danger', `No se pudo borrar imagen: ${error.message}`);
        return;
      }

      await refreshAll();
      renderProductImagesModalContent(currentImagesProductId);
      showAlert(productImagesFeedback, 'ok', 'Imagen eliminada.');
    }

    function openCategoryModal(categoryId = null) {
      resetCategoryForm();
      if (categoryId) {
        const category = categories.find((entry) => String(entry.id) === String(categoryId));
        if (!category) return;

        categoryModalTitle.textContent = `Editar: ${category.name}`;
        categoryForm.elements.namedItem('id').value = String(category.id);
        categoryForm.elements.namedItem('name').value = category.name || '';
        categoryForm.elements.namedItem('slug').value = category.slug || '';
        categoryForm.elements.namedItem('description').value = category.description || '';
      }
      categoryModal.showModal();
    }

    function hasLocalSales(productId) {
      return adminOrders.some((order) => (order.items || []).some((item) => String(item.productId || item.product_id) === String(productId)));
    }

    async function hasRemoteSales(productId) {
      const { count, error } = await supabase
        .from('order_items')
        .select('id', { count: 'exact', head: true })
        .eq('product_id', productId);

      if (error) {
        return false;
      }

      return (count || 0) > 0;
    }

    async function deleteProduct(productId) {
      if (hasLocalSales(productId) || (await hasRemoteSales(productId))) {
        showGlobal('danger', 'No puedes borrar un producto con ventas asociadas. Usa "Ocultar" para retirarlo de la tienda.');
        return;
      }

      const { error: imgError } = await supabase.from('product_images').delete().eq('product_id', productId);
      if (imgError) {
        showGlobal('danger', `No se pudo borrar imagenes: ${imgError.message}`);
        return;
      }

      const { error: variantError } = await supabase.from('product_variants').delete().eq('product_id', productId);
      if (variantError) {
        showGlobal('danger', `No se pudieron borrar variantes: ${variantError.message}`);
        return;
      }

      const { error: productError } = await supabase.from('products').delete().eq('id', productId);
      if (productError) {
        showGlobal('danger', `No se pudo borrar el producto: ${productError.message}`);
        return;
      }

      await refreshAll();
      showGlobal('ok', 'Producto eliminado.');
    }

    async function toggleProductVisibility(productId, nextActive) {
      const isActive = Boolean(nextActive);
      const { error } = await supabase.from('products').update({ is_active: isActive }).eq('id', productId);
      if (error) {
        showGlobal('danger', `No se pudo actualizar visibilidad: ${error.message}`);
        return;
      }

      await refreshAll();
      showGlobal('ok', isActive ? 'Producto visible en tienda.' : 'Producto oculto correctamente.');
    }

    async function saveProduct(event) {
      event.preventDefault();
      hideAlert(productFormFeedback);

      const id = String(productForm.elements.namedItem('id').value || '').trim();
      const variantId = String(productForm.elements.namedItem('variant_id').value || '').trim();
      const imageId = String(productForm.elements.namedItem('image_id').value || '').trim();

      const name = String(productForm.elements.namedItem('name').value || '').trim();
      const slugInput = String(productForm.elements.namedItem('slug').value || '').trim();
      const slug = toSlug(slugInput || name);
      const description = String(productForm.elements.namedItem('description').value || '').trim();
      const categoryId = Number(productForm.elements.namedItem('category_id').value || 0);
      const priceCents = euroToCents(productForm.elements.namedItem('price').value);
      const comparePriceRaw = String(productForm.elements.namedItem('compare_price').value || '').trim();
      const compareAtCents = comparePriceRaw ? euroToCents(comparePriceRaw) : null;
      const stock = Math.max(0, Math.round(Number(productForm.elements.namedItem('stock').value || 0)));
      const imageUrlInput = String(productForm.elements.namedItem('image_url').value || '').trim();
      const extraImageUrlsInput = String(productForm.elements.namedItem('extra_image_urls')?.value || '').trim();
      const isActive = Boolean(productForm.elements.namedItem('is_active').checked);
      const featured = Boolean(productForm.elements.namedItem('featured').checked);

      let imageUrl = toStorageReference(imageUrlInput);
      const selectedImageFile = productImageFileInput instanceof HTMLInputElement ? productImageFileInput.files?.[0] || null : null;
      const selectedGalleryFiles = productImageFilesInput instanceof HTMLInputElement ? Array.from(productImageFilesInput.files || []) : [];
      if (selectedImageFile) {
        try {
          uploadedProductImageDataUrl = await prepareProductImageData(selectedImageFile);
          setProductImagePreview(uploadedProductImageDataUrl);
        } catch (error) {
          const reason = error instanceof Error ? error.message : 'No se pudo procesar la imagen adjunta.';
          showAlert(productFormFeedback, 'danger', reason);
          return;
        }
      }

      if (!name || !slug || !Number.isFinite(categoryId) || categoryId <= 0) {
        showAlert(productFormFeedback, 'danger', 'Completa nombre, slug y categoria.');
        return;
      }

      const productPayload = {
        category_id: categoryId,
        slug,
        name,
        description: description || null,
        price_cents: priceCents,
        compare_at_cents: compareAtCents,
        is_active: isActive,
        featured,
      };

      let productId = id;

      if (productId) {
        const { error } = await supabase.from('products').update(productPayload).eq('id', productId);
        if (error) {
          showAlert(productFormFeedback, 'danger', `No se pudo actualizar: ${error.message}`);
          return;
        }
      } else {
        const { data, error } = await supabase.from('products').insert(productPayload).select('id').single();
        if (error || !data) {
          showAlert(productFormFeedback, 'danger', `No se pudo crear: ${error?.message || 'sin respuesta'}`);
          return;
        }
        productId = data.id;
      }

      if (selectedImageFile) {
        try {
          imageUrl = await uploadProductImageFileLegacyBroken(selectedImageFile, productId || 'producto');
        } catch (error) {
          const reason = error instanceof Error ? error.message : 'No se pudo subir la imagen a Storage.';
          showAlert(productFormFeedback, 'danger', reason);
          return;
        }
      }

      if (variantId) {
        const { error } = await supabase
          .from('product_variants')
          .update({ stock, name: 'Principal', is_active: true, price_cents: null, position: 1 })
          .eq('id', variantId)
          .eq('product_id', productId);
        if (error) {
          showAlert(productFormFeedback, 'danger', `No se pudo actualizar stock: ${error.message}`);
          return;
        }
      } else {
        const { error } = await supabase.from('product_variants').insert({
          product_id: productId,
          name: 'Principal',
          color_name: null,
          color_hex: null,
          size_label: null,
          price_cents: null,
          stock,
          is_active: true,
          position: 1,
        });
        if (error) {
          showAlert(productFormFeedback, 'danger', `No se pudo crear variante: ${error.message}`);
          return;
        }
      }

      if (imageUrl) {
        if (imageId) {
          const { error } = await supabase.from('product_images').update({ url: toStorageReference(imageUrl), position: 1 }).eq('id', imageId).eq('product_id', productId);
          if (error) {
            showAlert(productFormFeedback, 'danger', `No se pudo actualizar imagen: ${error.message}`);
            return;
          }
        } else {
          const { error } = await supabase.from('product_images').insert({
            product_id: productId,
            url: toStorageReference(imageUrl),
            alt_text: name,
            position: 1,
          });
          if (error) {
            showAlert(productFormFeedback, 'danger', `No se pudo crear imagen: ${error.message}`);
            return;
          }
        }
      }

      const extraImageUrls = extraImageUrlsInput
        .split(/\r?\n/)
        .map((line) => toStorageReference(line))
        .filter(Boolean);

      if (extraImageUrls.length > 0 || selectedGalleryFiles.length > 0) {
        const { data: existingRows, error: existingError } = await supabase
          .from('product_images')
          .select('id,url,position')
          .eq('product_id', productId)
          .order('position', { ascending: true });

        if (existingError) {
          showAlert(productFormFeedback, 'danger', `No se pudo leer imágenes actuales: ${existingError.message}`);
          return;
        }

        const existing = Array.isArray(existingRows) ? existingRows : [];
        let nextPosition = existing.reduce((acc, row) => Math.max(acc, Number(row.position) || 0), 0) + 1;
        const existingUrls = new Set(existing.map((row) => toStorageReference(row.url)).filter(Boolean));

        for (const rawUrl of extraImageUrls) {
          if (existingUrls.has(rawUrl)) continue;
          const { error } = await supabase.from('product_images').insert({
            product_id: productId,
            url: toStorageReference(rawUrl),
            alt_text: name,
            position: nextPosition,
          });
          if (error) {
            showAlert(productFormFeedback, 'danger', `No se pudo guardar URL extra: ${error.message}`);
            return;
          }
          existingUrls.add(rawUrl);
          nextPosition += 1;
        }

        for (const file of selectedGalleryFiles) {
          let uploadedUrl = '';
          try {
            uploadedUrl = await uploadProductImageFileLegacyBroken(file, productId || 'producto');
          } catch (error) {
            const reason = error instanceof Error ? error.message : 'No se pudo subir imagen de galería.';
            showAlert(productFormFeedback, 'danger', reason);
            return;
          }

          if (!uploadedUrl || existingUrls.has(uploadedUrl)) {
            continue;
          }

          const { error } = await supabase.from('product_images').insert({
            product_id: productId,
            url: toStorageReference(uploadedUrl),
            alt_text: name,
            position: nextPosition,
          });
          if (error) {
            showAlert(productFormFeedback, 'danger', `No se pudo guardar imagen de galería: ${error.message}`);
            return;
          }
          existingUrls.add(uploadedUrl);
          nextPosition += 1;
        }
      }

      await refreshAll();
      showAlert(productFormFeedback, 'ok', 'Producto guardado correctamente.');
      setTimeout(() => productModal.close(), 400);
    }

    async function saveCategory(event) {
      event.preventDefault();
      hideAlert(categoryFormFeedback);

      const id = String(categoryForm.elements.namedItem('id').value || '').trim();
      const name = String(categoryForm.elements.namedItem('name').value || '').trim();
      const slugInput = String(categoryForm.elements.namedItem('slug').value || '').trim();
      const slug = toSlug(slugInput || name);
      const description = String(categoryForm.elements.namedItem('description').value || '').trim();

      if (!name || !slug) {
        showAlert(categoryFormFeedback, 'danger', 'Completa nombre y slug.');
        return;
      }

      const payload = { name, slug, description: description || null };

      if (id) {
        const { error } = await supabase.from('categories').update(payload).eq('id', id);
        if (error) {
          showAlert(categoryFormFeedback, 'danger', `No se pudo actualizar categoria: ${error.message}`);
          return;
        }
      } else {
        const { error } = await supabase.from('categories').insert(payload);
        if (error) {
          showAlert(categoryFormFeedback, 'danger', `No se pudo crear categoria: ${error.message}`);
          return;
        }
      }

      await refreshAll();
      showAlert(categoryFormFeedback, 'ok', 'Categoria guardada.');
      setTimeout(() => categoryModal.close(), 400);
    }

    async function deleteCategory(categoryId) {
      const linkedProducts = products.some((product) => Number(product.category_id) === Number(categoryId));
      if (linkedProducts) {
        showGlobal('danger', 'No puedes borrar una categoria que tiene productos asociados.');
        return;
      }

      const { error } = await supabase.from('categories').delete().eq('id', categoryId);
      if (error) {
        showGlobal('danger', `No se pudo borrar la categoria: ${error.message}`);
        return;
      }

      await refreshAll();
      showGlobal('ok', 'Categoria eliminada.');
    }

    function updateOrderStatus(orderId, status) {
      const orders = readLocalArray(ORDERS_KEY);
      const next = orders.map((order) => (order.id === orderId ? { ...order, status } : order));
      writeLocalArray(ORDERS_KEY, next);
      adminOrders = adminOrders.map((order) => (order.id === orderId ? { ...order, status } : order));
      renderDashboard();
      renderOrdersTable();
      renderUsersTable();
    }

    function updateReturnStatus(orderId, status) {
      const returns = readLocalArray(RETURNS_KEY);
      const index = returns.findIndex((entry) => entry.order_id === orderId);
      if (index === -1) {
        returns.unshift({ order_id: orderId, status, updated_at: new Date().toISOString() });
      } else {
        returns[index] = { ...returns[index], status, updated_at: new Date().toISOString() };
      }
      writeLocalArray(RETURNS_KEY, returns);
      renderDashboard();
      renderOrdersTable();
    }

    function requestReturn(orderId) {
      const returns = readLocalArray(RETURNS_KEY);
      if (returns.some((entry) => entry.order_id === orderId)) {
        showGlobal('danger', 'Ese pedido ya tiene una devolucion registrada.');
        return;
      }

      returns.unshift({ order_id: orderId, status: 'requested', updated_at: new Date().toISOString() });
      writeLocalArray(RETURNS_KEY, returns);
      renderDashboard();
      renderOrdersTable();
      showGlobal('ok', 'Solicitud de devolucion registrada.');
    }

    function createInvoiceFromOrder(orderId) {
      const order = adminOrders.find((entry) => entry.id === orderId);
      if (!order) {
        showGlobal('danger', 'No se encontro el pedido para facturar.');
        return;
      }

      const invoice = ensureInvoice(order);
      renderInvoicesTable();
      showGlobal('ok', `Factura ${invoice.id} generada para ${order.id}.`);
    }

    function downloadInvoice(invoiceId) {
      const invoices = adminInvoices;
      const orders = adminOrders;
      const invoice = invoices.find((entry) => entry.id === invoiceId);
      if (!invoice) {
        showGlobal('danger', 'Factura no encontrada.');
        return;
      }

      const order = orders.find((entry) => entry.id === invoice.order_id);
      
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      
      // Colores corporativos (elegilsa.com)
      const brandColor = [126, 95, 75]; // #7e5f4b

      doc.setFontSize(22);
      doc.setTextColor(brandColor[0], brandColor[1], brandColor[2]);
      doc.text('ELEGILSA', 14, 20);
      
      doc.setFontSize(10);
      doc.setTextColor(100);
      doc.text('Moda femenina y complementos', 14, 26);
      doc.text('www.elegilsa.com', 14, 31);
      
      doc.setFontSize(14);
      doc.setTextColor(0);
      doc.text('FACTURA', 140, 20);
      
      doc.setFontSize(10);
      doc.setTextColor(100);
      doc.text(`Factura Nº: ${invoice.id}`, 140, 26);
      doc.text(`Fecha: ${formatDate(invoice.created_at)}`, 140, 31);
      doc.text(`Pedido: ${invoice.order_id}`, 140, 36);

      // Datos Cliente
      doc.setTextColor(0);
      doc.setFontSize(11);
      doc.text('Datos del Cliente:', 14, 50);
      doc.setFontSize(10);
      doc.setTextColor(100);
      if (order?.shipping) {
        doc.text(order.shipping.full_name || invoice.customer, 14, 56);
        doc.text(order.shipping.shipping_address || '', 14, 61);
        doc.text(`${order.shipping.shipping_postal_code || ''} ${order.shipping.shipping_city || ''}`, 14, 66);
        doc.text(order.shipping.shipping_country || '', 14, 71);
      } else {
        doc.text(invoice.customer, 14, 56);
      }

      const tableData = [];
      const items = Array.isArray(order?.items) ? order.items : [];
      let subtotal = 0;
      for (const item of items) {
        const qty = Number(item.quantity) || 0;
        const unit = Number(item.unitPriceCents) || 0;
        const lineTotal = unit * qty;
        subtotal += lineTotal;
        tableData.push([
          item.name || 'Producto',
          qty.toString(),
          formatMoney(unit),
          formatMoney(lineTotal)
        ]);
      }
      
      const shippingCost = Number(order?.shipping_cents) || 0;
      if (shippingCost > 0) {
        tableData.push(['Envío', '1', formatMoney(shippingCost), formatMoney(shippingCost)]);
      }

      doc.autoTable({
        startY: 85,
        head: [['Producto', 'Cantidad', 'Precio Unit.', 'Total']],
        body: tableData,
        theme: 'striped',
        headStyles: { fillColor: brandColor },
        margin: { left: 14, right: 14 }
      });

      const finalY = doc.lastAutoTable.finalY + 10;
      doc.setFontSize(12);
      doc.setTextColor(0);
      doc.text('Total Factura:', 140, finalY);
      doc.setFontSize(14);
      doc.text(formatMoney(invoice.total_cents), 170, finalY);
      
      // Footer
      doc.setFontSize(9);
      doc.setTextColor(150);
      doc.text('Gracias por su compra en Elegilsa.', 105, 280, { align: 'center' });

      doc.save(`Factura_Elegilsa_${invoice.id}.pdf`);
    }

    async function refreshAll() {
      await ensureCatalogLoaded();
      await refreshBusinessData();
      renderDashboard();
      renderProductsTable();
      renderCategoriesTable();
      renderOrdersTable();
      renderUsersTable();
      renderInvoicesTable();
      populateCategorySelect();
    }

    async function checkAuthAndInit() {
      hideAlert(authFeedback);
      hideAlert(globalFeedback);

      if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
        setAuthStatus('Faltan variables PUBLIC_SUPABASE_URL y PUBLIC_SUPABASE_ANON_KEY.');
        showAlert(authFeedback, 'danger', 'Configura variables publicas de Supabase para usar el panel admin.');
        return;
      }

      try {
        supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
          auth: { persistSession: true, autoRefreshToken: true },
        });
      } catch (error) {
        const reason = error instanceof Error ? error.message : 'Error desconocido.';
        showBootstrapError(`No se pudo inicializar Supabase: ${reason}`);
        return;
      }

      setAuthStatus('Comprobando permisos…');

      const { data, error } = await Promise.race([
        supabase.auth.getSession(),
        new Promise((resolve) => setTimeout(() => resolve({ data: { session: null }, error: new Error('timeout') }), 6500)),
      ]);

      if (error) {
        setAuthStatus('No se pudo validar sesion.');
        showAlert(authFeedback, 'danger', 'No se pudo comprobar la sesion. Revisa la conexion e intenta de nuevo.');
        return;
      }

      currentUser = data.session?.user || null;

      if (!currentUser) {
        setAuthStatus('No hay sesion iniciada.');
        showAlert(authFeedback, 'danger', 'Debes iniciar sesion para abrir el panel admin.');
        return;
      }

      if (!isAdminEmail(currentUser.email || '')) {
        setAuthStatus(`Sesion iniciada como ${currentUser.email || 'usuario'}, pero sin permisos de admin.`);
        showAlert(authFeedback, 'danger', 'Tu cuenta no esta autorizada para este panel. Configura PUBLIC_ADMIN_EMAILS.');
        return;
      }

      try {
        await refreshAll();
        maybeAutoMigrateImages().catch((migrationError) => {
          setImagesStatus('warning', `Migración automática con incidencia: ${migrationError?.message || 'error desconocido'}`);
        });
      } catch (catalogError) {
        setAuthStatus('Sesion valida, pero no se pudieron cargar datos.');
        showAlert(authFeedback, 'danger', `Error al cargar catalogo: ${catalogError.message || 'desconocido'}`);
        return;
      }

      setAuthStatus(`Sesion valida: ${currentUser.email || 'admin'}`);
      if (authGate) authGate.style.display = 'none';
      if (adminShell) {
        adminShell.style.display = 'grid';
        adminShell.querySelectorAll('.panel, .admin-panel').forEach((entry) => entry.classList.add('in-view'));
      }
      setTab('products');
    }

    tabs.forEach((tabLink) => {
      tabLink.addEventListener('click', async (event) => {
        event.preventDefault();
        const nextTab = tabLink.getAttribute('data-tab');
        if (!nextTab) return;
        setTab(nextTab);

        if (nextTab === 'products') {
          forceShowPanel('products');
          try {
            setCatalogStatus('warning', 'Cargando productos...');
            setProductsDebug('warning', 'Preparando tabla de productos...');
            renderProductsTable();
            await ensureCatalogLoaded();
            renderProductsTable();
            setProductsDebug('ok', `Panel productos listo · ${products.length} producto(s).`);
          } catch (error) {
            setProductsDebug('danger', `Error en panel productos: ${error?.message || 'error desconocido'}`);
            showGlobal('danger', `No se pudieron cargar productos: ${error?.message || 'error desconocido'}`);
          }
        }
      });
    });

    retryBtn?.addEventListener('click', checkAuthAndInit);

    compactSalesMonth?.addEventListener('change', () => {
      selectedCompactSalesMonth = compactSalesMonth.value || null;
      updateCompactSalesSummary(adminOrders);
    });

    reloadCatalogBtn?.addEventListener('click', async () => {
      try {
        setCatalogStatus('warning', 'Actualizando catálogo...');
        await refreshAll();
      } catch (error) {
        showGlobal('danger', `No se pudo recargar el catálogo: ${error?.message || 'error desconocido'}`);
      }
    });

    migrateImagesBtn?.addEventListener('click', async () => {
      const proceed = window.confirm('Se migrarán todas las imágenes existentes a Supabase Storage. ¿Continuar?');
      if (!proceed) return;
      await migrateAllImagesToStorage();
    });

    logoutBtn?.addEventListener('click', async () => {
      if (!supabase) return;
      await supabase.auth.signOut();
      window.location.href = '/perfil';
    });

    createProductBtn?.addEventListener('click', () => openProductModal());
    productCancelBtn?.addEventListener('click', () => productModal.close());
    productForm?.addEventListener('submit', saveProduct);
    productImageFileInput?.addEventListener('change', async () => {
      const file = productImageFileInput instanceof HTMLInputElement ? productImageFileInput.files?.[0] || null : null;
      if (!file) {
        uploadedProductImageDataUrl = null;
        const urlInput = productForm?.elements?.namedItem('image_url');
        setProductImagePreview(urlInput instanceof HTMLInputElement ? urlInput.value : '/catalogo/placeholder.svg');
        return;
      }

      try {
        uploadedProductImageDataUrl = await prepareProductImageData(file);
        setProductImagePreview(uploadedProductImageDataUrl);
      } catch (error) {
        uploadedProductImageDataUrl = null;
        if (productImageFileInput instanceof HTMLInputElement) {
          productImageFileInput.value = '';
        }
        const reason = error instanceof Error ? error.message : 'No se pudo leer la imagen seleccionada.';
        showAlert(productFormFeedback, 'danger', reason);
      }
    });
    productForm?.elements?.namedItem('image_url')?.addEventListener('input', (event) => {
      if (uploadedProductImageDataUrl) return;
      const target = event.target;
      setProductImagePreview(target && target.value ? target.value : '/catalogo/placeholder.svg');
    });
    productForm?.elements?.namedItem('name')?.addEventListener('input', () => {
      const slugInput = productForm.elements.namedItem('slug');
      if (!slugInput.value.trim()) {
        slugInput.value = toSlug(productForm.elements.namedItem('name').value);
      }
    });

    createCategoryBtn?.addEventListener('click', () => openCategoryModal());
    categoryCancelBtn?.addEventListener('click', () => categoryModal.close());
    categoryForm?.addEventListener('submit', saveCategory);
    categoryForm?.elements?.namedItem('name')?.addEventListener('input', () => {
      const slugInput = categoryForm.elements.namedItem('slug');
      if (!slugInput.value.trim()) {
        slugInput.value = toSlug(categoryForm.elements.namedItem('name').value);
      }
    });

    refreshInvoicesBtn?.addEventListener('click', async () => {
      await refreshBusinessData();
      renderInvoicesTable();
    });

    productImagesAddBtn?.addEventListener('click', async () => {
      if (!currentImagesProductId) return;

      const imageUrl = String(productImagesNewUrl?.value || '').trim();
      const imageFile = productImagesNewFile instanceof HTMLInputElement ? productImagesNewFile.files?.[0] || null : null;
      const altText = String(productImagesNewAlt?.value || '').trim();
      if (!imageUrl && !imageFile) {
        showAlert(productImagesFeedback, 'danger', 'Ingresa una URL o sube un archivo de imagen.');
        return;
      }

      await addProductImage(currentImagesProductId, imageUrl, altText, imageFile);
      if (productImagesNewUrl instanceof HTMLInputElement) {
        productImagesNewUrl.value = '';
      }
      if (productImagesNewFile instanceof HTMLInputElement) {
        productImagesNewFile.value = '';
      }
      if (productImagesNewAlt instanceof HTMLInputElement) {
        productImagesNewAlt.value = '';
      }
    });

    productImagesList?.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!action || !id) return;

      if (action === 'save-product-image') {
        await saveProductImage(id);
      }

      if (action === 'set-primary-product-image') {
        await setPrimaryProductImage(currentImagesProductId, id);
      }

      if (action === 'delete-product-image') {
        const shouldDelete = window.confirm('¿Seguro que quieres borrar esta imagen?');
        if (!shouldDelete) return;
        await deleteProductImage(id);
      }
    });

    productsTableBody?.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'edit-product') {
        openProductModal(id);
      }

      if (action === 'manage-product-images') {
        openProductImagesModal(id);
      }

      if (action === 'toggle-product-visibility') {
        const nextActive = button.getAttribute('data-next-active') === '1';
        await toggleProductVisibility(id, nextActive);
      }

      if (action === 'delete-product') {
        const shouldDelete = window.confirm('¿Seguro que quieres borrar este producto?');
        if (!shouldDelete) return;
        await deleteProduct(id);
      }
    });

    categoriesTableBody?.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'view-category-products') {
        openCategoryProductsModal(id);
      }

      if (action === 'edit-category') {
        openCategoryModal(id);
      }
      if (action === 'delete-category') {
        const shouldDelete = window.confirm('¿Seguro que quieres borrar esta categoria?');
        if (!shouldDelete) return;
        await deleteCategory(id);
      }
    });

    ordersTableBody?.addEventListener('change', (event) => {
      const target = event.target;
      const action = target.getAttribute('data-action');
      const id = target.getAttribute('data-id');
      if (!action || !id) return;

      if (action === 'order-status') {
        updateOrderStatus(id, target.value);
      }

      if (action === 'return-status') {
        updateReturnStatus(id, target.value);
      }
    });

    ordersTableBody?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'invoice-order') {
        createInvoiceFromOrder(id);
      }

      if (action === 'request-return') {
        requestReturn(id);
      }
    });

    invoicesTableBody?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'download-invoice') {
        downloadInvoice(id);
      }
    });

    setAuthStatus('Inicializando panel admin…');
    checkAuthAndInit().catch((error) => {
      const reason = error instanceof Error ? error.message : 'Error inesperado.';
      showBootstrapError(`No se pudo iniciar el panel: ${reason}`);
    });
  </script>
</Layout>
