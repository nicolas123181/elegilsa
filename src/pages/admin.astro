    const INVOICES_KEY = 'elegilsa_invoices_v1';
    const RETURNS_KEY = 'elegilsa_returns_v1';
    const ADMIN_CATALOG_CACHE_KEY = 'elegilsa_admin_catalog_cache_v1';
    const ADMIN_IMAGE_MIGRATION_FLAG_KEY = 'elegilsa_admin_image_migration_done_v1';
    const SHOPIFY_PRODUCTS_URL = 'https://elegilsa.com/products.json?limit=250';
    const SERVER_FALLBACK_PRODUCTS = (() => {
      try {
        const raw = document.getElementById('admin-server-fallback-products')?.textContent || '[]';
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    })();
    const FALLBACK_IMAGES_BY_SLUG = (() => {
      const map = new Map();
      for (const product of SERVER_FALLBACK_PRODUCTS) {
        const slug = String(product?.slug || '').trim();
        if (!slug) continue;
        const urls = Array.isArray(product?.product_images)
          ? product.product_images
              .map((image) => String(image?.url || '').trim())
              .filter((url) => url.startsWith('http://') || url.startsWith('https://'))
          : [];
        if (urls.length > 0) {
          map.set(slug, urls);
        }
      }
      return map;
    })();

