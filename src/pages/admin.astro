---
import Layout from '../layouts/Layout.astro';

const ADMIN_SHOPIFY_FALLBACK_URL = 'https://elegilsa.com/products.json?limit=250';

let serverFallbackProducts = [];
try {
  const response = await fetch(ADMIN_SHOPIFY_FALLBACK_URL, {
    headers: { Accept: 'application/json' },
  });

  if (response.ok) {
    const payload = await response.json();
    const sourceProducts = Array.isArray(payload?.products) ? payload.products : [];

    serverFallbackProducts = sourceProducts
      .map((entry, index) => {
        const slug = String(entry?.handle || '').trim();
        const name = String(entry?.title || '').trim();
        if (!slug || !name) return null;

        const firstVariant = Array.isArray(entry?.variants) ? entry.variants[0] : null;
        const cents = Math.round(Number(firstVariant?.price || 0) * 100);
        const compareCents = firstVariant?.compare_at_price ? Math.round(Number(firstVariant.compare_at_price) * 100) : null;
        const stock = Number(firstVariant?.inventory_quantity || 0);
        const images = Array.isArray(entry?.images) ? entry.images : [];
        const mappedImages = images
          .map((img, imgIndex) => {
            const url = String(img?.src || '').trim();
            if (!url) return null;
            return {
              id: imgIndex + 1,
              url,
              alt_text: String(img?.alt || '').trim() || name,
              position: imgIndex + 1,
            };
          })
          .filter(Boolean);

        return {
          id: `shopify:${slug}:${index}`,
          category_id: null,
          slug,
          name,
          description: typeof entry?.body_html === 'string' ? entry.body_html.replace(/<[^>]+>/g, '').trim() : null,
          price_cents: Number.isFinite(cents) && cents > 0 ? cents : 0,
          compare_at_cents: Number.isFinite(compareCents) ? compareCents : null,
          featured: false,
          is_active: true,
          created_at: String(entry?.published_at || new Date().toISOString()),
          product_variants: [
            {
              id: `shopify-variant:${slug}`,
              name: 'Talla única',
              stock: Number.isFinite(stock) ? Math.max(0, stock) : 0,
              is_active: true,
              position: 1,
            },
          ],
          product_images: mappedImages.length > 0
            ? mappedImages
            : [
                {
                  id: 1,
                  url: '/catalogo/placeholder.svg',
                  alt_text: name,
                  position: 1,
                },
              ],
          is_shopify_fallback: true,
        };
      })
      .filter(Boolean);
  }
} catch {
  serverFallbackProducts = [];
}
