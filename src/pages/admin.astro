    function readCatalogCache() {
      try {
        const raw = localStorage.getItem(ADMIN_CATALOG_CACHE_KEY);
        const parsed = raw ? JSON.parse(raw) : null;
        if (!parsed || typeof parsed !== 'object') return null;
        const cachedCategories = Array.isArray(parsed.categories) ? parsed.categories : null;
        const cachedProducts = Array.isArray(parsed.products) ? parsed.products : null;
        if (!cachedCategories || !cachedProducts) return null;
        return {
          categories: cachedCategories,
          products: cachedProducts,
          updatedAt: typeof parsed.updatedAt === 'string' ? parsed.updatedAt : null,
        };
      } catch {
        return null;
      }
    }

    function writeCatalogCache(payload) {
      try {
        localStorage.setItem(
          ADMIN_CATALOG_CACHE_KEY,
          JSON.stringify({
            categories: payload.categories,
            products: payload.products,
            updatedAt: new Date().toISOString(),
          })
        );
      } catch {}
    }

    function parseMaybeJson(value, fallback) {
      if (Array.isArray(value) || (value && typeof value === 'object')) {
        return value;
      }

      if (typeof value !== 'string') {
        return fallback;
      }

      try {
        const parsed = JSON.parse(value);
        return parsed ?? fallback;
      } catch {
        return fallback;
      }
    }

    function normalizeOrderItems(items) {
      const source = Array.isArray(items) ? items : [];
      return source.map((item) => ({
        ...item,
        productId: item?.productId ?? item?.product_id ?? null,
        product_id: item?.product_id ?? item?.productId ?? null,
        name: item?.name ?? item?.product_name ?? 'Producto',
        quantity: Math.max(0, Number(item?.quantity) || 0),
        unitPriceCents: Math.max(
          0,
          Number(item?.unitPriceCents ?? item?.unit_price_cents ?? item?.price_cents ?? 0) || 0
        ),
      }));
    }

    function normalizeOrderRow(row, itemsByOrderId = new Map()) {
      const id = String(row?.id || '').trim();
      if (!id) return null;

      const remoteItems = itemsByOrderId.get(id);
      const embeddedItems = parseMaybeJson(row?.items, []);
      const shipping = parseMaybeJson(row?.shipping ?? row?.shipping_data, {});

      return {
        ...row,
        id,
        created_at: row?.created_at || new Date().toISOString(),
        user_id: row?.user_id || row?.customer_id || row?.profile_id || null,
        shipping_method: row?.shipping_method || row?.shipping_type || 'standard',
        payment_method: row?.payment_method || row?.payment_type || 'stripe',
        shipping: shipping && typeof shipping === 'object' ? shipping : {},
        items: normalizeOrderItems(remoteItems && remoteItems.length ? remoteItems : embeddedItems),
        subtotal_cents: Math.max(0, Number(row?.subtotal_cents) || 0),
        shipping_cents: Math.max(0, Number(row?.shipping_cents) || 0),
        total_cents: Math.max(
          0,
          Number(row?.total_cents ?? row?.amount_cents ?? row?.amount_total_cents ?? 0) || 0
        ),
        status: String(row?.status || 'pending'),
      };
    }

    function normalizeInvoiceRow(row) {
      const id = String(row?.id || '').trim();
      const orderId = String(row?.order_id || row?.orderId || '').trim();
      if (!id || !orderId) return null;

      return {
        ...row,
        id,
        order_id: orderId,
        created_at: row?.created_at || new Date().toISOString(),
        total_cents: Math.max(0, Number(row?.total_cents ?? row?.amount_cents ?? 0) || 0),
        customer: row?.customer || row?.customer_name || row?.billing_name || 'Cliente',
      };
    }

    function mergeRecords(primary, secondary) {
      const merged = new Map();
      for (const record of [...(Array.isArray(primary) ? primary : []), ...(Array.isArray(secondary) ? secondary : [])]) {
        const id = String(record?.id || '').trim();
        if (!id || merged.has(id)) continue;
        merged.set(id, record);
      }
      return [...merged.values()];
    }

    function buildDerivedInvoices(orders, explicitInvoices) {
      const existing = new Map();
      for (const invoice of explicitInvoices) {
        existing.set(String(invoice.order_id || ''), invoice);
      }

      for (const order of orders) {
        if (!order?.id || String(order.status || '') === 'cancelled') continue;
        if (existing.has(String(order.id))) continue;
        existing.set(String(order.id), {
          id: `AUTO-${order.id}`,
          order_id: order.id,
          created_at: order.created_at || new Date().toISOString(),
          total_cents: Number(order.total_cents) || 0,
          customer: order.shipping?.full_name || order.user_id || 'Cliente',
          auto_generated: true,
        });
      }

      return [...existing.values()].sort((a, b) => +new Date(b.created_at) - +new Date(a.created_at));
    }

    async function refreshBusinessData() {
      const localOrders = readLocalArray(ORDERS_KEY);
      const localInvoices = readLocalArray(INVOICES_KEY);

      let remoteOrders = [];
      let remoteInvoices = [];

      try {
        const ordersResult = await supabase.from('orders').select('*').order('created_at', { ascending: false });
        if (!ordersResult.error && Array.isArray(ordersResult.data)) {
          let itemsByOrderId = new Map();
          const itemsResult = await supabase.from('order_items').select('*').order('id', { ascending: true });
          if (!itemsResult.error && Array.isArray(itemsResult.data)) {
            itemsByOrderId = itemsResult.data.reduce((map, item) => {
              const orderId = String(item?.order_id || '').trim();
              if (!orderId) return map;
              if (!map.has(orderId)) map.set(orderId, []);
              map.get(orderId).push(item);
              return map;
            }, new Map());
          }

          remoteOrders = ordersResult.data
            .map((row) => normalizeOrderRow(row, itemsByOrderId))
            .filter(Boolean);
        }
      } catch {}

      try {
        const invoicesResult = await supabase.from('invoices').select('*').order('created_at', { ascending: false });
        if (!invoicesResult.error && Array.isArray(invoicesResult.data)) {
          remoteInvoices = invoicesResult.data.map(normalizeInvoiceRow).filter(Boolean);
        }
      } catch {}

      adminOrders = mergeRecords(remoteOrders, localOrders).sort((a, b) => +new Date(b.created_at) - +new Date(a.created_at));
      adminInvoices = buildDerivedInvoices(
        adminOrders,
        mergeRecords(remoteInvoices, localInvoices)
          .map(normalizeInvoiceRow)
          .filter(Boolean)
      );
    }

    function resolveCatalogPathToFallbackUrl(pathLike, slugHint = '') {
      const value = String(pathLike || '').trim();
      if (!value.startsWith('/catalogo/')) return '';

      let slug = String(slugHint || '').trim();
      const normalized = value.replace(/^\/+/, '');
      const parts = normalized.split('/');
      if (!slug && parts.length >= 3 && parts[0] === 'catalogo') {
        slug = String(parts[1] || '').trim();
      }
      if (!slug) return '';

      const urls = FALLBACK_IMAGES_BY_SLUG.get(slug) || [];
      if (urls.length === 0) return '';

      const fileName = parts.length >= 3 ? parts[2] : '';
      const indexMatch = String(fileName).match(/(\d+)/);
      const imageIndex = Math.max(0, Number(indexMatch?.[1] || 1) - 1);
      return urls[imageIndex] || urls[0] || '';
    }

    function getProductImagesBaseUrl() {
      if (PRODUCT_IMAGES_BASE_URL) {
        return PRODUCT_IMAGES_BASE_URL.replace(/\/+$/, '');
      }

      if (!SUPABASE_URL) return '';
      return `${SUPABASE_URL.replace(/\/+$/, '')}/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}`;
    }

    function toStorageReference(rawValue) {
      const value = String(rawValue || '').trim();
      if (!value) return '';

      const baseUrl = getProductImagesBaseUrl();
      if (baseUrl && value.startsWith(`${baseUrl}/`)) {
        return `${PRODUCT_IMAGES_BUCKET}/${value.slice(baseUrl.length + 1)}`;
      }

      if (value.includes(`/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}/`)) {
        const [, storagePath = ''] = value.split(`/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}/`);
        return storagePath ? `${PRODUCT_IMAGES_BUCKET}/${storagePath}` : '';
      }

      if (value.startsWith(`${PRODUCT_IMAGES_BUCKET}/`)) {
        return value;
      }

      return value;
    }

    function resolveImageUrl(rawValue) {
      const value = toStorageReference(rawValue);
      if (!value) return '/catalogo/placeholder.svg';

      if (value.startsWith('/catalogo/')) {
        const fallbackUrl = resolveCatalogPathToFallbackUrl(value);
        return fallbackUrl || '/catalogo/placeholder.svg';
      }

      if (
        value.startsWith('http://') ||
        value.startsWith('https://') ||
        value.startsWith('data:image/') ||
        value.startsWith('blob:')
      ) {
        return value;
      }

      if (value.startsWith('//')) {
        return `https:${value}`;
      }

      if (value.startsWith('storage/v1/object/public/')) {
        if (!SUPABASE_URL) return value;
        return `${SUPABASE_URL.replace(/\/+$/, '')}/${value}`;
      }

      if (value.startsWith('/')) {
        return value;
      }

      if (value.startsWith(`${PRODUCT_IMAGES_BUCKET}/`)) {
        const baseUrl = getProductImagesBaseUrl();
        const storagePath = value.slice(PRODUCT_IMAGES_BUCKET.length + 1);
        return baseUrl ? `${baseUrl}/${storagePath}` : value;
      }

      if (!supabase) return value;
      const storagePath = value.replace(/^\/+/, '');
      const { data } = supabase.storage.from(PRODUCT_IMAGES_BUCKET).getPublicUrl(storagePath);
      return String(data?.publicUrl || value);
    }

    function normalizeExt(file) {
      const fromName = String(file?.name || '').split('.').pop()?.toLowerCase();
      if (fromName && /^[a-z0-9]{2,6}$/.test(fromName)) return fromName;
      const fromType = String(file?.type || '').split('/').pop()?.toLowerCase();
      if (fromType === 'jpeg') return 'jpg';
      if (fromType && /^[a-z0-9]{2,6}$/.test(fromType)) return fromType;
      return 'jpg';
    }

    async function uploadProductImageFile(file, productId) {
      if (!(file instanceof File) || !String(file.type || '').startsWith('image/')) {
        throw new Error('Selecciona un archivo de imagen válido.');
      }

      const maxBytes = PRODUCT_IMAGE_MAX_MB * 1024 * 1024;
      if (Number(file.size) > maxBytes) {
        throw new Error(`La imagen supera ${PRODUCT_IMAGE_MAX_MB}MB.`);
      }

      const safeProductId = String(productId || 'tmp').replace(/[^a-zA-Z0-9_-]/g, '_');
      const ext = normalizeExt(file);
      const randomSuffix = Math.random().toString(36).slice(2, 9);
      const filePath = `${safeProductId}/${Date.now()}-${randomSuffix}.${ext}`;

      const { error: uploadError } = await supabase.storage.from(PRODUCT_IMAGES_BUCKET).upload(filePath, file, {
        cacheControl: '31536000',
        upsert: false,
        contentType: file.type,
      });

      if (uploadError) {
        throw new Error(`No se pudo subir a Storage (${PRODUCT_IMAGES_BUCKET}): ${uploadError.message}`);
      }

        throw new Error('No se pudo obtener URL pública de la imagen.');
      return `${PRODUCT_IMAGES_BUCKET}/${filePath}`;
    }

    function isStorageHostedImage(url) {
      const value = String(url || '').trim();
      if (!value) return false;
      if (value.includes(`/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}/`)) return true;
      if (value.startsWith(`${PRODUCT_IMAGES_BUCKET}/`)) return true;
      return false;
    }

    async function uploadProductImageFileLegacyBroken(file, productId) {
      if (!(file instanceof File) || !String(file.type || '').startsWith('image/')) {
        throw new Error('Selecciona un archivo de imagen valido.');
      }

      const maxBytes = PRODUCT_IMAGE_MAX_MB * 1024 * 1024;
      if (Number(file.size) > maxBytes) {
        throw new Error(`La imagen supera ${PRODUCT_IMAGE_MAX_MB}MB.`);
      }

      const safeProductId = String(productId || 'tmp').replace(/[^a-zA-Z0-9_-]/g, '_');
      const ext = normalizeExt(file);
      const randomSuffix = Math.random().toString(36).slice(2, 9);
      const filePath = `${safeProductId}/${Date.now()}-${randomSuffix}.${ext}`;

      const { error: uploadError } = await supabase.storage.from(PRODUCT_IMAGES_BUCKET).upload(filePath, file, {
        cacheControl: '31536000',
        upsert: false,
        contentType: file.type,
      });

      if (uploadError) {
        throw new Error(`No se pudo subir a Storage (${PRODUCT_IMAGES_BUCKET}): ${uploadError.message}`);
      }

      return `${PRODUCT_IMAGES_BUCKET}/${filePath}`;
    }

    function isStorageHostedImageLegacy(url) {
      const value = toStorageReference(url);
      if (!value) return false;
      if (value.includes(`/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}/`)) return true;
      if (value.startsWith(`${PRODUCT_IMAGES_BUCKET}/`)) return true;
      return false;
    }

    async function fetchImageAsFile(url, fallbackName = 'imagen') {
      const sourceUrl = resolveImageUrl(url);
      const response = await fetch(sourceUrl, { mode: 'cors' });
      if (!response.ok) {
        throw new Error(`No se pudo descargar (${response.status})`);
      }

      const blob = await response.blob();
      if (!String(blob.type || '').startsWith('image/')) {
        throw new Error('El recurso no es una imagen.');
      }

      const ext = normalizeExt({ name: fallbackName, type: blob.type });
      const filename = `${fallbackName}.${ext}`;
      return new File([blob], filename, { type: blob.type || 'image/jpeg' });
    }

    async function migrateAllImagesToStorage() {
      setImagesStatus('warning', 'Migrando imágenes a Supabase Storage...');

      const { data: rows, error } = await supabase
        .from('product_images')
        .select('id,product_id,url,position')
        .order('id', { ascending: true });

      if (error) {
        setImagesStatus('danger', `No se pudo leer product_images: ${error.message}`);
        return { migrated: 0, skipped: 0, failed: 1 };
      }

      const images = Array.isArray(rows) ? rows : [];
      if (images.length === 0) {
        setImagesStatus('ok', 'No hay imágenes para migrar.');
        return { migrated: 0, skipped: 0, failed: 0 };
      }

      const { data: productRows } = await supabase
        .from('products')
        .select('id,slug');
      const slugByProductId = new Map(
        (Array.isArray(productRows) ? productRows : [])
          .map((row) => [String(row.id || ''), String(row.slug || '').trim()])
      );

      let migrated = 0;
      let skipped = 0;
      let failed = 0;

      for (const image of images) {
        const currentUrl = String(image.url || '').trim();
        if (!currentUrl || currentUrl.startsWith('data:image/')) {
          skipped += 1;
          continue;
        }

        if (isStorageHostedImageLegacy(currentUrl)) {
          skipped += 1;
          continue;
        }

        try {
          const slug = slugByProductId.get(String(image.product_id || '')) || '';
          const sourceUrl = currentUrl.startsWith('/catalogo/')
            ? resolveCatalogPathToFallbackUrl(currentUrl, slug)
            : currentUrl;

          if (!sourceUrl) {
            failed += 1;
            continue;
          }

          const file = await fetchImageAsFile(sourceUrl, `product-${image.product_id || 'img'}-${image.id}`);
          const nextUrl = await uploadProductImageFileLegacyBroken(file, String(image.product_id || 'producto'));
          const { error: updateError } = await supabase.from('product_images').update({ url: nextUrl }).eq('id', image.id);
          if (updateError) {
            failed += 1;
            continue;
          }
          migrated += 1;
        } catch {
          failed += 1;
        }
      }

      await refreshAll();

      if (failed > 0) {
        setImagesStatus('warning', `Migración completada con incidencias: ${migrated} migradas, ${skipped} ya en Storage/omitidas, ${failed} con error.`);
      } else {
        setImagesStatus('ok', `Migración completada: ${migrated} migradas, ${skipped} ya en Storage/omitidas.`);
      }

      return { migrated, skipped, failed };
    }

    async function maybeAutoMigrateImages() {
      if (localStorage.getItem(ADMIN_IMAGE_MIGRATION_FLAG_KEY) === '1') return;
      const summary = await migrateAllImagesToStorage();
      if (summary && summary.failed === 0) {
