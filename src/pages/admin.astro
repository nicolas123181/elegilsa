    function readFileAsDataUrl(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ''));
        reader.onerror = () => reject(new Error('No se pudo leer el archivo.'));
        reader.readAsDataURL(file);
      });
    }

    async function prepareProductImageData(file) {
      const rawDataUrl = await readFileAsDataUrl(file);
      if (!rawDataUrl.startsWith('data:image/')) {
        throw new Error('El archivo seleccionado no es una imagen válida.');
      }
      return rawDataUrl;
    }

    function toMonthKey(value) {
      const date = new Date(value);
      if (!Number.isFinite(date.getTime())) return null;
      const month = String(date.getMonth() + 1).padStart(2, '0');
      return `${date.getFullYear()}-${month}`;
    }

    function monthLabel(monthKey) {
      const [year, month] = String(monthKey).split('-').map(Number);
      if (!Number.isFinite(year) || !Number.isFinite(month)) return monthKey;
      const date = new Date(year, month - 1, 1);
      return new Intl.DateTimeFormat('es-ES', { month: 'long', year: 'numeric' }).format(date);
    }

    function getDaysInMonth(monthKey) {
      const [year, month] = String(monthKey).split('-').map(Number);
      if (!Number.isFinite(year) || !Number.isFinite(month)) return 30;
      return new Date(year, month, 0).getDate();
    }

    function getMonthWeekRanges(monthKey) {
      const daysInMonth = getDaysInMonth(monthKey);
      return [
        { key: 'w1', label: 'Semana 1', startDay: 1, endDay: Math.min(7, daysInMonth) },
        { key: 'w2', label: 'Semana 2', startDay: 8, endDay: Math.min(14, daysInMonth) },
        { key: 'w3', label: 'Semana 3', startDay: 15, endDay: Math.min(21, daysInMonth) },
        { key: 'w4', label: 'Semana 4', startDay: 22, endDay: daysInMonth },
      ].filter((entry) => entry.startDay <= entry.endDay);
    }

    function updateCompactSalesSummary(orders) {
      if (!compactSalesMonth || !compactSalesGrid || !compactSalesTotal) return;

      const validOrders = (orders || []).filter((order) => order.status !== 'cancelled');
      const monthSet = new Set();
      monthSet.add(toMonthKey(new Date().toISOString()));
      for (const order of validOrders) {
        const key = toMonthKey(order.created_at);
        if (key) monthSet.add(key);
      }

      const monthOptions = [...monthSet].filter(Boolean).sort((a, b) => b.localeCompare(a));
      if (monthOptions.length === 0) {
        compactSalesMonth.innerHTML = '';
        compactSalesGrid.innerHTML = '<p class="search-state">Sin datos de ventas para mostrar.</p>';
        compactSalesTotal.textContent = '';
        return;
      }

      if (!selectedCompactSalesMonth || !monthOptions.includes(selectedCompactSalesMonth)) {
        selectedCompactSalesMonth = monthOptions[0];
      }

      compactSalesMonth.innerHTML = monthOptions
        .map((monthKey) => `<option value="${monthKey}" ${monthKey === selectedCompactSalesMonth ? 'selected' : ''}>${monthLabel(monthKey)}</option>`)
        .join('');

      const monthKey = selectedCompactSalesMonth;
      const ranges = getMonthWeekRanges(monthKey);
      const buckets = ranges.map((range) => ({ ...range, cents: 0, orders: 0 }));

      for (const order of validOrders) {
        if (toMonthKey(order.created_at) !== monthKey) continue;
        const day = new Date(order.created_at).getDate();
        const bucket = buckets.find((entry) => day >= entry.startDay && day <= entry.endDay);
        if (!bucket) continue;
        bucket.cents += Number(order.total_cents) || 0;
        bucket.orders += 1;
      }

      const maxValue = Math.max(...buckets.map((entry) => entry.cents), 1);
      const totalCents = buckets.reduce((acc, entry) => acc + entry.cents, 0);

      compactSalesGrid.innerHTML = buckets
        .map((entry) => {
          const width = Math.max(14, Math.round((entry.cents / maxValue) * 100));
          return `
            <article class="compact-sales-card">
              <p>${entry.label}</p>
              <strong>${formatMoney(entry.cents)}</strong>
              <small>${entry.orders} pedido(s) · días ${entry.startDay}-${entry.endDay}</small>
              <div class="compact-sales-progress"><span style="width:${width}%"></span></div>
            </article>
          `;
        })
        .join('');

      compactSalesTotal.textContent = `Total ${monthLabel(monthKey)}: ${formatMoney(totalCents)}`;
    }

    async function fetchShopifyProductsFallback() {
      if (SERVER_FALLBACK_PRODUCTS.length > 0) {
        return SERVER_FALLBACK_PRODUCTS.map((entry) => ({ ...entry }));
      }

      const response = await fetch(SHOPIFY_PRODUCTS_URL, {
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) {
        throw new Error(`Shopify fallback ${response.status}`);
      }

      const payload = await response.json();
      const sourceProducts = Array.isArray(payload?.products) ? payload.products : [];

      return sourceProducts
        .map((entry, index) => {
          const slug = String(entry?.handle || '').trim();
          const name = String(entry?.title || '').trim();
          if (!slug || !name) return null;

          const firstVariant = Array.isArray(entry?.variants) ? entry.variants[0] : null;
          const cents = Math.round(Number(firstVariant?.price || 0) * 100);
          const compareCents = firstVariant?.compare_at_price ? Math.round(Number(firstVariant.compare_at_price) * 100) : null;
          const stock = Number(firstVariant?.inventory_quantity || 0);
          const imageUrl = Array.isArray(entry?.images) && entry.images[0]?.src ? String(entry.images[0].src) : '/catalogo/placeholder.svg';

          return {
            id: `shopify:${slug}:${index}`,
            category_id: null,
            slug,
            name,
            description: typeof entry?.body_html === 'string' ? entry.body_html.replace(/<[^>]+>/g, '').trim() : null,
            price_cents: Number.isFinite(cents) && cents > 0 ? cents : 0,
            compare_at_cents: Number.isFinite(compareCents) ? compareCents : null,
            featured: false,
            is_active: true,
            created_at: String(entry?.published_at || new Date().toISOString()),
            product_variants: [
              {
                id: `shopify-variant:${slug}`,
                name: 'Talla única',
                stock: Number.isFinite(stock) ? Math.max(0, stock) : 0,
                is_active: true,
                position: 1,
              },
            ],
            product_images: [
              {
                id: 1,
                url: imageUrl,
                alt_text: name,
                position: 1,
              },
            ],
            is_shopify_fallback: true,
          };
        })
        .filter(Boolean);
    }

    function isAdminEmail(email) {
      if (!email) return false;
      if (ADMIN_EMAILS.length === 0) return true;
      return ADMIN_EMAILS.includes(String(email).trim().toLowerCase());
    }

    function forceShowPanel(tab) {
      const safeTab = Object.prototype.hasOwnProperty.call(panels, tab) ? tab : 'dashboard';
      const keys = Object.keys(panels);

      for (const key of keys) {
        const panelEl = document.getElementById(`admin-panel-${key}`);
        if (!(panelEl instanceof HTMLElement)) continue;
        panelEl.style.display = key === safeTab ? 'block' : 'none';
      }

      return safeTab;
    }

    function setTab(tab) {
      const safeTab = forceShowPanel(tab);

      tabs.forEach((entry) => {
        const isActive = entry.getAttribute('data-tab') === safeTab;
        entry.classList.toggle('active', isActive);
      });
    }

    function getCategoryName(categoryId) {
      const match = categories.find((entry) => Number(entry.id) === Number(categoryId));
      return match ? match.name : 'Sin categoria';
    }

    function getPrimaryVariant(product) {
      const variants = Array.isArray(product.product_variants) ? product.product_variants : [];
      return variants.find((variant) => variant.is_active) || variants[0] || null;
    }

    function getPrimaryImageUrl(product) {
      const sorted = getSortedImages(product);
      return sorted[0]?.url || '/catalogo/placeholder.svg';
    }

    function getSortedImages(product) {
      const images = Array.isArray(product?.product_images) ? product.product_images : [];
      return [...images].sort((a, b) => (a.position || 0) - (b.position || 0));
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderImageStrip(product) {
      const images = getSortedImages(product);
      if (images.length === 0) {
        return '<span class="admin-image-empty">Sin imagenes</span>';
      }

      const thumbnails = images
        .slice(0, 4)
        .map((img, index) => {
          const label = index === 0 ? 'Principal' : `Imagen ${index + 1}`;
          const src = resolveImageUrl(img.url || '/catalogo/placeholder.svg');
          return `<img class="admin-thumb ${index === 0 ? 'is-primary' : ''}" src="${escapeHtml(src)}" alt="${escapeHtml(img.alt_text || label)}" title="${escapeHtml(label)}" loading="lazy" onerror="this.onerror=null;this.src='/catalogo/placeholder.svg'" />`;
        })
        .join('');
      const extra = images.length > 4 ? `<span class="admin-thumb-more">+${images.length - 4}</span>` : '';
      return `<div class="admin-image-strip">${thumbnails}${extra}</div>`;
    }

    async function fetchCatalogFromSupabase() {
      const categoriesResult = await supabase
        .from('categories')
        .select('id,slug,name,description,created_at')
        .order('name', { ascending: true });
      const categoriesRows = categoriesResult.error ? [] : categoriesResult.data || [];

      const productsResult = await supabase
        .from('products')
        .select('id,category_id,slug,name,description,price_cents,compare_at_cents,featured,is_active,created_at')
        .order('created_at', { ascending: false });

      let productRows = productsResult.data || [];
      if (productsResult.error) {
        const activeProductsResult = await supabase
          .from('products')
          .select('id,category_id,slug,name,description,price_cents,compare_at_cents,featured,is_active,created_at')
          .eq('is_active', true)
          .order('created_at', { ascending: false });

        if (activeProductsResult.error) {
          throw productsResult.error;
        }

        productRows = activeProductsResult.data || [];
      }

      let variants = [];
      const variantsResult = await supabase
        .from('product_variants')
        .select('id,product_id,name,stock,price_cents,is_active,position')
        .order('position', { ascending: true });
      if (!variantsResult.error && Array.isArray(variantsResult.data)) {
        variants = variantsResult.data;
      }

      let images = [];
      const imagesResult = await supabase
        .from('product_images')
        .select('id,product_id,url,alt_text,position')
        .order('position', { ascending: true });
      if (!imagesResult.error && Array.isArray(imagesResult.data)) {
        images = imagesResult.data;
      }

      const variantsByProduct = new Map();
      for (const variant of variants) {
        const key = String(variant.product_id || '');
        if (!variantsByProduct.has(key)) variantsByProduct.set(key, []);
        variantsByProduct.get(key).push(variant);
      }

      const imagesByProduct = new Map();
      for (const image of images) {
        const key = String(image.product_id || '');
        if (!imagesByProduct.has(key)) imagesByProduct.set(key, []);
        imagesByProduct.get(key).push(image);
      }

      const mergedProducts = productRows.map((product) => ({
        ...product,
        product_variants: variantsByProduct.get(String(product.id)) || [],
        product_images: imagesByProduct.get(String(product.id)) || [],
      }));

      return {
        categories: categoriesRows,
        products: mergedProducts,
      };
    }

    async function ensureCatalogLoaded() {
      const cachedCatalog = readCatalogCache();
      let lastError = null;

      for (let attempt = 1; attempt <= 3; attempt += 1) {
        try {
          const fresh = await fetchCatalogFromSupabase();

          if (fresh.products.length === 0) {
            if (cachedCatalog?.products?.length) {
              categories = cachedCatalog.categories;
              products = cachedCatalog.products;
              setCatalogStatus('warning', 'Supabase devolvió 0 productos. Mostrando el último catálogo guardado.');
              return;
            }

            if (SERVER_FALLBACK_PRODUCTS.length > 0) {
              categories = fresh.categories || [];
              products = SERVER_FALLBACK_PRODUCTS.map((entry) => ({ ...entry }));
              setCatalogStatus('warning', 'Supabase devolvió 0 productos. Mostrando catálogo de respaldo del servidor.');
              return;
            }

            try {
              const fallbackProducts = await fetchShopifyProductsFallback();
              if (fallbackProducts.length > 0) {
                categories = fresh.categories || [];
                products = fallbackProducts;
                setCatalogStatus('warning', 'Supabase devolvió 0 productos. Mostrando catálogo de respaldo (Shopify).');
                return;
              }
            } catch {}
          }

          categories = fresh.categories;
          products = fresh.products;
          writeCatalogCache(fresh);

          const updatedAt = new Intl.DateTimeFormat('es-ES', { dateStyle: 'short', timeStyle: 'short' }).format(new Date());
          setCatalogStatus('ok', `Catálogo actualizado · ${updatedAt} · ${products.length} producto(s)`);
          return;
        } catch (error) {
          lastError = error;
          if (attempt < 3) {
            await sleep(220 * attempt);
          }
        }
      }

      if (cachedCatalog?.products?.length) {
        categories = cachedCatalog.categories;
        products = cachedCatalog.products;
        setCatalogStatus('warning', 'No se pudo refrescar el catálogo. Mostrando datos guardados localmente.');
        return;
      }

      try {
        const fallbackProducts = await fetchShopifyProductsFallback();
        if (fallbackProducts.length > 0) {
          categories = cachedCatalog?.categories || [];
          products = fallbackProducts;
          setCatalogStatus('warning', 'Mostrando catálogo de respaldo (Shopify). Revisa permisos de Supabase para edición completa.');
          return;
        }
      } catch {}

      setCatalogStatus('danger', 'No se pudo cargar el catálogo. Pulsa Recargar catálogo para reintentar.');
      throw lastError || new Error('No se pudo cargar el catálogo de administración.');
    }

    function computeTopProducts(orders) {
      const summary = new Map();
      for (const order of orders) {
        const items = Array.isArray(order.items) ? order.items : [];
        for (const item of items) {
          const id = String(item.productId || item.product_id || item.slug || item.name || 'desconocido');
          const name = String(item.name || item.product_name || item.slug || 'Producto');
          const quantity = Number(item.quantity) || 0;
          const revenue = (Number(item.unitPriceCents) || 0) * quantity;

          const prev = summary.get(id) || { name, quantity: 0, revenue: 0 };
          prev.quantity += quantity;
          prev.revenue += revenue;
          summary.set(id, prev);
        }
      }

      return [...summary.values()].sort((a, b) => b.quantity - a.quantity).slice(0, 8);
    }

