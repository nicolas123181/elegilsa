    async function setPrimaryProductImage(productId, imageId) {
      const product = products.find((entry) => String(entry.id) === String(productId));
      if (!product) {
        showAlert(productImagesFeedback, 'danger', 'Producto no encontrado.');
        return;
      }

      const sorted = getSortedImages(product);
      if (sorted.length <= 1) {
        showAlert(productImagesFeedback, 'ok', 'Ya existe una única imagen principal.');
        return;
      }

      const selected = sorted.find((entry) => String(entry.id) === String(imageId));
      if (!selected) {
        showAlert(productImagesFeedback, 'danger', 'Imagen no encontrada.');
        return;
      }

      const reordered = [selected, ...sorted.filter((entry) => String(entry.id) !== String(imageId))];
      for (let index = 0; index < reordered.length; index += 1) {
        const image = reordered[index];
        const { error } = await supabase.from('product_images').update({ position: index + 1 }).eq('id', image.id).eq('product_id', productId);
        if (error) {
          showAlert(productImagesFeedback, 'danger', `No se pudo actualizar orden de imágenes: ${error.message}`);
          return;
        }
      }

      await refreshAll();
      renderProductImagesModalContent(productId);
      showAlert(productImagesFeedback, 'ok', 'Imagen principal actualizada.');
    }

