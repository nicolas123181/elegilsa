<section class="admin-page-head">
    <div>
      <h1>Panel Admin</h1>
      <p>Controla ventas, catalogo, usuarios, pedidos y facturacion desde un unico panel.</p>
    </div>
    <div class="admin-head-actions row">
      <a class="btn secondary" href="/collections/all">Ver tienda</a>
    </div>
  </section>

  <div id="admin-auth-gate" class="panel" style="margin-bottom: 1rem;">
    <h2 style="margin-top: 0;">Acceso de administrador</h2>
    <p id="admin-auth-status" style="margin: 0; color: var(--muted);">Validando sesion…</p>
    <div class="row" style="margin-top: 0.7rem;">
      <a id="admin-login-link" class="btn" href="/perfil?next=/admin">Iniciar sesion</a>
      <button id="admin-retry-btn" type="button" class="btn secondary">Reintentar</button>
    </div>
    <p id="admin-auth-feedback" class="alert" style="display: none; margin-top: 0.9rem;"></p>
  </div>

  <div id="admin-shell" class="admin-shell" style="display: none;">
    <aside class="admin-sidebar panel">
      <h2 class="admin-sidebar-title">Gestion</h2>
      <nav class="admin-sidebar-nav" id="admin-tabs" aria-label="Secciones de administracion">
        <a href="/admin" data-tab="dashboard">Dashboard</a>
        <a href="/admin/products" data-tab="products" class="active">Productos</a>
        <a href="/admin/categories" data-tab="categories">Categorias</a>
        <a href="/admin/orders" data-tab="orders">Pedidos</a>
        <a href="/admin/users" data-tab="users">Usuarios</a>
        <a href="/admin/invoices" data-tab="invoices">Facturas</a>
      </nav>
      <div class="admin-logout-form">
        <button id="admin-logout-btn" type="button" class="btn secondary" style="width: 100%;">Cerrar sesion</button>
      </div>
    </aside>

    <div class="admin-content" style="display: grid; gap: 1rem;">
      <section id="admin-panel-dashboard" class="panel admin-panel" style="display: none;">
        <h2 style="margin-top: 0;">KPIs</h2>
        <div class="kpi-grid" id="kpi-grid"></div>

        <div class="panel" style="margin-top: 1rem;">
          <div class="compact-sales-head">
            <h3 style="margin: 0;">Ventas del mes por semanas</h3>
            <div class="compact-sales-controls">
              <label class="compact-sales-filter">
                <span>Mes principal</span>
                <select id="compact-sales-month"></select>
              </label>
              <label class="compact-sales-filter">
                <span>Comparar con</span>
                <select id="compact-sales-compare-month"></select>
              </label>
              <div class="compact-sales-view-toggle" id="compact-sales-view-toggle" role="tablist" aria-label="Modo de visualizacion">
                <button type="button" class="btn secondary is-active" data-view="summary">Resumen</button>
                <button type="button" class="btn secondary" data-view="chart">Grafico</button>
              </div>
            </div>
          </div>
          <div class="compact-sales-grid" id="compact-sales-grid"></div>
          <div id="compact-sales-chart" class="compact-sales-chart" style="display: none;"></div>
          <p id="compact-sales-total" class="compact-sales-total"></p>
        </div>

        <div class="panel" style="margin-top: 1rem;">
          <h3 style="margin-top: 0;">Productos mas vendidos</h3>
          <div class="table-wrap">
            <table class="admin-table" id="top-products-table">
              <thead>
                <tr>
                  <th>Producto</th>
                  <th>Unidades</th>
                  <th>Facturacion</th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </section>

      <section id="admin-panel-products" class="panel admin-panel" style="display: block;">
        <div class="admin-page-head" style="margin-bottom: 0.6rem;">
          <div>
            <h2 style="margin: 0;">Productos</h2>
            <p style="margin: 0.2rem 0 0; color: var(--muted);">Crear, editar y eliminar. No se permite borrar productos con ventas.</p>
            <p id="admin-catalog-status" class="admin-catalog-status" style="display: none;"></p>
            <p id="admin-products-debug" class="admin-catalog-status" style="display: none;"></p>
          </div>
          <div class="admin-products-head-actions">
            <label class="admin-inline-filter">
              <span>Buscar producto</span>
              <input id="products-filter" type="search" placeholder="ID, nombre, slug o categoria" autocomplete="off" />
            </label>
            <div class="row">
              <button id="reload-catalog-btn" type="button" class="btn secondary">Recargar catálogo</button>
              <button id="create-product-btn" type="button">Nuevo producto</button>
            </div>
          </div>
        </div>

        <div class="table-wrap">
          <table class="admin-table" id="products-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Slug</th>
                <th>Categoria</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Activo</th>
                <th>Imagenes</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="9">Cargando productos...</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="row" style="justify-content: space-between; align-items: center; margin-top: 0.9rem; gap: 0.75rem; flex-wrap: wrap;">
          <p id="products-pagination-status" style="margin: 0; color: var(--muted);">Cargando productos...</p>
          <div class="row" style="gap: 0.5rem;">
            <button id="products-prev-page" type="button" class="btn secondary">Anterior</button>
            <button id="products-next-page" type="button" class="btn secondary">Siguiente</button>
          </div>
        </div>
      </section>

      <section id="admin-panel-categories" class="panel admin-panel" style="display: none;">
        <div class="admin-page-head" style="margin-bottom: 0.6rem;">
          <div>
            <h2 style="margin: 0;">Categorias</h2>
            <p style="margin: 0.2rem 0 0; color: var(--muted);">Gestiona la estructura del catalogo.</p>
          </div>
          <button id="create-category-btn" type="button">Nueva categoria</button>
        </div>

        <div class="table-wrap">
          <table class="admin-table" id="categories-table">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Slug</th>
                <th>Descripcion</th>
                <th>Productos</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </section>

      <section id="admin-panel-orders" class="panel admin-panel" style="display: none;">
        <h2 style="margin-top: 0;">Pedidos</h2>
        <div class="table-wrap">
          <table class="admin-table" id="orders-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Total</th>
                <th>Envio</th>
                <th>Estado</th>
                <th>Devolucion</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </section>

      <section id="admin-panel-users" class="panel admin-panel" style="display: none;">
        <div class="admin-page-head" style="margin-bottom: 0.6rem;">
          <div>
            <h2 style="margin: 0;">Usuarios</h2>
            <p style="margin: 0.2rem 0 0; color: var(--muted);">Busca por nombre o por id visual para localizar usuarios mas rapido.</p>
          </div>
          <label style="display: inline-flex; flex-direction: column; gap: 0.2rem; min-width: 240px; color: var(--muted); font-size: 0.92rem;">
            Buscar usuario
            <input id="users-filter" type="search" placeholder="Nombre o ID" autocomplete="off" />
          </label>
        </div>
        <div class="table-wrap">
          <table class="admin-table" id="users-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Usuario</th>
                <th>Pedidos</th>
                <th>Gasto total</th>
                <th>Ultimo pedido</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </section>

      <section id="admin-panel-invoices" class="panel admin-panel" style="display: none;">
        <div class="admin-page-head" style="margin-bottom: 0.6rem;">
          <div>
            <h2 style="margin: 0;">Facturas</h2>
            <p style="margin: 0.2rem 0 0; color: var(--muted);">Genera y descarga facturas para tus pedidos.</p>
          </div>
          <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
            <label style="display: inline-flex; flex-direction: column; gap: 0.2rem; min-width: 240px; color: var(--muted); font-size: 0.92rem;">
              Buscar por cliente
              <input id="invoice-customer-filter" type="search" placeholder="Nombre del cliente" autocomplete="off" />
            </label>
            <button id="refresh-invoices-btn" type="button" class="btn secondary">Actualizar</button>
          </div>
        </div>

        <div class="table-wrap">
          <table class="admin-table" id="invoices-table">
            <thead>
              <tr>
                <th>Factura</th>
                <th>Pedido</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </section>
    </div>
  </div>

  <dialog id="product-modal" class="admin-modal" aria-label="Editor de producto">
    <section class="panel admin-modal-panel">
      <h2 id="product-modal-title" style="margin-top: 0;">Nuevo producto</h2>
      <form id="product-form" class="form-grid">
        <input type="hidden" name="id" />
        <input type="hidden" name="image_id" />

        <label>
          Nombre
          <input name="name" type="text" maxlength="140" required autocomplete="off" />
        </label>
        <label>
          Slug
          <input name="slug" type="text" maxlength="180" required autocomplete="off" />
        </label>
        <label>
          Categoria
          <select name="category_id" required></select>
        </label>
        <label>
          Precio (€)
          <input name="price" type="number" min="0" step="0.01" required inputmode="decimal" />
        </label>
        <label>
          Precio anterior (€)
          <input name="compare_price" type="number" min="0" step="0.01" inputmode="decimal" />
        </label>
        <label style="grid-column: 1 / -1;">
          Descripcion
          <textarea name="description" rows="3" maxlength="1200"></textarea>
        </label>
        <section id="product-variants-section" class="admin-variants-section" style="grid-column: 1 / -1;">
          <header class="admin-variants-head">
            <div>
              <strong>Variantes</strong>
              <p id="variants-rules-hint" class="admin-variants-hint">Define color, talla y stock según la categoría.</p>
            </div>
            <button id="add-variant-btn" type="button" class="btn secondary">Añadir variante</button>
          </header>
          <div id="product-variants-list" class="admin-variants-list"></div>
        </section>
        <label style="grid-column: 1 / -1;">
          Imagen principal
          <input id="product-image-file" name="image_file" type="file" accept="image/*" />
          <small>Se subirá directamente a Supabase Storage.</small>
        </label>
        <label style="grid-column: 1 / -1;">
          Galería adicional
          <input id="product-image-files" name="image_files" type="file" accept="image/*" multiple />
          <small>Estas imágenes también se guardarán en Storage.</small>
        </label>
        <div class="admin-image-preview-wrap" style="grid-column: 1 / -1;">
          <img id="product-image-preview" class="admin-image-preview" src="/catalogo/placeholder.svg" alt="Vista previa" />
        </div>
        <div class="row admin-check-row" style="grid-column: 1 / -1;">
          <label class="checkbox-line compact">
            <input name="is_active" type="checkbox" checked />
            Activo
          </label>
          <label class="checkbox-line compact">
            <input name="featured" type="checkbox" />
            Destacado
          </label>
        </div>

        <div class="checkout-actions" style="grid-column: 1 / -1;">
          <button type="button" class="btn secondary" id="product-cancel-btn">Cancelar</button>
          <button type="submit" id="product-save-btn">Guardar producto</button>
        </div>
      </form>
      <p id="product-form-feedback" class="alert" style="display: none; margin-top: 0.8rem;"></p>
    </section>
  </dialog>

  <dialog id="category-modal" class="admin-modal" aria-label="Editor de categoria">
    <section class="panel admin-modal-panel">
      <h2 id="category-modal-title" style="margin-top: 0;">Nueva categoria</h2>
      <form id="category-form" class="form-grid">
        <input type="hidden" name="id" />

        <label>
          Nombre
          <input name="name" type="text" maxlength="100" required autocomplete="off" />
        </label>
        <label>
          Slug
          <input name="slug" type="text" maxlength="140" required autocomplete="off" />
        </label>
        <label style="grid-column: 1 / -1;">
          Descripcion
          <textarea name="description" rows="3" maxlength="500"></textarea>
        </label>

        <div class="checkout-actions" style="grid-column: 1 / -1;">
          <button type="button" class="btn secondary" id="category-cancel-btn">Cancelar</button>
          <button type="submit" id="category-save-btn">Guardar categoria</button>
        </div>
      </form>
      <p id="category-form-feedback" class="alert" style="display: none; margin-top: 0.8rem;"></p>
    </section>
  </dialog>

  <dialog id="category-products-modal" class="admin-modal" aria-label="Productos de categoria">
    <section class="panel admin-modal-panel" style="max-width: 900px;">
      <h2 id="category-products-modal-title" style="margin-top: 0;">Gestionar Productos</h2>
      <p id="category-products-subtitle" style="color: var(--muted); margin-top: 0.2rem;"></p>
      
      <div style="margin: 1.5rem 0; border: 1px solid var(--border); padding: 1rem; border-radius: 8px;">
        <h3 style="margin-top: 0; font-size: 1rem;">Añadir producto a esta categoria</h3>
        <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
          <select id="category-add-product-select" style="flex: 1; padding: 0.5rem;">
            <option value="">Selecciona un producto...</option>
          </select>
          <button type="button" id="category-add-product-btn">Añadir</button>
        </div>
      </div>

      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Producto</th>
              <th>Imagenes</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="category-products-list"></tbody>
        </table>
      </div>

      <div class="checkout-actions" style="margin-top: 1rem;">
        <button type="button" class="btn secondary" id="category-products-close-btn">Cerrar</button>
      </div>
    </section>
  </dialog>

  <dialog id="product-images-modal" class="admin-modal" aria-label="Gestion de imagenes de producto">
    <section class="panel admin-modal-panel" style="max-width: 980px;">
      <h2 id="product-images-modal-title" style="margin-top: 0;">Gestionar imagenes</h2>
      <p id="product-images-modal-subtitle" style="color: var(--muted); margin-top: 0.2rem;"></p>

      <div class="form-grid" style="margin-top: 0.8rem;">
        <label>
          Nueva imagen
          <input id="product-images-new-file" type="file" accept="image/*" />
        </label>
        <label>
          ALT
          <input id="product-images-new-alt" type="text" maxlength="200" autocomplete="off" placeholder="Descripcion breve" />
        </label>
        <div class="checkout-actions" style="margin-top: 0; align-items: end;">
          <button type="button" id="product-images-add-btn">Añadir imagen</button>
        </div>
      </div>

      <div class="table-wrap" style="margin-top: 0.9rem;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Vista</th>
              <th>Archivo</th>
              <th>ALT</th>
              <th>Principal</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="product-images-list"></tbody>
        </table>
      </div>

      <p id="product-images-feedback" class="alert" style="display: none; margin-top: 0.7rem;"></p>

      <div class="checkout-actions" style="margin-top: 1rem;">
        <button type="button" class="btn secondary" id="product-images-close-btn">Cerrar</button>
      </div>
    </section>
  </dialog>

  <dialog id="invoice-preview-modal" class="admin-modal" aria-label="Vista previa de factura">
    <section class="panel admin-modal-panel" style="max-width: 1080px;">
      <div class="admin-page-head" style="margin-bottom: 0.8rem;">
        <div>
          <h2 id="invoice-preview-title" style="margin: 0;">Vista previa de factura</h2>
          <p id="invoice-preview-subtitle" style="margin: 0.2rem 0 0; color: var(--muted);"></p>
        </div>
        <button id="invoice-preview-close-btn" type="button" class="btn ghost">Cerrar</button>
      </div>
      <iframe
        id="invoice-preview-frame"
        title="Vista previa PDF factura"
        style="width: 100%; min-height: 72vh; border: 1px solid var(--border); border-radius: 1rem; background: #fff;"
      ></iframe>
    </section>
  </dialog>

  <p id="admin-global-feedback" class="alert" style="display: none; margin-top: 1rem;"></p>

  <!-- jsPDF & jsPDF-AutoTable para facturas -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.1/jspdf.plugin.autotable.min.js"></script>

  <script>
    // @ts-nocheck
    import { createClient } from '@supabase/supabase-js';

    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || '';
    const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
    const PRODUCT_IMAGES_BUCKET = String(import.meta.env.PUBLIC_SUPABASE_PRODUCT_IMAGES_BUCKET || 'product-images').trim() || 'product-images';
    const PRODUCT_IMAGES_BASE_URL = String(import.meta.env.PUBLIC_SUPABASE_PRODUCT_IMAGES_BASE_URL || '').trim();
    const PRODUCT_IMAGE_MAX_MB = Math.max(1, Number(import.meta.env.PUBLIC_PRODUCT_IMAGE_MAX_MB || 8));
    const INVOICE_SERIES = String(import.meta.env.PUBLIC_INVOICE_SERIES || 'ELG').trim().toUpperCase() || 'ELG';
    const INVOICE_VAT_RATE = Math.max(0, Number(import.meta.env.PUBLIC_INVOICE_VAT_RATE || 0.21));
    const COMPANY_LEGAL_NAME = String(import.meta.env.PUBLIC_COMPANY_LEGAL_NAME || 'ELEGILSA').trim() || 'ELEGILSA';
    const COMPANY_TAX_ID = String(import.meta.env.PUBLIC_COMPANY_TAX_ID || 'PENDIENTE').trim() || 'PENDIENTE';
    const COMPANY_ADDRESS = String(import.meta.env.PUBLIC_COMPANY_ADDRESS || 'Direccion fiscal pendiente de configurar').trim() || 'Direccion fiscal pendiente de configurar';
    const COMPANY_CITY = String(import.meta.env.PUBLIC_COMPANY_CITY || 'Espana').trim() || 'Espana';
    const COMPANY_SUPPORT_EMAIL = String(import.meta.env.PUBLIC_COMPANY_SUPPORT_EMAIL || 'soporte@elegilsa.com').trim() || 'soporte@elegilsa.com';
    const COMPANY_WEB = String(import.meta.env.PUBLIC_COMPANY_WEB || 'www.elegilsa.com').trim() || 'www.elegilsa.com';
    const ADMIN_EMAIL_PLACEHOLDERS = new Set(['admin@tudominio.com']);
    const ADMIN_EMAILS = String(import.meta.env.PUBLIC_ADMIN_EMAILS || '')
      .split(',')
      .map((entry) => entry.trim().toLowerCase())
      .filter((entry) => entry && !ADMIN_EMAIL_PLACEHOLDERS.has(entry));

    const ORDERS_KEY = 'elegilsa_orders_v1';
    const INVOICES_KEY = 'elegilsa_invoices_v1';
    const RETURNS_KEY = 'elegilsa_returns_v1';
    const ADMIN_CATALOG_CACHE_KEY = 'elegilsa_admin_catalog_cache_v1';

    const authGate = document.getElementById('admin-auth-gate');
    const authStatus = document.getElementById('admin-auth-status');
    const authFeedback = document.getElementById('admin-auth-feedback');
    const retryBtn = document.getElementById('admin-retry-btn');
    const adminShell = document.getElementById('admin-shell');
    const globalFeedback = document.getElementById('admin-global-feedback');

    const kpiGrid = document.getElementById('kpi-grid');
    const compactSalesMonth = document.getElementById('compact-sales-month');
    const compactSalesCompareMonth = document.getElementById('compact-sales-compare-month');
    const compactSalesViewToggle = document.getElementById('compact-sales-view-toggle');
    const compactSalesGrid = document.getElementById('compact-sales-grid');
    const compactSalesChart = document.getElementById('compact-sales-chart');
    const compactSalesTotal = document.getElementById('compact-sales-total');

    const topProductsTableBody = document.querySelector('#top-products-table tbody');
    const productsTableBody = document.querySelector('#products-table tbody');
    const productsFilterInput = document.getElementById('products-filter');
    const productsPaginationStatus = document.getElementById('products-pagination-status');
    const productsPrevPageBtn = document.getElementById('products-prev-page');
    const productsNextPageBtn = document.getElementById('products-next-page');
    const categoriesTableBody = document.querySelector('#categories-table tbody');
    const ordersTableBody = document.querySelector('#orders-table tbody');
    const usersTableBody = document.querySelector('#users-table tbody');
    const usersFilterInput = document.getElementById('users-filter');
    const invoicesTableBody = document.querySelector('#invoices-table tbody');
    const invoiceCustomerFilterInput = document.getElementById('invoice-customer-filter');

    const productModal = document.getElementById('product-modal');
    const productModalTitle = document.getElementById('product-modal-title');
    const productForm = document.getElementById('product-form');
    const productFormFeedback = document.getElementById('product-form-feedback');
    const productImageFileInput = document.getElementById('product-image-file');
    const productImageFilesInput = document.getElementById('product-image-files');
    const productImagePreview = document.getElementById('product-image-preview');
    const createProductBtn = document.getElementById('create-product-btn');
    const reloadCatalogBtn = document.getElementById('reload-catalog-btn');
    const addVariantBtn = document.getElementById('add-variant-btn');
    const productVariantsList = document.getElementById('product-variants-list');
    const variantsRulesHint = document.getElementById('variants-rules-hint');
    const productCancelBtn = document.getElementById('product-cancel-btn');
    const adminCatalogStatus = document.getElementById('admin-catalog-status');
    const adminProductsDebug = document.getElementById('admin-products-debug');

    const categoryModal = document.getElementById('category-modal');
    const categoryModalTitle = document.getElementById('category-modal-title');
    const categoryForm = document.getElementById('category-form');
    const categoryFormFeedback = document.getElementById('category-form-feedback');
    const createCategoryBtn = document.getElementById('create-category-btn');
    const categoryCancelBtn = document.getElementById('category-cancel-btn');

    const refreshInvoicesBtn = document.getElementById('refresh-invoices-btn');
    const logoutBtn = document.getElementById('admin-logout-btn');
    const productImagesModal = document.getElementById('product-images-modal');
    const productImagesModalTitle = document.getElementById('product-images-modal-title');
    const productImagesModalSubtitle = document.getElementById('product-images-modal-subtitle');
    const productImagesList = document.getElementById('product-images-list');
    const productImagesNewFile = document.getElementById('product-images-new-file');
    const productImagesNewAlt = document.getElementById('product-images-new-alt');
    const productImagesAddBtn = document.getElementById('product-images-add-btn');
    const productImagesCloseBtn = document.getElementById('product-images-close-btn');
    const productImagesFeedback = document.getElementById('product-images-feedback');
    const invoicePreviewModal = document.getElementById('invoice-preview-modal');
    const invoicePreviewTitle = document.getElementById('invoice-preview-title');
    const invoicePreviewSubtitle = document.getElementById('invoice-preview-subtitle');
    const invoicePreviewFrame = document.getElementById('invoice-preview-frame');
    const invoicePreviewCloseBtn = document.getElementById('invoice-preview-close-btn');

