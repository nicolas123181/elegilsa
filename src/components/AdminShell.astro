    function readCatalogCache() {
      try {
        const raw = localStorage.getItem(ADMIN_CATALOG_CACHE_KEY);
        const parsed = raw ? JSON.parse(raw) : null;
        if (!parsed || typeof parsed !== 'object') return null;
        const cachedCategories = Array.isArray(parsed.categories) ? parsed.categories : null;
        const cachedProducts = Array.isArray(parsed.products) ? parsed.products : null;
        if (!cachedCategories || !cachedProducts) return null;
        return {
          categories: cachedCategories,
          products: cachedProducts,
          updatedAt: typeof parsed.updatedAt === 'string' ? parsed.updatedAt : null,
        };
      } catch {
        return null;
      }
    }

    function writeCatalogCache(payload) {
      try {
        localStorage.setItem(
          ADMIN_CATALOG_CACHE_KEY,
          JSON.stringify({
            categories: payload.categories,
            products: payload.products,
            updatedAt: new Date().toISOString(),
          })
        );
      } catch {}
    }

    function parseMaybeJson(value, fallback) {
      if (Array.isArray(value) || (value && typeof value === 'object')) {
        return value;
      }

      if (typeof value !== 'string') {
        return fallback;
      }

      try {
        const parsed = JSON.parse(value);
        return parsed ?? fallback;
      } catch {
        return fallback;
      }
    }

    function normalizeOrderItems(items) {
      const source = Array.isArray(items) ? items : [];
      return source.map((item) => ({
        ...item,
        productId: item?.productId ?? item?.product_id ?? null,
        product_id: item?.product_id ?? item?.productId ?? null,
        name: item?.name ?? item?.product_name ?? 'Producto',
        quantity: Math.max(0, Number(item?.quantity) || 0),
        unitPriceCents: Math.max(
          0,
          Number(item?.unitPriceCents ?? item?.unit_price_cents ?? item?.price_cents ?? 0) || 0
        ),
      }));
    }

    function normalizeOrderRow(row, itemsByOrderId = new Map()) {
      const id = String(row?.id || '').trim();
      if (!id) return null;

      const remoteItems = itemsByOrderId.get(id);
      const embeddedItems = parseMaybeJson(row?.items, []);
      const shipping = parseMaybeJson(row?.shipping ?? row?.shipping_data, {});
      const paymentMethod = row?.payment_method || row?.payment_type || 'stripe';

      return {
        ...row,
        id,
        created_at: row?.created_at || new Date().toISOString(),
        user_id: row?.user_id || row?.customer_id || row?.profile_id || null,
        shipping_method: row?.shipping_method || row?.shipping_type || 'standard',
        payment_method: paymentMethod,
        shipping: shipping && typeof shipping === 'object' ? shipping : {},
        items: normalizeOrderItems(remoteItems && remoteItems.length ? remoteItems : embeddedItems),
        subtotal_cents: Math.max(0, Number(row?.subtotal_cents) || 0),
        shipping_cents: Math.max(0, Number(row?.shipping_cents) || 0),
        total_cents: Math.max(
          0,
          Number(row?.total_cents ?? row?.amount_cents ?? row?.amount_total_cents ?? 0) || 0
        ),
        status: normalizeOrderStatus(row?.status, paymentMethod, row),
      };
    }

    function normalizeInvoiceRow(row) {
      const id = String(row?.id || '').trim();
      const orderId = String(row?.order_id || row?.orderId || '').trim();
      if (!id || !orderId) return null;

      return {
        ...row,
        id,
        order_id: orderId,
        created_at: row?.created_at || new Date().toISOString(),
        total_cents: Math.max(0, Number(row?.total_cents ?? row?.amount_cents ?? 0) || 0),
        customer: row?.customer || row?.customer_name || row?.billing_name || 'Cliente',
        kind: String(row?.kind || row?.invoice_type || 'standard').trim().toLowerCase() || 'standard',
        refund_cents: Math.max(0, Number(row?.refund_cents ?? row?.refund_amount_cents ?? 0) || 0),
        shipping_non_refunded_cents: Math.max(0, Number(row?.shipping_non_refunded_cents ?? row?.shipping_cents ?? 0) || 0),
        original_invoice_id: row?.original_invoice_id || null,
      };
    }

    function mergeRecords(primary, secondary) {
      const merged = new Map();
      for (const record of [...(Array.isArray(primary) ? primary : []), ...(Array.isArray(secondary) ? secondary : [])]) {
        const id = String(record?.id || '').trim();
        if (!id) continue;
        if (merged.has(id)) {
          merged.set(id, { ...merged.get(id), ...record });
          continue;
        }
        merged.set(id, record);
      }
      return [...merged.values()];
    }

    function normalizeReturnRow(row) {
      const orderId = String(row?.order_id || row?.orderId || '').trim();
      if (!orderId) return null;
      const rawStatus = String(row?.status || '').trim().toLowerCase();
      const status = rawStatus === 'accepted' ? 'returned' : rawStatus || 'requested';
      return {
        ...row,
        order_id: orderId,
        status,
        updated_at: row?.updated_at || new Date().toISOString(),
        refund_id: row?.refund_id || row?.refundId || null,
        refund_amount_cents: Math.max(0, Number(row?.refund_amount_cents ?? row?.refund_cents ?? 0) || 0),
        refunded_at: row?.refunded_at || null,
        refund_error: row?.refund_error || null,
        refund_payload: parseMaybeJson(row?.refund_payload, null),
      };
    }

    function mergeReturns(primary, secondary) {
      const merged = new Map();
      for (const entry of [...(Array.isArray(primary) ? primary : []), ...(Array.isArray(secondary) ? secondary : [])]) {
        const normalized = normalizeReturnRow(entry);
        if (!normalized?.order_id) continue;
        const key = normalized.order_id;
        if (!merged.has(key) || +new Date(normalized.updated_at || 0) >= +new Date(merged.get(key).updated_at || 0)) {
          merged.set(key, normalized);
        }
      }
      return [...merged.values()].sort((a, b) => +new Date(b.updated_at || 0) - +new Date(a.updated_at || 0));
    }

    async function syncOrderToSupabase(order) {
      if (!supabase || !order?.id) return;
      try {
        const payload = {
          id: order.id,
          user_id: order.user_id || null,
          created_at: order.created_at || new Date().toISOString(),
          shipping_method: order.shipping_method || null,
          payment_method: order.payment_method || null,
          shipping: order.shipping || {},
          items: Array.isArray(order.items) ? order.items : [],
          subtotal_cents: Math.max(0, Number(order.subtotal_cents) || 0),
          shipping_cents: Math.max(0, Number(order.shipping_cents) || 0),
          total_cents: Math.max(0, Number(order.total_cents) || 0),
          status: normalizeOrderStatus(order.status, order.payment_method, order),
          stripe_session_id: order.stripe_session_id || null,
          stripe_payment_intent_id: order.stripe_payment_intent_id || null,
        };
        await supabase.from('orders').upsert(payload, { onConflict: 'id' });
      } catch {}
    }

    async function syncInvoiceToSupabase(invoice) {
      if (!supabase || !invoice?.id) return;
      const detailedPayload = {
        id: invoice.id,
        order_id: invoice.order_id,
        created_at: invoice.created_at || new Date().toISOString(),
        total_cents: Math.max(0, Number(invoice.total_cents) || 0),
        customer: invoice.customer || 'Cliente',
        kind: invoice.kind || 'standard',
        refund_cents: Math.max(0, Number(invoice.refund_cents) || 0),
        shipping_non_refunded_cents: Math.max(0, Number(invoice.shipping_non_refunded_cents) || 0),
        original_invoice_id: invoice.original_invoice_id || null,
      };

      try {
        const detailed = await supabase.from('invoices').upsert(detailedPayload, { onConflict: 'id' });
        if (!detailed?.error) return;
      } catch {}

      try {
        const fallbackPayload = {
          id: invoice.id,
          order_id: invoice.order_id,
          created_at: invoice.created_at || new Date().toISOString(),
          total_cents: Math.max(0, Number(invoice.total_cents) || 0),
          customer: invoice.customer || 'Cliente',
        };
        await supabase.from('invoices').upsert(fallbackPayload, { onConflict: 'id' });
      } catch {}
    }

    async function syncReturnToSupabase(returnEntry) {
      if (!supabase || !returnEntry?.order_id) return;
      const detailedPayload = {
        order_id: returnEntry.order_id,
        status: returnEntry.status,
        updated_at: returnEntry.updated_at || new Date().toISOString(),
        refund_id: returnEntry.refund_id || null,
        refund_amount_cents: Math.max(0, Number(returnEntry.refund_amount_cents) || 0),
        refunded_at: returnEntry.refunded_at || null,
        refund_error: returnEntry.refund_error || null,
        refund_payload: returnEntry.refund_payload || null,
      };

      try {
        const updated = await supabase
          .from('returns')
          .update(detailedPayload)
          .eq('order_id', returnEntry.order_id)
          .select('order_id')
          .maybeSingle();

        if (!updated?.error && updated?.data) return;
      } catch {}

      try {
        const inserted = await supabase.from('returns').insert(detailedPayload);
        if (!inserted?.error) return;
      } catch {}

      const fallbackPayload = {
        order_id: returnEntry.order_id,
        status: returnEntry.status,
        updated_at: returnEntry.updated_at || new Date().toISOString(),
      };

      try {
        const fallbackUpdated = await supabase
          .from('returns')
          .update(fallbackPayload)
          .eq('order_id', returnEntry.order_id)
          .select('order_id')
          .maybeSingle();

        if (!fallbackUpdated?.error && fallbackUpdated?.data) return;
      } catch {}

      try {
        await supabase.from('returns').insert(fallbackPayload);
      } catch {}
    }

    async function requestStripeRefund(order, refundAmountCents) {
      const response = await fetch('/api/stripe/create-refund', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
        },
        body: JSON.stringify({
          order_id: order.id,
          amount_cents: Math.max(0, Number(refundAmountCents) || 0),
          payment_intent_id: order.stripe_payment_intent_id || null,
          stripe_session_id: order.stripe_session_id || null,
        }),
      });

      let payload = null;
      try {
        payload = await response.json();
      } catch {
        payload = null;
      }

      if (!response.ok) {
        const message = payload?.error || 'No se pudo crear el reembolso en Stripe.';
        throw new Error(message);
      }

      return payload || {};
    }

    function buildDerivedInvoices(orders, explicitInvoices) {
      const existing = new Map();
      const standardInvoicesByOrderId = new Map();
      for (const invoice of explicitInvoices) {
        const normalized = normalizeInvoiceRow(invoice);
        if (!normalized?.id) continue;
        existing.set(normalized.id, normalized);
        if (normalized.kind !== 'rectifying') {
          standardInvoicesByOrderId.set(String(normalized.order_id || ''), normalized);
        }
      }

      for (const order of orders) {
        if (!order?.id || String(order.status || '') === 'cancelled') continue;
        if (standardInvoicesByOrderId.has(String(order.id))) continue;
        const invoice = {
          id: `AUTO-${order.id}`,
          order_id: order.id,
          created_at: order.created_at || new Date().toISOString(),
          total_cents: Number(order.total_cents) || 0,
          customer: order.shipping?.full_name || order.user_id || 'Cliente',
          auto_generated: true,
          kind: 'standard',
          refund_cents: 0,
          shipping_non_refunded_cents: 0,
          original_invoice_id: null,
        };
        existing.set(invoice.id, invoice);
      }

      return [...existing.values()].sort((a, b) => +new Date(b.created_at) - +new Date(a.created_at));
    }

    async function refreshBusinessData() {
      const localOrders = readLocalArray(ORDERS_KEY);
      const localInvoices = readLocalArray(INVOICES_KEY);
      const localReturns = readLocalArray(RETURNS_KEY);

      let remoteOrders = [];
      let remoteInvoices = [];
      let remoteReturns = [];

      try {
        const ordersResult = await supabase.from('orders').select('*').order('created_at', { ascending: false });
        if (!ordersResult.error && Array.isArray(ordersResult.data)) {
          let itemsByOrderId = new Map();
          const itemsResult = await supabase.from('order_items').select('*').order('id', { ascending: true });
          if (!itemsResult.error && Array.isArray(itemsResult.data)) {
            itemsByOrderId = itemsResult.data.reduce((map, item) => {
              const orderId = String(item?.order_id || '').trim();
              if (!orderId) return map;
              if (!map.has(orderId)) map.set(orderId, []);
              map.get(orderId).push(item);
              return map;
            }, new Map());
          }

          remoteOrders = ordersResult.data
            .map((row) => normalizeOrderRow(row, itemsByOrderId))
            .filter(Boolean);
        }
      } catch {}

      try {
        const invoicesResult = await supabase.from('invoices').select('*').order('created_at', { ascending: false });
        if (!invoicesResult.error && Array.isArray(invoicesResult.data)) {
          remoteInvoices = invoicesResult.data.map(normalizeInvoiceRow).filter(Boolean);
        }
      } catch {}

      try {
        const returnsResult = await supabase.from('returns').select('*').order('updated_at', { ascending: false });
        if (!returnsResult.error && Array.isArray(returnsResult.data)) {
          remoteReturns = returnsResult.data.map(normalizeReturnRow).filter(Boolean);
        }
      } catch {}

      adminOrders = sortOrdersByShippingPriority(
        mergeRecords(localOrders, remoteOrders)
          .map((row) => normalizeOrderRow(row))
          .filter(Boolean)
      );
      adminInvoices = buildDerivedInvoices(
        adminOrders,
        mergeRecords(remoteInvoices, localInvoices)
          .map(normalizeInvoiceRow)
          .filter(Boolean)
      );
      adminReturns = mergeReturns(remoteReturns, localReturns);
    }

    function resolveCatalogPathToFallbackUrl(pathLike, slugHint = '') {
      const value = String(pathLike || '').trim();
      if (!value.startsWith('/catalogo/')) return '';
      return value;
    }

    function getProductImagesBaseUrl() {
      if (PRODUCT_IMAGES_BASE_URL) {
        return PRODUCT_IMAGES_BASE_URL.replace(/\/+$/, '');
      }

      if (!SUPABASE_URL) return '';
      return `${SUPABASE_URL.replace(/\/+$/, '')}/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}`;
    }

    function toStorageReference(rawValue) {
      const value = String(rawValue || '').trim();
      if (!value) return '';

      const baseUrl = getProductImagesBaseUrl();
      if (baseUrl && value.startsWith(`${baseUrl}/`)) {
        return `${PRODUCT_IMAGES_BUCKET}/${value.slice(baseUrl.length + 1)}`;
      }

      if (value.includes(`/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}/`)) {
        const [, storagePath = ''] = value.split(`/storage/v1/object/public/${PRODUCT_IMAGES_BUCKET}/`);
        return storagePath ? `${PRODUCT_IMAGES_BUCKET}/${storagePath}` : '';
      }

      if (value.startsWith(`${PRODUCT_IMAGES_BUCKET}/`)) {
        return value;
      }

      return value;
    }

    function resolveImageUrl(rawValue) {
      const value = toStorageReference(rawValue);
      if (!value) return '/catalogo/placeholder.svg';

      if (value.startsWith('/catalogo/')) {
        const fallbackUrl = resolveCatalogPathToFallbackUrl(value);
        return fallbackUrl || '/catalogo/placeholder.svg';
      }

      if (
        value.startsWith('http://') ||
        value.startsWith('https://') ||
        value.startsWith('data:image/') ||
        value.startsWith('blob:')
      ) {
        return value;
      }

      if (value.startsWith('//')) {
        return `https:${value}`;
      }

      if (value.startsWith('storage/v1/object/public/')) {
        if (!SUPABASE_URL) return value;
        return `${SUPABASE_URL.replace(/\/+$/, '')}/${value}`;
      }

      if (value.startsWith('/')) {
        return value;
      }

      if (value.startsWith(`${PRODUCT_IMAGES_BUCKET}/`)) {
        const baseUrl = getProductImagesBaseUrl();
        const storagePath = value.slice(PRODUCT_IMAGES_BUCKET.length + 1);
        return baseUrl ? `${baseUrl}/${storagePath}` : value;
      }

      if (!supabase) return value;
      const storagePath = value.replace(/^\/+/, '');
      const { data } = supabase.storage.from(PRODUCT_IMAGES_BUCKET).getPublicUrl(storagePath);
      return String(data?.publicUrl || value);
    }

    function normalizeExt(file) {
      const fromName = String(file?.name || '').split('.').pop()?.toLowerCase();
      if (fromName && /^[a-z0-9]{2,6}$/.test(fromName)) return fromName;
      const fromType = String(file?.type || '').split('/').pop()?.toLowerCase();
      if (fromType === 'jpeg') return 'jpg';
      if (fromType && /^[a-z0-9]{2,6}$/.test(fromType)) return fromType;
      return 'jpg';
    }

    async function uploadProductImageFile(file, productId) {
      if (!(file instanceof File) || !String(file.type || '').startsWith('image/')) {
        throw new Error('Selecciona un archivo de imagen valido.');
      }

      const maxBytes = PRODUCT_IMAGE_MAX_MB * 1024 * 1024;
      if (Number(file.size) > maxBytes) {
        throw new Error(`La imagen supera ${PRODUCT_IMAGE_MAX_MB}MB.`);
      }

      const safeProductId = String(productId || 'tmp').replace(/[^a-zA-Z0-9_-]/g, '_');
      const ext = normalizeExt(file);
      const randomSuffix = Math.random().toString(36).slice(2, 9);
      const filePath = `${safeProductId}/${Date.now()}-${randomSuffix}.${ext}`;

      const { error: uploadError } = await supabase.storage.from(PRODUCT_IMAGES_BUCKET).upload(filePath, file, {
        cacheControl: '31536000',
        upsert: false,
        contentType: file.type,
      });

      if (uploadError) {
        throw new Error(`No se pudo subir a Storage (${PRODUCT_IMAGES_BUCKET}): ${uploadError.message}`);
      }

      return `${PRODUCT_IMAGES_BUCKET}/${filePath}`;
    }

    function setProductImagePreview(src) {
      if (!(productImagePreview instanceof HTMLImageElement)) return;
      const safeSrc = resolveImageUrl(src);
      productImagePreview.src = safeSrc;
      productImagePreview.onerror = () => {
        productImagePreview.src = '/catalogo/placeholder.svg';
      };
    }

    function readFileAsDataUrl(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ''));
        reader.onerror = () => reject(new Error('No se pudo leer el archivo.'));
        reader.readAsDataURL(file);
      });
    }

    async function prepareProductImageData(file) {
      const rawDataUrl = await readFileAsDataUrl(file);
      if (!rawDataUrl.startsWith('data:image/')) {
        throw new Error('El archivo seleccionado no es una imagen válida.');
      }
      return rawDataUrl;
    }

    function toMonthKey(value) {
      const date = new Date(value);
      if (!Number.isFinite(date.getTime())) return null;
      const month = String(date.getMonth() + 1).padStart(2, '0');
      return `${date.getFullYear()}-${month}`;
    }

    function monthLabel(monthKey) {
      const [year, month] = String(monthKey).split('-').map(Number);
      if (!Number.isFinite(year) || !Number.isFinite(month)) return monthKey;
      const date = new Date(year, month - 1, 1);
      return new Intl.DateTimeFormat('es-ES', { month: 'long', year: 'numeric' }).format(date);
    }

    function getDaysInMonth(monthKey) {
      const [year, month] = String(monthKey).split('-').map(Number);
      if (!Number.isFinite(year) || !Number.isFinite(month)) return 30;
      return new Date(year, month, 0).getDate();
    }

    function getMonthWeekRanges(monthKey) {
      const daysInMonth = getDaysInMonth(monthKey);
      return [
        { key: 'w1', label: 'Semana 1', startDay: 1, endDay: Math.min(7, daysInMonth) },
        { key: 'w2', label: 'Semana 2', startDay: 8, endDay: Math.min(14, daysInMonth) },
        { key: 'w3', label: 'Semana 3', startDay: 15, endDay: Math.min(21, daysInMonth) },
        { key: 'w4', label: 'Semana 4', startDay: 22, endDay: daysInMonth },
      ].filter((entry) => entry.startDay <= entry.endDay);
    }

    function buildMonthlyWeekBuckets(orders, monthKey) {
      const ranges = getMonthWeekRanges(monthKey);
      const buckets = ranges.map((range) => ({ ...range, cents: 0, orders: 0 }));

      for (const order of orders) {
        if (toMonthKey(order.created_at) !== monthKey) continue;
        const day = new Date(order.created_at).getDate();
        const bucket = buckets.find((entry) => day >= entry.startDay && day <= entry.endDay);
        if (!bucket) continue;
        bucket.cents += Number(order.total_cents) || 0;
        bucket.orders += 1;
      }

      return buckets;
    }

    function renderCompactSalesChart(monthSeries) {
      if (!compactSalesChart) return;
      if (!Array.isArray(monthSeries) || monthSeries.length === 0) {
        compactSalesChart.innerHTML = '<p class="search-state">Selecciona al menos un mes para ver el grafico.</p>';
        return;
      }

      const palette = ['#b48a67', '#3f7e77', '#d27c57', '#556b9a'];
      const maxValue = Math.max(
        1,
        ...monthSeries.flatMap((series) => series.buckets.map((bucket) => bucket.cents))
      );

      const weekCount = Math.max(...monthSeries.map((series) => series.buckets.length), 0);
      const groups = Array.from({ length: weekCount }, (_, index) => ({
        index,
        label: `Semana ${index + 1}`,
        bars: monthSeries.map((series, seriesIndex) => ({
          label: monthLabel(series.monthKey),
          color: palette[seriesIndex % palette.length],
          bucket: series.buckets[index] || { cents: 0, orders: 0, startDay: 0, endDay: 0 },
        })),
      }));

      const legend = monthSeries
        .map((series, index) => `<span class="compact-sales-legend-item"><i style="background:${palette[index % palette.length]}"></i>${monthLabel(series.monthKey)}</span>`)
        .join('');

      const groupsHtml = groups
        .map((group) => {
          const barsHtml = group.bars
            .map((bar) => {
              const hasValue = bar.bucket.cents > 0;
              const ratio = hasValue ? bar.bucket.cents / maxValue : 0;
              const height = hasValue
                ? Math.max(18, Math.round(18 + ratio * 82))
                : 6;
              const rangeText = bar.bucket.startDay && bar.bucket.endDay ? `${bar.bucket.startDay}-${bar.bucket.endDay}` : '';
              return `
                <div class="compact-sales-bar-wrap">
                  <div class="compact-sales-bar ${hasValue ? 'has-value' : 'is-empty'}" style="height:${height}%; background:${bar.color};" title="${escapeHtml(`${bar.label} · ${group.label} (${rangeText}) · ${formatMoney(bar.bucket.cents)} · ${bar.bucket.orders} pedido(s)`) }"></div>
                  <small>${formatMoney(bar.bucket.cents)}</small>
                </div>
              `;
            })
            .join('');

          return `
            <article class="compact-sales-chart-group">
              <div class="compact-sales-bars">${barsHtml}</div>
              <strong>${group.label}</strong>
            </article>
          `;
        })
        .join('');

      compactSalesChart.innerHTML = `
        <div class="compact-sales-legend">${legend}</div>
        <div class="compact-sales-chart-grid">${groupsHtml}</div>
      `;
    }

    function updateCompactSalesSummary(orders) {
      if (!compactSalesMonth || !compactSalesGrid || !compactSalesTotal || !compactSalesCompareMonth || !compactSalesChart) return;

      const validOrders = (orders || []).filter((order) => order.status !== 'cancelled');
      const monthSet = new Set();
      monthSet.add(toMonthKey(new Date().toISOString()));
      for (const order of validOrders) {
        const key = toMonthKey(order.created_at);
        if (key) monthSet.add(key);
      }

      const monthOptions = [...monthSet].filter(Boolean).sort((a, b) => b.localeCompare(a));
      if (monthOptions.length === 0) {
        compactSalesMonth.innerHTML = '';
        compactSalesGrid.innerHTML = '<p class="search-state">Sin datos de ventas para mostrar.</p>';
        compactSalesTotal.textContent = '';
        return;
      }

      if (!selectedCompactSalesMonth || !monthOptions.includes(selectedCompactSalesMonth)) {
        selectedCompactSalesMonth = monthOptions[0];
      }

      compactSalesMonth.innerHTML = monthOptions
        .map((monthKey) => `<option value="${monthKey}" ${monthKey === selectedCompactSalesMonth ? 'selected' : ''}>${monthLabel(monthKey)}</option>`)
        .join('');

      if (
        selectedCompactSalesCompareMonth &&
        (
          selectedCompactSalesCompareMonth === selectedCompactSalesMonth ||
          !monthOptions.includes(selectedCompactSalesCompareMonth)
        )
      ) {
        selectedCompactSalesCompareMonth = '';
      }
      compactSalesCompareMonth.innerHTML = [
        '<option value="">Sin comparativa</option>',
        ...monthOptions
          .filter((monthKey) => monthKey !== selectedCompactSalesMonth)
          .map((monthKey) => `<option value="${monthKey}" ${selectedCompactSalesCompareMonth === monthKey ? 'selected' : ''}>${monthLabel(monthKey)}</option>`)
      ].join('');

      const monthKey = selectedCompactSalesMonth;
      const buckets = buildMonthlyWeekBuckets(validOrders, monthKey);
      const maxValue = Math.max(...buckets.map((entry) => entry.cents), 1);
      const totalCents = buckets.reduce((acc, entry) => acc + entry.cents, 0);
      const compareMonths = selectedCompactSalesCompareMonth ? [monthKey, selectedCompactSalesCompareMonth] : [monthKey];
      const chartSeries = compareMonths.map((entry) => ({
        monthKey: entry,
        buckets: buildMonthlyWeekBuckets(validOrders, entry),
      }));

      compactSalesGrid.innerHTML = buckets
        .map((entry) => {
          const width = Math.max(14, Math.round((entry.cents / maxValue) * 100));
          return `
            <article class="compact-sales-card">
              <p>${entry.label}</p>
              <strong>${formatMoney(entry.cents)}</strong>
              <small>${entry.orders} pedido(s) · días ${entry.startDay}-${entry.endDay}</small>
              <div class="compact-sales-progress"><span style="width:${width}%"></span></div>
            </article>
          `;
        })
        .join('');

      renderCompactSalesChart(chartSeries);
      const effectiveView = selectedCompactSalesCompareMonth ? 'chart' : compactSalesView;
      compactSalesGrid.style.display = effectiveView === 'summary' ? '' : 'none';
      compactSalesChart.style.display = effectiveView === 'chart' ? '' : 'none';
      compactSalesTotal.textContent = `Total ${monthLabel(monthKey)}: ${formatMoney(totalCents)}`;
    }

    function isAdminEmail(email) {
      if (!email) return false;
      if (ADMIN_EMAILS.length === 0) return true;
      return ADMIN_EMAILS.includes(String(email).trim().toLowerCase());
    }

    function forceShowPanel(tab) {
      const safeTab = Object.prototype.hasOwnProperty.call(panels, tab) ? tab : 'dashboard';
      const keys = Object.keys(panels);

      for (const key of keys) {
        const panelEl = document.getElementById(`admin-panel-${key}`);
        if (!(panelEl instanceof HTMLElement)) continue;
        panelEl.style.display = key === safeTab ? 'block' : 'none';
      }

      return safeTab;
    }

    function getInitialAdminTab() {
      const fromHash = String(window.location.hash || '').replace(/^#/, '').trim().toLowerCase();
      if (Object.prototype.hasOwnProperty.call(panels, fromHash)) {
        return fromHash;
      }

      const pathSegments = window.location.pathname
        .split('/')
        .map((entry) => entry.trim().toLowerCase())
        .filter(Boolean);

      if (pathSegments.length >= 2 && pathSegments[0] === 'admin') {
        const fromPath = pathSegments[1];
        if (Object.prototype.hasOwnProperty.call(panels, fromPath)) {
          return fromPath;
        }
      }

      return 'dashboard';
    }

    function syncAdminRoute(tab) {
      const safeTab = Object.prototype.hasOwnProperty.call(ADMIN_TAB_ROUTES, tab) ? tab : 'products';
      const route = ADMIN_TAB_ROUTES[safeTab] || '/admin/products';
      if (`${window.location.pathname}${window.location.search}` === route) return;
      window.history.replaceState({}, '', route);
    }

    function setTab(tab, options = {}) {
      const safeTab = forceShowPanel(tab);
      activeAdminTab = safeTab;
      if (!options?.skipRouteSync) {
        syncAdminRoute(safeTab);
      }

      tabs.forEach((entry) => {
        const isActive = entry.getAttribute('data-tab') === safeTab;
        entry.classList.toggle('active', isActive);
      });

      if (currentUser) {
        renderActiveAdminTab(safeTab);
      }
    }

    function getCategoryName(categoryId) {
      const match = categories.find((entry) => Number(entry.id) === Number(categoryId));
      return match ? match.name : 'Sin categoria';
    }

    function normalizeTextToken(value) {
      return String(value || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function getCategoryVariantMode(categoryId) {
      const category = categories.find((entry) => Number(entry.id) === Number(categoryId));
      const token = normalizeTextToken(`${category?.slug || ''} ${category?.name || ''}`);

      if (/calzado|zapat|sandali|bota|cuña|cuna/.test(token)) return 'footwear';
      if (/complement|accesor|bolso|cinturon|bisuter|joya|sombrer|gorr|cartera/.test(token)) return 'accessory';
      return 'apparel';
    }

    function getVariantRules(categoryId) {
      const mode = getCategoryVariantMode(categoryId);

      if (mode === 'footwear') {
        return {
          colorRequired: false,
          colorVisible: true,
          sizeVisible: true,
          sizeRequired: true,
          sizeLabel: 'Talla del calzado',
          hint: 'Calzado: talla obligatoria y color opcional.',
        };
      }

      if (mode === 'accessory') {
        return {
          colorRequired: false,
          colorVisible: true,
          sizeVisible: false,
          sizeRequired: false,
          sizeLabel: 'Talla',
          hint: 'Complementos: color opcional y sin talla obligatoria.',
        };
      }

      return {
        colorRequired: true,
        colorVisible: true,
        sizeVisible: true,
        sizeRequired: true,
        sizeLabel: 'Talla',
        hint: 'Ropa: color y talla obligatorios.',
      };
    }

    function parseVariantMeta(raw) {
      const value = String(raw || '').trim();
      if (!value) {
        return { colorHex: '', imageId: '' };
      }

      let colorHex = '';
      let imageId = '';
      const parts = value.split('|').map((part) => part.trim()).filter(Boolean);

      for (const part of parts) {
        const imageMatch = part.match(/^img:(\d+)$/i);
        if (imageMatch) {
          imageId = imageMatch[1];
          continue;
        }

        if (/^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(part)) {
          colorHex = part;
        }
      }

      if (!colorHex && /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(value)) {
        colorHex = value;
      }

      return { colorHex, imageId };
    }

    function serializeVariantMeta(colorHex, imageId) {
      const safeHex = /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(String(colorHex || '').trim())
        ? String(colorHex || '').trim()
        : '';
      const safeImageId = /^\d+$/.test(String(imageId || '').trim())
        ? String(imageId || '').trim()
        : '';

      if (safeHex && safeImageId) return `${safeHex}|img:${safeImageId}`;
      if (safeHex) return safeHex;
      if (safeImageId) return `img:${safeImageId}`;
      return null;
    }

    function getVariantImageOptions(productId) {
      const product = products.find((entry) => String(entry.id) === String(productId));
      const sorted = getSortedImages(product);
      return sorted.map((image, index) => ({
        id: String(image.id),
        label: `${index === 0 ? 'Principal' : `Imagen ${index + 1}`} · ${String(image.alt_text || '').trim() || `#${image.id}`}`,
      }));
    }

    function createVariantRow(variant = {}, options = {}) {
      const rules = options.rules || getVariantRules(productForm?.elements?.namedItem('category_id')?.value);
      const imageOptions = Array.isArray(options.imageOptions) ? options.imageOptions : [];
      const meta = parseVariantMeta(variant?.color_hex);

      const row = document.createElement('article');
      row.className = 'admin-variant-row';
      row.dataset.variantId = String(variant?.id || '').trim();

      const imageSelectOptions = ['<option value="">Auto por color / principal</option>']
        .concat(imageOptions.map((entry) => `<option value="${escapeHtml(entry.id)}">${escapeHtml(entry.label)}</option>`))
        .join('');

      row.innerHTML = `
        <div class="admin-variant-grid">
          <label>
            Nombre opcional
            <input type="text" data-field="name" maxlength="100" value="${escapeHtml(variant?.name || '')}" placeholder="Principal" />
          </label>
          <label data-role="color-wrap">
            <span class="admin-variant-color-label">Color</span>
            <input type="text" data-field="color_name" maxlength="80" value="${escapeHtml(variant?.color_name || '')}" placeholder="Azul" />
          </label>
          <label data-role="size-wrap">
            <span class="admin-variant-size-label">${escapeHtml(rules.sizeLabel || 'Talla')}</span>
            <input type="text" data-field="size_label" maxlength="60" value="${escapeHtml(variant?.size_label || '')}" placeholder="M" />
          </label>
          <label>
            Precio variante (€)
            <input type="number" min="0" step="0.01" inputmode="decimal" data-field="price" value="${variant?.price_cents != null ? escapeHtml(String((Number(variant.price_cents) || 0) / 100)) : ''}" placeholder="Usar precio general" />
          </label>
          <label>
            Stock
            <input type="number" min="0" step="1" inputmode="numeric" data-field="stock" value="${escapeHtml(String(Math.max(0, Number(variant?.stock) || 0)))}" required />
          </label>
          <label>
            Imagen variante
            <select data-field="image_id">${imageSelectOptions}</select>
          </label>
          <label>
            Hex (opcional)
            <input type="text" data-field="color_hex" maxlength="7" value="${escapeHtml(meta.colorHex)}" placeholder="#1f4fff" />
          </label>
          <label class="checkbox-line compact">
            <input type="checkbox" data-field="is_active" ${variant?.is_active === false ? '' : 'checked'} />
            Activa
          </label>
          <div class="admin-variant-row-actions">
            <button type="button" class="btn secondary" data-action="remove-variant-row">Quitar</button>
          </div>
        </div>
      `;

      const imageSelect = row.querySelector('select[data-field="image_id"]');
      if (imageSelect instanceof HTMLSelectElement) {
        imageSelect.value = meta.imageId || '';
      }

      return row;
    }

    function applyVariantRulesToRows() {
      if (!(productVariantsList instanceof HTMLElement)) return;

      const rules = getVariantRules(productForm?.elements?.namedItem('category_id')?.value);
      if (variantsRulesHint) {
        variantsRulesHint.textContent = rules.hint;
      }

      const rows = Array.from(productVariantsList.querySelectorAll('.admin-variant-row'));
      for (const row of rows) {
        const colorWrap = row.querySelector('[data-role="color-wrap"]');
        const colorLabel = row.querySelector('.admin-variant-color-label');
        const colorInput = row.querySelector('input[data-field="color_name"]');
        const sizeLabel = row.querySelector('.admin-variant-size-label');
        const sizeInput = row.querySelector('input[data-field="size_label"]');

        if (colorWrap instanceof HTMLElement) {
          colorWrap.style.display = rules.colorVisible ? '' : 'none';
        }
        if (colorLabel instanceof HTMLElement) {
          colorLabel.textContent = rules.colorRequired ? 'Color *' : 'Color';
        }
        if (colorInput instanceof HTMLInputElement) {
          colorInput.required = Boolean(rules.colorRequired);
        }

        if (sizeLabel instanceof HTMLElement) {
          sizeLabel.textContent = rules.sizeRequired ? `${rules.sizeLabel} *` : rules.sizeLabel;
        }
        const sizeWrap = row.querySelector('[data-role="size-wrap"]');
        if (sizeWrap instanceof HTMLElement) {
          sizeWrap.style.display = rules.sizeVisible ? '' : 'none';
        }
        if (sizeInput instanceof HTMLInputElement) {
          sizeInput.placeholder = rules.sizeLabel.toLowerCase().includes('calzado') ? '38' : 'M';
          sizeInput.required = Boolean(rules.sizeRequired);
          if (!rules.sizeVisible) {
            sizeInput.value = '';
          }
        }
      }
    }

    function renderVariantRows(variants = [], productId = '') {
      if (!(productVariantsList instanceof HTMLElement)) return;

      const rows = Array.isArray(variants) ? variants : [];
      const rules = getVariantRules(productForm?.elements?.namedItem('category_id')?.value);
      const imageOptions = getVariantImageOptions(productId);

      productVariantsList.innerHTML = '';

      const initialRows = rows.length > 0
        ? rows
        : [{ id: '', name: 'Principal', color_name: '', color_hex: '', size_label: '', price_cents: null, stock: 0, is_active: true, position: 1 }];

      initialRows
        .slice()
        .sort((a, b) => (Number(a?.position) || 0) - (Number(b?.position) || 0))
        .forEach((variant) => {
          productVariantsList.appendChild(createVariantRow(variant, { rules, imageOptions }));
        });

      applyVariantRulesToRows();
    }

    function readVariantRowsFromForm() {
      if (!(productVariantsList instanceof HTMLElement)) return [];

      const rows = Array.from(productVariantsList.querySelectorAll('.admin-variant-row'));
      return rows.map((row, index) => {
        const id = String(row.dataset.variantId || '').trim();
        const name = String(row.querySelector('input[data-field="name"]')?.value || '').trim();
        const colorName = String(row.querySelector('input[data-field="color_name"]')?.value || '').trim();
        const sizeLabel = String(row.querySelector('input[data-field="size_label"]')?.value || '').trim();
        const priceRaw = String(row.querySelector('input[data-field="price"]')?.value || '').trim();
        const stock = Math.max(0, Math.round(Number(row.querySelector('input[data-field="stock"]')?.value || 0)));
        const isActive = Boolean(row.querySelector('input[data-field="is_active"]')?.checked);
        const imageId = String(row.querySelector('select[data-field="image_id"]')?.value || '').trim();
        const colorHex = String(row.querySelector('input[data-field="color_hex"]')?.value || '').trim();

        return {
          id,
          name: name || 'Principal',
          color_name: colorName || null,
          color_hex: serializeVariantMeta(colorHex, imageId),
          size_label: sizeLabel || null,
          price_cents: priceRaw ? euroToCents(priceRaw) : null,
          stock,
          is_active: isActive,
          position: index + 1,
        };
      });
    }

    function getPrimaryVariant(product) {
      const variants = Array.isArray(product.product_variants) ? product.product_variants : [];
      return variants.find((variant) => variant.is_active) || variants[0] || null;
    }

    function getPrimaryImageUrl(product) {
      const sorted = getSortedImages(product);
      return sorted[0]?.url || '/catalogo/placeholder.svg';
    }

    function getSortedImages(product) {
      const images = Array.isArray(product?.product_images) ? product.product_images : [];
      return [...images].sort((a, b) => (a.position || 0) - (b.position || 0));
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getInvoiceOrder(invoice) {
      return adminOrders.find((entry) => String(entry?.id || '') === String(invoice?.order_id || '')) || null;
    }

    function getInvoiceCustomerName(invoice, order = null) {
      return String(
        order?.shipping?.full_name ||
        invoice?.customer ||
        order?.user_id ||
        'Cliente'
      ).trim() || 'Cliente';
    }

    function getProductVisualRows() {
      return products
        .map((product, index) => ({
          ...product,
          displayId: index + 1,
          category_name: getCategoryName(product.category_id),
        }));
    }

    function clampProductsPage(totalItems) {
      const totalPages = Math.max(1, Math.ceil(totalItems / PRODUCTS_PER_PAGE));
      productsPage = Math.min(Math.max(productsPage, 1), totalPages);
      return totalPages;
    }

    function getOrderItemImageUrl(item) {
      const productId = String(item?.productId ?? item?.product_id ?? '').trim();
      let product = productId
        ? products.find((entry) => String(entry?.id || '').trim() === productId)
        : null;

      if (!product) {
        const itemName = String(item?.name || '').trim().toLowerCase();
        if (itemName) {
          product = products.find((entry) => String(entry?.name || '').trim().toLowerCase() === itemName);
        }
      }

      if (!product) return '';
      const raw = getPrimaryImageUrl(product);
      const resolved = resolveImageUrl(raw);
      return resolved.includes('/catalogo/placeholder.svg') ? '' : resolved;
    }

    function loadImageThumbnailDataUrl(url, options = {}) {
      const src = String(url || '').trim();
      if (!src || src.endsWith('.svg') || src.includes('/catalogo/placeholder.svg')) {
        return Promise.resolve(null);
      }

      if (invoiceImageDataCache.has(src)) {
        return invoiceImageDataCache.get(src);
      }

      const maxWidth = Math.max(24, Number(options.maxWidth) || 72);
      const maxHeight = Math.max(24, Number(options.maxHeight) || 72);
      const quality = Math.min(0.92, Math.max(0.45, Number(options.quality) || 0.76));
      const timeoutMs = Math.max(800, Number(options.timeoutMs) || 2500);

      const pending = new Promise((resolve) => {
        const image = new Image();
        let settled = false;

        const finish = (result) => {
          if (settled) return;
          settled = true;
          window.clearTimeout(timer);
          resolve(result);
        };

        const timer = window.setTimeout(() => finish(null), timeoutMs);

        image.crossOrigin = 'anonymous';
        image.decoding = 'async';
        image.onload = () => {
          try {
            const width = Math.max(1, Number(image.naturalWidth) || 1);
            const height = Math.max(1, Number(image.naturalHeight) || 1);
            const ratio = Math.min(maxWidth / width, maxHeight / height, 1);
            const canvas = document.createElement('canvas');
            canvas.width = Math.max(1, Math.round(width * ratio));
            canvas.height = Math.max(1, Math.round(height * ratio));
            const context = canvas.getContext('2d', { alpha: false });
            if (!context) {
              finish(null);
              return;
            }

            context.fillStyle = '#ffffff';
            context.fillRect(0, 0, canvas.width, canvas.height);
            context.drawImage(image, 0, 0, canvas.width, canvas.height);
            finish(canvas.toDataURL('image/jpeg', quality));
          } catch {
            finish(null);
          }
        };
        image.onerror = () => finish(null);
        image.src = src;
      });

      invoiceImageDataCache.set(src, pending);
      return pending;
    }

