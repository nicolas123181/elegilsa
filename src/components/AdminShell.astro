    async function deleteCategory(categoryId) {
      const linkedProducts = products.some((product) => Number(product.category_id) === Number(categoryId));
      if (linkedProducts) {
        showGlobal('danger', 'No puedes borrar una categoria que tiene productos asociados.');
        return;
      }

      const { error } = await supabase.from('categories').delete().eq('id', categoryId);
      if (error) {
        showGlobal('danger', `No se pudo borrar la categoria: ${error.message}`);
        return;
      }

      await refreshAll();
      showGlobal('ok', 'Categoria eliminada.');
    }

    async function updateOrderStatus(orderId, status, options = {}) {
      const normalizedStatus = normalizeOrderStatus(status, 'stripe');
      if (normalizedStatus !== 'returned') {
        showGlobal('danger', 'Los pedidos pagados solo pueden cambiarse manualmente a Devuelto.');
        renderOrdersTable();
        return;
      }

      const order = adminOrders.find((entry) => entry.id === orderId);
      if (!order) {
        showGlobal('danger', `No se encontro el pedido ${orderId}.`);
        renderOrdersTable();
        return;
      }

      const existingReturn = adminReturns.find((entry) => entry.order_id === orderId) || null;
      let returnPatch = {};

      const paymentMethod = String(order.payment_method || '').trim().toLowerCase();
      const refundCents = getReturnRefundCents(order);
      const hasExistingRefund =
        Boolean(existingReturn?.refund_id) ||
        Math.max(0, Number(existingReturn?.refund_amount_cents) || 0) > 0;

      if (!options?.skipStripeRefund && paymentMethod === 'stripe') {
        if (refundCents <= 0) {
          showGlobal('danger', 'No se pudo calcular un importe de reembolso válido para este pedido.');
          renderOrdersTable();
          return;
        }

        if (!order.stripe_payment_intent_id && !order.stripe_session_id) {
          showGlobal('danger', 'Falta el identificador de cobro Stripe. No se puede ejecutar el reembolso automático.');
          renderOrdersTable();
          return;
        }

        if (!hasExistingRefund) {
          try {
            const refundResult = await requestStripeRefund(order, refundCents);
            returnPatch = {
              refund_id: refundResult?.refundId || null,
              refund_amount_cents: Math.max(0, Number(refundResult?.amountCents ?? refundCents) || 0),
              refunded_at: new Date().toISOString(),
              refund_error: null,
              refund_payload: refundResult,
            };
          } catch (error) {
            const reason = error instanceof Error ? error.message : 'Stripe rechazó el reembolso.';
            showGlobal('danger', `No se pudo marcar como devuelto: ${reason}`);
            renderOrdersTable();
            return;
          }
        } else {
          returnPatch = {
            refund_id: existingReturn?.refund_id || null,
            refund_amount_cents: Math.max(0, Number(existingReturn?.refund_amount_cents ?? refundCents) || 0),
            refunded_at: existingReturn?.refunded_at || new Date().toISOString(),
            refund_error: existingReturn?.refund_error || null,
            refund_payload: existingReturn?.refund_payload || null,
          };
        }
      }

      const orders = readLocalArray(ORDERS_KEY);
      const next = orders.map((order) => (order.id === orderId ? { ...order, status: 'returned' } : order));
      writeLocalArray(ORDERS_KEY, next);
      adminOrders = sortOrdersByShippingPriority(
        adminOrders.map((order) => (order.id === orderId ? { ...order, status: 'returned' } : order))
      );
      await syncOrderToSupabase(order);
      const rectifyingInvoice = ensureRectifyingInvoice(order);
      await syncInvoiceToSupabase(rectifyingInvoice);

      if (!returnPatch.refund_amount_cents && refundCents > 0) {
        returnPatch.refund_amount_cents = refundCents;
      }

      await updateReturnStatus(orderId, 'returned', { skipOrderStatusSync: true, patch: returnPatch });
      await refreshBusinessData();
      renderDashboard();
      renderOrdersTable();
      renderUsersTable();
      renderInvoicesTable();
      const refundedLabel = returnPatch.refund_amount_cents
        ? ` Reembolso aplicado: ${formatMoney(returnPatch.refund_amount_cents)}.`
        : '';
      showGlobal('ok', `Pedido ${orderId} marcado como devuelto y factura rectificativa generada.${refundedLabel}`);
    }

    async function updateReturnStatus(orderId, status, options = {}) {
      const returns = readLocalArray(RETURNS_KEY);
      const index = returns.findIndex((entry) => entry.order_id === orderId);
      const normalizedStatus = status === 'accepted' ? 'returned' : status;
      const patch = options?.patch && typeof options.patch === 'object' ? options.patch : {};
      let persistedEntry = null;
      if (index === -1) {
        persistedEntry = { order_id: orderId, ...patch, status: normalizedStatus, updated_at: new Date().toISOString() };
        returns.unshift(persistedEntry);
      } else {
        persistedEntry = { ...returns[index], ...patch, status: normalizedStatus, updated_at: new Date().toISOString() };
        returns[index] = persistedEntry;
      }
      writeLocalArray(RETURNS_KEY, returns);
      await syncReturnToSupabase(persistedEntry);
      if (normalizedStatus === 'returned' && !options?.skipOrderStatusSync) {
        await updateOrderStatus(orderId, 'returned');
        return;
      }
      adminReturns = mergeReturns(adminReturns, [persistedEntry]);
      renderDashboard();
      renderOrdersTable();
    }

    async function requestReturn(orderId) {
      const returns = readLocalArray(RETURNS_KEY);
      if (returns.some((entry) => entry.order_id === orderId)) {
        showGlobal('danger', 'Ese pedido ya tiene una devolucion registrada.');
        return;
      }

      const returnEntry = { order_id: orderId, status: 'requested', updated_at: new Date().toISOString() };
      returns.unshift(returnEntry);
      writeLocalArray(RETURNS_KEY, returns);
      await syncReturnToSupabase(returnEntry);
      adminReturns = mergeReturns(adminReturns, [returnEntry]);
      renderDashboard();
      renderOrdersTable();
      showGlobal('ok', 'Solicitud de devolucion registrada.');
    }

    async function createInvoiceFromOrder(orderId) {
      const order = adminOrders.find((entry) => entry.id === orderId);
      if (!order) {
        showGlobal('danger', 'No se encontro el pedido para facturar.');
        return;
      }

      const invoice = ensureInvoice(order);
      await syncInvoiceToSupabase(invoice);
      await refreshBusinessData();
      renderInvoicesTable();
      showGlobal('ok', `Factura ${invoice.id} generada para ${order.id}.`);
    }

    function setInvoiceActionButtonState(triggerButton, isBusy, labelWhenBusy = 'Preparando...') {
      if (!(triggerButton instanceof HTMLButtonElement)) return () => {};
      const originalLabel = triggerButton.textContent || '';
      triggerButton.disabled = isBusy;
      triggerButton.textContent = isBusy ? labelWhenBusy : originalLabel;
      return () => {
        triggerButton.disabled = false;
        triggerButton.textContent = originalLabel;
      };
    }

    async function buildInvoicePdf(invoiceId) {
      const invoices = adminInvoices;
      const orders = adminOrders;
      const invoice = invoices.find((entry) => entry.id === invoiceId);
      if (!invoice) {
        throw new Error('Factura no encontrada.');
      }

      const order = orders.find((entry) => entry.id === invoice.order_id);
      const isRectifying = String(invoice?.kind || 'standard') === 'rectifying';
      const refundCents = Math.max(0, Number(invoice?.refund_cents ?? getReturnRefundCents(order)) || 0);
      const invoiceTotalCents = isRectifying
        ? refundCents
        : Math.max(0, Number(invoice?.total_cents ?? order?.total_cents) || 0);
      const shippingCost = Math.max(0, Number(order?.shipping_cents) || 0);
      const fiscalNumber = toFiscalNumber(invoice);
      const vatBaseCents = Math.round(invoiceTotalCents / (1 + INVOICE_VAT_RATE));
      const vatAmountCents = Math.max(0, invoiceTotalCents - vatBaseCents);
      const customerTaxId = String(order?.shipping?.tax_id || order?.shipping?.nif || order?.shipping?.dni || '').trim() || 'N/D';
      const customerName = getInvoiceCustomerName(invoice, order);

      if (!window.jspdf?.jsPDF) {
        throw new Error('La libreria de PDF no esta disponible.');
      }

      const { jsPDF } = window.jspdf;
      const doc = new jsPDF({ unit: 'mm', format: 'a4' });

      const brandColor = [126, 95, 75];
      const softBrand = [244, 238, 233];

      doc.setFillColor(brandColor[0], brandColor[1], brandColor[2]);
      doc.rect(0, 0, 210, 36, 'F');
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(24);
      doc.text(COMPANY_LEGAL_NAME, 14, 16);
      doc.setFontSize(10);
      doc.text('Moda femenina y complementos', 14, 22);
      doc.text(COMPANY_WEB, 14, 27);

      doc.setFontSize(18);
      doc.text(isRectifying ? 'FACTURA RECTIFICATIVA' : 'FACTURA', isRectifying ? 112 : 152, 16);
      doc.setFontSize(9);
      doc.text(`Serie/N: ${fiscalNumber}`, 132, 22);
      doc.text(`Emision: ${formatDate(invoice.created_at)}`, 132, 27);
      doc.text(`Pedido: ${invoice.order_id}`, 132, 32);

      doc.setFillColor(softBrand[0], softBrand[1], softBrand[2]);
      doc.roundedRect(14, 42, 88, 48, 2, 2, 'F');
      doc.roundedRect(108, 42, 88, 48, 2, 2, 'F');
      doc.setTextColor(50, 50, 50);
      doc.setFontSize(10);
      doc.text('Emisor', 18, 49);
      doc.setFontSize(11);
      doc.text(COMPANY_LEGAL_NAME, 18, 55);
      doc.setFontSize(9);
      doc.text(`NIF/CIF: ${COMPANY_TAX_ID}`, 18, 60);
      doc.text(COMPANY_ADDRESS, 18, 65, { maxWidth: 80 });
      doc.text(COMPANY_CITY, 18, 71);
      doc.text(COMPANY_SUPPORT_EMAIL, 18, 76);

      doc.setFontSize(10);
      doc.setTextColor(50, 50, 50);
      doc.text('Cliente / Receptor', 112, 49);
      doc.setFontSize(11);
      doc.text(customerName, 112, 55);
      doc.setFontSize(9);
      doc.text(`NIF/DNI: ${customerTaxId}`, 112, 60);
      doc.text(order?.shipping?.shipping_address || '', 112, 65, { maxWidth: 80 });
      doc.text(`${order?.shipping?.shipping_postal_code || ''} ${order?.shipping?.shipping_city || ''}`.trim(), 112, 71);
      doc.text(order?.shipping?.shipping_country || '', 112, 76);

      doc.setFontSize(9);
      doc.setTextColor(80, 80, 80);
      doc.text(`Envio: ${getShippingLabel(order).title}`, 14, 97);
      doc.text(`Pago: ${String(order?.payment_method || 'stripe').toUpperCase()}`, 62, 97);
      doc.text(`Estado: ${String(order?.status || 'pending').toUpperCase()}`, 104, 97);
      doc.text(`IVA aplicado: ${formatPercent(INVOICE_VAT_RATE)}`, 152, 97);
      if (isRectifying) {
        doc.setFontSize(8.5);
        doc.setTextColor(140, 84, 54);
        doc.text(`Rectificativa de ${invoice.original_invoice_id || 'factura original'} · El envio no se devuelve.`, 14, 102);
      }

      const items = Array.isArray(order?.items) ? order.items : [];
      const imageUrls = items.map((item) => getOrderItemImageUrl(item));
      const imageDataList = await Promise.all(
        imageUrls.map((url) => loadImageThumbnailDataUrl(url, { maxWidth: 68, maxHeight: 68, timeoutMs: 1800 }))
      );

      const tableData = [];
      let subtotal = 0;

      for (const [index, item] of items.entries()) {
        const qty = Number(item.quantity) || 0;
        const unit = Number(item.unitPriceCents) || 0;
        const lineTotal = unit * qty;
        subtotal += lineTotal;

        tableData.push([
          { content: item.name || `Producto ${index + 1}`, imageData: imageDataList[index] || null },
          isRectifying ? `-${qty}` : qty.toString(),
          isRectifying ? formatMoney(-unit) : formatMoney(unit),
          isRectifying ? formatMoney(-lineTotal) : formatMoney(lineTotal)
        ]);
      }

      if (shippingCost > 0 && !isRectifying) {
        tableData.push([{ content: 'Envio', imageData: null }, '1', formatMoney(shippingCost), formatMoney(shippingCost)]);
      }

      doc.autoTable({
        startY: isRectifying ? 106 : 102,
        head: [['Producto', 'Cantidad', 'Precio Unit.', 'Total']],
        body: tableData,
        theme: 'grid',
        headStyles: { fillColor: brandColor },
        styles: { fontSize: 9, valign: 'middle', cellPadding: 2.2, overflow: 'linebreak' },
        columnStyles: {
          0: { cellWidth: 96 },
          1: { cellWidth: 26, halign: 'center' },
          2: { cellWidth: 34, halign: 'right' },
          3: { cellWidth: 34, halign: 'right' },
        },
        didParseCell: (hookData) => {
          if (hookData.section === 'body' && hookData.column.index === 0) {
            const raw = hookData.cell.raw;
            const hasImage = Boolean(raw && typeof raw === 'object' && raw.imageData);
            if (raw && typeof raw === 'object') {
              hookData.cell.text = [String(raw.content || '')];
            }
            if (hasImage) {
              hookData.cell.styles.minCellHeight = 22;
              hookData.cell.styles.cellPadding = { top: 4, right: 2.2, bottom: 4, left: 20 };
            } else {
              hookData.cell.styles.cellPadding = { top: 3, right: 2.2, bottom: 3, left: 2.2 };
            }
          }
        },
        didDrawCell: (hookData) => {
          if (hookData.section !== 'body' || hookData.column.index !== 0) return;
          const raw = hookData.cell.raw;
          if (!raw || typeof raw !== 'object' || !raw.imageData) return;

          const imageSize = 14;
          const imageX = hookData.cell.x + 2;
          const imageY = hookData.cell.y + Math.max(1, (hookData.cell.height - imageSize) / 2);

          try {
            doc.addImage(raw.imageData, 'JPEG', imageX, imageY, imageSize, imageSize, undefined, 'FAST');
          } catch {
            try {
              doc.addImage(raw.imageData, 'PNG', imageX, imageY, imageSize, imageSize, undefined, 'FAST');
            } catch {}
          }
        },
        margin: { left: 14, right: 14 },
      });

      const finalY = doc.lastAutoTable.finalY + 8;
      doc.setFillColor(softBrand[0], softBrand[1], softBrand[2]);
      doc.roundedRect(106, finalY - 2, 90, 36, 2, 2, 'F');
      doc.setFontSize(10);
      doc.setTextColor(80, 80, 80);
      doc.text(isRectifying ? 'Subtotal rectificado' : 'Subtotal articulos', 112, finalY + 4);
      doc.text(formatMoney(isRectifying ? -refundCents : subtotal), 192, finalY + 4, { align: 'right' });
      doc.text(isRectifying ? 'Envio no devuelto' : 'Envio', 112, finalY + 9);
      doc.text(formatMoney(shippingCost), 192, finalY + 9, { align: 'right' });
      doc.text(isRectifying ? 'Base rectificada' : 'Base imponible', 112, finalY + 14);
      doc.text(formatMoney(vatBaseCents), 192, finalY + 14, { align: 'right' });
      doc.text(isRectifying ? `IVA rectificado (${formatPercent(INVOICE_VAT_RATE)})` : `IVA (${formatPercent(INVOICE_VAT_RATE)})`, 112, finalY + 19);
      doc.text(formatMoney(vatAmountCents), 192, finalY + 19, { align: 'right' });
      doc.setFontSize(12);
      doc.setTextColor(brandColor[0], brandColor[1], brandColor[2]);
      doc.text(isRectifying ? 'Total rectificativa' : 'Total factura', 112, finalY + 28);
      doc.text(formatMoney(invoiceTotalCents), 192, finalY + 28, { align: 'right' });

      doc.setFontSize(9);
      doc.setTextColor(120, 120, 120);
      doc.text('Factura emitida segun Reglamento de facturacion (RD 1619/2012).', 14, 286);
      doc.text(`Gracias por confiar en Elegilsa. Soporte: ${COMPANY_SUPPORT_EMAIL}`, 105, 291, { align: 'center' });

      return {
        invoice,
        customerName,
        doc,
        blob: doc.output('blob'),
      };
    }

    async function downloadInvoice(invoiceId, triggerButton = null) {
      const restoreButton = setInvoiceActionButtonState(triggerButton, true, 'Generando...');
      try {
        await waitForNextFrame();
        const { invoice, blob } = await buildInvoicePdf(invoiceId);
        downloadBlob(`Factura_Elegilsa_${invoice.id}.pdf`, blob);
      } catch (error) {
        const reason = error instanceof Error ? error.message : 'No se pudo generar la factura.';
        showGlobal('danger', reason);
      } finally {
        restoreButton();
      }
    }

    async function previewInvoice(invoiceId, triggerButton = null) {
      const restoreButton = setInvoiceActionButtonState(triggerButton, true, 'Abriendo...');
      try {
        await waitForNextFrame();
        const { invoice, customerName, blob } = await buildInvoicePdf(invoiceId);
        closeInvoicePreview();
        invoicePreviewUrl = URL.createObjectURL(blob);
        if (invoicePreviewTitle) {
          invoicePreviewTitle.textContent = `Vista previa · ${invoice.id}`;
        }
        if (invoicePreviewSubtitle) {
          invoicePreviewSubtitle.textContent = `${customerName} · ${formatDate(invoice.created_at)}`;
        }
        if (invoicePreviewFrame instanceof HTMLIFrameElement) {
          invoicePreviewFrame.src = invoicePreviewUrl;
        }
        if (!invoicePreviewModal?.open) {
          invoicePreviewModal?.showModal();
        }
      } catch (error) {
        const reason = error instanceof Error ? error.message : 'No se pudo abrir la factura.';
        showGlobal('danger', reason);
      } finally {
        restoreButton();
      }
    }

    async function refreshAll(tab = activeAdminTab) {
      const targetTab = Object.prototype.hasOwnProperty.call(panels, tab) ? tab : activeAdminTab;
      const needsCatalog = targetTab === 'products' || targetTab === 'categories';
      const needsBusiness = true;

      await Promise.all([
        needsCatalog ? ensureCatalogLoaded() : Promise.resolve(),
        needsBusiness ? refreshBusinessData() : Promise.resolve(),
      ]);

      if (needsCatalog) {
        populateCategorySelect();
      }

      renderActiveAdminTab(targetTab);
    }

    async function checkAuthAndInit() {
      hideAlert(authFeedback);
      hideAlert(globalFeedback);

      if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
        setAuthStatus('Faltan variables PUBLIC_SUPABASE_URL y PUBLIC_SUPABASE_ANON_KEY.');
        showAlert(authFeedback, 'danger', 'Configura variables publicas de Supabase para usar el panel admin.');
        return;
      }

      try {
        supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
          auth: { persistSession: true, autoRefreshToken: true },
        });
      } catch (error) {
        const reason = error instanceof Error ? error.message : 'Error desconocido.';
        showBootstrapError(`No se pudo inicializar Supabase: ${reason}`);
        return;
      }

      setAuthStatus('Comprobando permisos…');

      const { data, error } = await Promise.race([
        supabase.auth.getSession(),
        new Promise((resolve) => setTimeout(() => resolve({ data: { session: null }, error: new Error('timeout') }), 6500)),
      ]);

      if (error) {
        setAuthStatus('No se pudo validar sesion.');
        showAlert(authFeedback, 'danger', 'No se pudo comprobar la sesion. Revisa la conexion e intenta de nuevo.');
        return;
      }

      currentUser = data.session?.user || null;

      if (!currentUser) {
        setAuthStatus('No hay sesion iniciada.');
        showAlert(authFeedback, 'danger', 'Debes iniciar sesion para abrir el panel admin.');
        return;
      }

      if (!isAdminEmail(currentUser.email || '')) {
        setAuthStatus(`Sesion iniciada como ${currentUser.email || 'usuario'}, pero sin permisos de admin.`);
        showAlert(authFeedback, 'danger', 'Tu cuenta no esta autorizada para este panel. Configura PUBLIC_ADMIN_EMAILS.');
        return;
      }

      const initialTab = getInitialAdminTab();
      activeAdminTab = initialTab;

      try {
        await refreshAll(initialTab);
      } catch (catalogError) {
        setAuthStatus('Sesion valida, pero no se pudieron cargar datos.');
        showAlert(authFeedback, 'danger', `Error al cargar catalogo: ${catalogError.message || 'desconocido'}`);
        return;
      }

      setAuthStatus(`Sesion valida: ${currentUser.email || 'admin'}`);
      if (authGate) authGate.style.display = 'none';
      if (adminShell) {
        adminShell.style.display = 'grid';
        adminShell.querySelectorAll('.panel, .admin-panel').forEach((entry) => entry.classList.add('in-view'));
      }
      setTab(initialTab, { skipRouteSync: true });
    }

    tabs.forEach((tabLink) => {
      tabLink.addEventListener('click', (event) => {
        const nextTab = tabLink.getAttribute('data-tab');
        if (!nextTab) return;

        const targetRoute = ADMIN_TAB_ROUTES[nextTab];
        if (targetRoute && window.location.pathname !== targetRoute) {
          return;
        }

        event.preventDefault();
        setTab(nextTab);
      });
    });

    retryBtn?.addEventListener('click', checkAuthAndInit);

    compactSalesMonth?.addEventListener('change', () => {
      selectedCompactSalesMonth = compactSalesMonth.value || null;
      updateCompactSalesSummary(adminOrders);
    });

    compactSalesCompareMonth?.addEventListener('change', () => {
      selectedCompactSalesCompareMonth = compactSalesCompareMonth.value || '';
      if (selectedCompactSalesCompareMonth) {
        compactSalesView = 'chart';
        compactSalesViewToggle?.querySelectorAll('button[data-view]').forEach((entry) => {
          entry.classList.toggle('is-active', entry.getAttribute('data-view') === 'chart');
        });
      }
      updateCompactSalesSummary(adminOrders);
    });

    compactSalesViewToggle?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-view]');
      if (!button) return;
      compactSalesView = button.getAttribute('data-view') === 'chart' ? 'chart' : 'summary';
      compactSalesViewToggle.querySelectorAll('button[data-view]').forEach((entry) => {
        entry.classList.toggle('is-active', entry === button);
      });
      updateCompactSalesSummary(adminOrders);
    });

    productsFilterInput?.addEventListener('input', (event) => {
      productsFilter = event.target instanceof HTMLInputElement ? event.target.value : '';
      productsPage = 1;
      renderProductsTable();
    });

    productsPrevPageBtn?.addEventListener('click', () => {
      productsPage = Math.max(1, productsPage - 1);
      renderProductsTable();
    });

    productsNextPageBtn?.addEventListener('click', () => {
      productsPage += 1;
      renderProductsTable();
    });

    reloadCatalogBtn?.addEventListener('click', async () => {
      try {
        setCatalogStatus('warning', 'Actualizando catálogo...');
        await refreshAll();
      } catch (error) {
        showGlobal('danger', `No se pudo recargar el catálogo: ${error?.message || 'error desconocido'}`);
      }
    });

    addVariantBtn?.addEventListener('click', () => {
      if (!(productVariantsList instanceof HTMLElement)) return;
      const productId = String(productForm?.elements?.namedItem('id')?.value || '').trim();
      const imageOptions = getVariantImageOptions(productId);
      const rules = getVariantRules(productForm?.elements?.namedItem('category_id')?.value);
      productVariantsList.appendChild(createVariantRow({}, { rules, imageOptions }));
      applyVariantRulesToRows();
    });

    productVariantsList?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-action="remove-variant-row"]');
      if (!button) return;

      const row = button.closest('.admin-variant-row');
      if (!(row instanceof HTMLElement) || !(productVariantsList instanceof HTMLElement)) return;

      if (productVariantsList.querySelectorAll('.admin-variant-row').length <= 1) {
        showAlert(productFormFeedback, 'danger', 'Debe quedar al menos una variante.');
        return;
      }

      row.remove();
    });

    logoutBtn?.addEventListener('click', async () => {
      if (!supabase) return;
      await supabase.auth.signOut();
      window.location.href = '/perfil';
    });

    createProductBtn?.addEventListener('click', () => openProductModal());
    productCancelBtn?.addEventListener('click', () => productModal.close());
    productForm?.addEventListener('submit', saveProduct);
    productImageFileInput?.addEventListener('change', async () => {
      const file = productImageFileInput instanceof HTMLInputElement ? productImageFileInput.files?.[0] || null : null;
      if (!file) {
        uploadedProductImageDataUrl = null;
        setProductImagePreview('/catalogo/placeholder.svg');
        return;
      }

      try {
        uploadedProductImageDataUrl = await prepareProductImageData(file);
        setProductImagePreview(uploadedProductImageDataUrl);
      } catch (error) {
        uploadedProductImageDataUrl = null;
        if (productImageFileInput instanceof HTMLInputElement) {
          productImageFileInput.value = '';
        }
        const reason = error instanceof Error ? error.message : 'No se pudo leer la imagen seleccionada.';
        showAlert(productFormFeedback, 'danger', reason);
      }
    });
    productForm?.elements?.namedItem('name')?.addEventListener('input', () => {
      const slugInput = productForm.elements.namedItem('slug');
      if (!slugInput.value.trim()) {
        slugInput.value = toSlug(productForm.elements.namedItem('name').value);
      }
    });
    productForm?.elements?.namedItem('category_id')?.addEventListener('change', () => {
      applyVariantRulesToRows();
    });

    createCategoryBtn?.addEventListener('click', () => openCategoryModal());
    categoryCancelBtn?.addEventListener('click', () => categoryModal.close());
    categoryForm?.addEventListener('submit', saveCategory);
    categoryForm?.elements?.namedItem('name')?.addEventListener('input', () => {
      const slugInput = categoryForm.elements.namedItem('slug');
      if (!slugInput.value.trim()) {
        slugInput.value = toSlug(categoryForm.elements.namedItem('name').value);
      }
    });

    refreshInvoicesBtn?.addEventListener('click', async () => {
      await refreshBusinessData();
      renderInvoicesTable();
    });

    invoiceCustomerFilterInput?.addEventListener('input', (event) => {
      invoiceCustomerFilter = event.target instanceof HTMLInputElement ? event.target.value : '';
      renderInvoicesTable();
    });

    usersFilterInput?.addEventListener('input', (event) => {
      usersFilter = event.target instanceof HTMLInputElement ? event.target.value : '';
      renderUsersTable();
    });

    productImagesAddBtn?.addEventListener('click', async () => {
      if (!currentImagesProductId) return;

      const imageFile = productImagesNewFile instanceof HTMLInputElement ? productImagesNewFile.files?.[0] || null : null;
      const altText = String(productImagesNewAlt?.value || '').trim();
      if (!imageFile) {
        showAlert(productImagesFeedback, 'danger', 'Adjunta una imagen para continuar.');
        return;
      }

      await addProductImage(currentImagesProductId, altText, imageFile);
      if (productImagesNewFile instanceof HTMLInputElement) {
        productImagesNewFile.value = '';
      }
      if (productImagesNewAlt instanceof HTMLInputElement) {
        productImagesNewAlt.value = '';
      }
    });

    productImagesList?.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!action || !id) return;

      if (action === 'save-product-image') {
        await saveProductImage(id);
      }

      if (action === 'set-primary-product-image') {
        await setPrimaryProductImage(currentImagesProductId, id);
      }

      if (action === 'delete-product-image') {
        const shouldDelete = window.confirm('¿Seguro que quieres borrar esta imagen?');
        if (!shouldDelete) return;
        await deleteProductImage(id);
      }
    });

    productsTableBody?.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'edit-product') {
        openProductModal(id);
      }

      if (action === 'manage-product-images') {
        openProductImagesModal(id);
      }

      if (action === 'toggle-product-visibility') {
        const nextActive = button.getAttribute('data-next-active') === '1';
        await toggleProductVisibility(id, nextActive);
      }

      if (action === 'delete-product') {
        const shouldDelete = window.confirm('¿Seguro que quieres borrar este producto?');
        if (!shouldDelete) return;
        await deleteProduct(id);
      }
    });

    categoriesTableBody?.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'view-category-products') {
        openCategoryProductsModal(id);
      }

      if (action === 'edit-category') {
        openCategoryModal(id);
      }
      if (action === 'delete-category') {
        const shouldDelete = window.confirm('¿Seguro que quieres borrar esta categoria?');
        if (!shouldDelete) return;
        await deleteCategory(id);
      }
    });

    ordersTableBody?.addEventListener('change', (event) => {
      const target = event.target;
      const action = target.getAttribute('data-action');
      const id = target.getAttribute('data-id');
      if (!action || !id) return;

      if (action === 'order-status') {
        updateOrderStatus(id, target.value);
      }

      if (action === 'return-status') {
        updateReturnStatus(id, target.value);
      }
    });

    ordersTableBody?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'invoice-order') {
        createInvoiceFromOrder(id);
      }

      if (action === 'request-return') {
        requestReturn(id);
      }
    });

    invoicesTableBody?.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action');
      const id = button.getAttribute('data-id');
      if (!id) return;

      if (action === 'preview-invoice') {
        previewInvoice(id, button);
      }

      if (action === 'download-invoice') {
        downloadInvoice(id, button);
      }
    });

    setAuthStatus('Inicializando panel admin…');
    checkAuthAndInit().catch((error) => {
      const reason = error instanceof Error ? error.message : 'Error inesperado.';
      showBootstrapError(`No se pudo iniciar el panel: ${reason}`);
    });
  </script>


