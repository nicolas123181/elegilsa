    function formatMoney(cents) {
      return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format((Number(cents) || 0) / 100);
    }

    function formatDate(iso) {
      if (!iso) return '—';
      return new Intl.DateTimeFormat('es-ES', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(iso));
    }

    function normalizeOrderStatus(status, paymentMethod, row = null) {
      const raw = String(status || '').trim().toLowerCase();
      const method = String(paymentMethod || '').trim().toLowerCase();
      const hasStripeEvidence = Boolean(row?.stripe_session_id || row?.stripe_payment_intent_id);

      if (raw === 'returned' || raw === 'devuelto' || raw === 'refunded') {
        return 'returned';
      }

      if (raw === 'paid' || raw === 'cancelled' || raw === 'pending') {
        if (raw === 'pending' && method === 'stripe' && hasStripeEvidence) return 'paid';
        return raw;
      }

      if (raw === 'completed' || raw === 'success' || raw === 'succeeded') {
        return 'paid';
      }

      if (!raw && method === 'stripe' && hasStripeEvidence) {
        return 'paid';
      }

      return 'pending';
    }

    function isPriorityShippingOrder(order) {
      const method = String(order?.shipping_method || '').trim().toLowerCase();
      return method === 'express' || (Number(order?.shipping_cents) || 0) > 0;
    }

    function getShippingLabel(order) {
      const express = isPriorityShippingOrder(order);
      const shippingCost = Number(order?.shipping_cents) || 0;
      const priceText = shippingCost > 0 ? formatMoney(shippingCost) : 'Gratis';
      return {
        title: express ? 'Express prioritario' : 'Estandar',
        subtitle: express ? `Llega antes · ${priceText}` : `Entrega regular · ${priceText}`,
        express,
      };
    }

    function sortOrdersByShippingPriority(records) {
      return [...(Array.isArray(records) ? records : [])].sort((a, b) => {
        const shippingDelta = Number(isPriorityShippingOrder(b)) - Number(isPriorityShippingOrder(a));
        if (shippingDelta !== 0) return shippingDelta;
        return +new Date(b?.created_at || 0) - +new Date(a?.created_at || 0);
      });
    }

    function formatPercent(value) {
      return `${((Number(value) || 0) * 100).toFixed(0)}%`;
    }

    function toFiscalNumber(invoice) {
      const createdAt = new Date(invoice?.created_at || Date.now());
      const year = Number.isFinite(createdAt.getTime()) ? createdAt.getFullYear() : new Date().getFullYear();
      const compactId = String(invoice?.id || '')
        .replace(/[^a-zA-Z0-9]/g, '')
        .toUpperCase();
      const suffix = (compactId.slice(-6) || `${Date.now()}`.slice(-6)).padStart(6, '0');
      return `${INVOICE_SERIES}-${year}-${suffix}`;
    }

    function toSlug(value) {
      return String(value || '')
        .trim()
        .toLowerCase()
        .normalize('NFD')
        .replace(/[^\w\s-]/g, '')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-');
    }

    function euroToCents(value) {
      const n = Number(value);
      if (!Number.isFinite(n) || n < 0) return 0;
      return Math.round(n * 100);
    }

    function showAlert(target, type, message) {
      if (!target) return;
      target.textContent = message;
      target.classList.remove('ok', 'danger');
      target.classList.add(type === 'ok' ? 'ok' : 'danger');
      target.style.display = 'block';
    }

    function hideAlert(target) {
      if (!target) return;
      target.style.display = 'none';
    }

    function getReturnRefundCents(order) {
      const subtotal = Math.max(0, Number(order?.subtotal_cents) || 0);
      if (subtotal > 0) return subtotal;
      const total = Math.max(0, Number(order?.total_cents) || 0);
      const shipping = Math.max(0, Number(order?.shipping_cents) || 0);
      return Math.max(0, total - shipping);
    }

    function normalizeSearchText(value) {
      return String(value || '')
        .trim()
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');
    }

    function showGlobal(type, message) {
