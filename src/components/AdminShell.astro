    function renderUsersTable() {
      const orders = adminOrders;
      const grouped = new Map();

      for (const order of orders) {
        const key = String(order.user_id || order.shipping?.email || order.shipping?.full_name || 'anonimo');
        const prev = grouped.get(key) || {
          name: order.shipping?.full_name || key,
          orders: 0,
          total: 0,
          last: null,
        };
        prev.orders += 1;
        prev.total += Number(order.total_cents) || 0;
        if (!prev.last || new Date(order.created_at) > new Date(prev.last)) {
          prev.last = order.created_at;
        }
        grouped.set(key, prev);
      }

      const rows = [...grouped.entries()]
        .map(([key, user]) => ({ ...user, key }))
        .sort((a, b) => b.total - a.total)
        .map((user, index) => ({ ...user, displayId: index + 1 }));

      const search = normalizeSearchText(usersFilter);
      const filteredRows = rows.filter((user) => {
        if (!search) return true;
        return normalizeSearchText(`${user.displayId} ${user.name} ${user.key}`).includes(search);
      });

      usersTableBody.innerHTML = filteredRows.length
        ? filteredRows
            .map((user) => `<tr><td>${user.displayId}</td><td>${escapeHtml(user.name)}</td><td>${user.orders}</td><td>${formatMoney(user.total)}</td><td>${formatDate(user.last)}</td></tr>`)
            .join('')
        : `<tr><td colspan="5">${rows.length ? 'No hay usuarios que coincidan con la busqueda.' : 'No hay usuarios con pedidos.'}</td></tr>`;
    }

    function downloadText(filename, content) {
      const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    function downloadBlob(filename, blob) {
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      window.setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function ensureInvoice(order) {
      const invoices = readLocalArray(INVOICES_KEY);
      const existing = invoices.find((invoice) => invoice.order_id === order.id && String(invoice.kind || 'standard') !== 'rectifying');
      if (existing) return existing;

      const invoice = {
        id: `FAC-${Date.now()}`,
        order_id: order.id,
        created_at: new Date().toISOString(),
        total_cents: Number(order.total_cents) || 0,
        customer: order.shipping?.full_name || order.user_id || 'Cliente',
        kind: 'standard',
        refund_cents: 0,
        shipping_non_refunded_cents: 0,
        original_invoice_id: null,
      };

      invoices.unshift(invoice);
      writeLocalArray(INVOICES_KEY, invoices);
      adminInvoices = buildDerivedInvoices(adminOrders, mergeRecords(adminInvoices, invoices));
      return invoice;
    }

    function ensureRectifyingInvoice(order) {
      const invoices = readLocalArray(INVOICES_KEY);
      const existing = invoices.find((invoice) => invoice.order_id === order.id && String(invoice.kind || '') === 'rectifying');
      if (existing) return existing;

      const originalInvoice = ensureInvoice(order);
      const refundCents = getReturnRefundCents(order);
      const shippingNonRefundedCents = Math.max(0, Number(order?.shipping_cents) || 0);

      const invoice = {
        id: `RCT-${Date.now()}`,
        order_id: order.id,
        created_at: new Date().toISOString(),
        total_cents: refundCents,
        refund_cents: refundCents,
        shipping_non_refunded_cents: shippingNonRefundedCents,
        customer: order.shipping?.full_name || order.user_id || 'Cliente',
        kind: 'rectifying',
        original_invoice_id: originalInvoice?.id || null,
      };

      invoices.unshift(invoice);
      writeLocalArray(INVOICES_KEY, invoices);
      adminInvoices = buildDerivedInvoices(adminOrders, mergeRecords(adminInvoices, invoices));
      return invoice;
    }

